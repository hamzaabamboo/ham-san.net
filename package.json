{
  "name": "ham-san-net",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "compose:dev": "docker compose -f docker-compose.dev.yml",
    "prepare": "husky install && bun codegen:api && nx sync client && nx run-many -p client, astro -t prepare",
    "codegen": "nx run-many -p client, astro -t codegen",
    "check": "nx run-many -p client, astro -t lint, format",
    "fix": "nx run-many -p client, astro -t fix:all",
    "codegen:prod": "nx run-many -p client, astro -t codegen:prod",
    "check:react-astro": "bash ./tools/check-react-astro.sh",
    "test": "echo \"Error: no test specified\" && exit 1",
    "codegen:api": "bunx openapi-typescript https://raw.githubusercontent.com/outline/openapi/main/spec3.yml -o ./libs/outline/schema.ts"
  },
  "lint-staged": {
    "client/*.{ts,tsx,svelte}": "eslint --fix",
    "astro/*.{astro,ts,tsx,svelte}": "eslint --fix"
  },
  "dependencies": {
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "openapi-fetch": "^0.10.2",
    "postcss-import": "^16.1.0",
    "tslib": "^2.6.3",
    "typescript-eslint": "^7.15.0",
    "vite": "^5.3.3"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@eslint/js": "9.1.1",
    "@nrwl/devkit": "18.3.3",
    "@nrwl/linter": "18.3.3",
    "@nx-tools/nx-container": "^5.3.1",
    "@nx/eslint": "18.3.3",
    "@nx/eslint-plugin": "18.3.3",
    "@nx/jest": "18.3.3",
    "@nx/js": "18.3.3",
    "@nxext/sveltekit": "18.0.0",
    "@pandabox/prettier-plugin": "^0.1.3",
    "@types/jest": "^29.5.12",
    "@types/node": "20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "~9.1.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "lerna": "^8.1.5",
    "lint-staged": "^15.2.7",
    "nx": "18.3.3",
    "nx-cloud": "18.0.0",
    "openapi-typescript": "^7.0.2",
    "prettier": "^3.3.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^3.5.1",
    "ts-jest": "^29.1.5",
    "ts-node": "10.9.2",
    "typescript": "^5.5.3"
  },
  "nx": {
    "targets": {}
  },
  "resolutions": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "sharp"
    ]
  },
  "overrides": {
    "@radix-ui/react-slot": "1.2.3",
    "graphql": "16.12.0",
    "nexus>graphql": "16.12.0"
  }
}
