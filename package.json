{
  "name": "ham-san-net",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "compose:dev": "docker compose -f docker-compose.dev.yml",
    "clean:containers": "bash ./tools/cleanup-container-artifacts.sh",
    "prepare": "husky install && bun codegen:api && nx sync client && nx run-many -p client, astro -t prepare",
    "codegen": "nx run-many -p client, astro -t codegen",
    "check": "nx run-many -p client, astro -t lint, format",
    "fix": "nx run-many -p client, astro -t fix:all",
    "codegen:prod": "nx run-many -p client, astro -t codegen:prod",
    "check:react-astro": "bash ./tools/check-react-astro.sh",
    "test": "echo \"Error: no test specified\" && exit 1",
    "codegen:api": "bunx openapi-typescript https://raw.githubusercontent.com/outline/openapi/main/spec3.yml -o ./libs/outline/schema.ts"
  },
  "lint-staged": {
    "client/*.{ts,tsx,svelte}": "eslint --fix",
    "astro/*.{astro,ts,tsx,svelte}": "eslint --fix"
  },
  "dependencies": {
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "openapi-fetch": "^0.17.0",
    "postcss-import": "^16.1.1",
    "tslib": "^2.8.1",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "10.0.1",
    "@nrwl/devkit": "19.8.4",
    "@nrwl/linter": "19.8.4",
    "@nx-tools/nx-container": "^7.2.3",
    "@nx/eslint": "22.7.5",
    "@nx/eslint-plugin": "22.7.5",
    "@nx/jest": "22.7.5",
    "@nx/js": "22.7.5",
    "@nxext/sveltekit": "21.0.0",
    "@pandabox/prettier-plugin": "^0.1.3",
    "@types/jest": "^30.0.0",
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "~10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-node": "^30.4.1",
    "lerna": "^9.0.7",
    "lint-staged": "^17.0.7",
    "nx": "22.7.5",
    "nx-cloud": "19.1.3",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-svelte": "^4.1.0",
    "ts-jest": "^29.4.11",
    "ts-node": "10.9.2",
    "typescript": "^6.0.3"
  },
  "nx": {
    "targets": {}
  },
  "resolutions": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "sharp"
    ]
  },
  "overrides": {
    "@radix-ui/react-slot": "1.2.3",
    "graphql": "16.14.1"
  }
}
