{
  "name": "astro",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/astro/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/astro",
        "command": "bun run build"
      }
    },
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": ["build"],
      "defaultConfiguration": "local",
      "options": {
        "engine": "docker",
        "context": "{workspaceRoot}",
        "file": "Dockerfile",
        "target": "astro"
      },
      "configurations": {
        "local": {
          "tags": ["ham-san-net-astro:latest"],
          "push": false
        },
        "production": {
          "tags": ["registry.ham-san.net/ham-san-net-astro:latest"],
          "push": true
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/astro/**/*.{ts,tsx,astro}"]
      }
    }
  }
}
