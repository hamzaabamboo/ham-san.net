---
import { HStack, Stack, Wrap } from 'styled-system/jsx';
import { useTranslations, validateLocale } from '~/i18n/utils';
import { BrandMark } from '../brand/BrandMark';
import { Link } from '../ui/link';
import { Text } from '../ui/text';

const locale = validateLocale(Astro.params.locale) ? Astro.params.locale : 'en';
const t = useTranslations(locale);
---

<Wrap
  _print={{ display: 'none' }}
  w="full"
  py="6"
  px={{ base: '4', md: '8' }}
  justifyContent="space-between"
  alignItems="center"
  bg="bg.default"
  color="fg.muted"
  borderTop="1px solid"
  borderColor="border.subtle"
  fontSize="sm"
>
  <Stack gap="2">
    <HStack gap="3" alignItems="center">
      <BrandMark size={22} />
      <Text textTransform="uppercase" letterSpacing="0.18em" fontWeight="bold" fontSize="xs">
        atelier log
      </Text>
    </HStack>
    <Text fontFamily="JetBrains Mono, monospace" fontSize="xs">
      {t('common.copyright')}
    </Text>
  </Stack>
  <HStack gap="6">
    <Link
      target="_blank"
      rel="noreferrer"
      href="https://github.com/hamzaabamboo/ham-san.net"
      fontFamily="JetBrains Mono, monospace"
      textTransform="uppercase"
      fontSize="xs"
      letterSpacing="0.12em"
      _hover={{ color: 'amber.500' }}
      transition="colors"
    >
      {t('common.view-source')}
    </Link>
  </HStack>
</Wrap>
