---
import { useTranslations, validateLocale } from '~/i18n/utils';

const locale = validateLocale(Astro.params.locale) ? Astro.params.locale : 'en';
const t = useTranslations(locale);
---

<footer class="shell-footer">
  <div style="font-family:'JetBrains Mono',monospace;font-size:11px;text-transform:uppercase;color:#FFB000;opacity:0.8">
    {t('common.copyright')}
  </div>
  <div style="display:flex;gap:2rem;align-items:center">
    <a
      target="_blank"
      rel="noreferrer"
      href="https://github.com/hamzaabamboo/ham-san.net"
      style="font-family:'JetBrains Mono',monospace;font-size:10px;text-transform:uppercase;color:#c7c6c6;text-decoration:none;transition:color 0.15s ease"
      class="shell-footer-link"
    >
      GitHub
    </a>
    <a
      target="_blank"
      rel="noreferrer"
      href="https://www.linkedin.com/in/tvittayapalotai/"
      style="font-family:'JetBrains Mono',monospace;font-size:10px;text-transform:uppercase;color:#c7c6c6;text-decoration:none;transition:color 0.15s ease"
      class="shell-footer-link"
    >
      LinkedIn
    </a>
    <a
      href={`/${locale}/rss.xml`}
      style="font-family:'JetBrains Mono',monospace;font-size:10px;text-transform:uppercase;color:#c7c6c6;text-decoration:none;transition:color 0.15s ease"
      class="shell-footer-link"
    >
      RSS
    </a>
    <a
      href={`/${locale}/sitemap.xml`}
      style="font-family:'JetBrains Mono',monospace;font-size:10px;text-transform:uppercase;color:#c7c6c6;text-decoration:none;transition:color 0.15s ease"
      class="shell-footer-link"
    >
      Sitemap
    </a>
  </div>
</footer>
