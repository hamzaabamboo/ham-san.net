---
import { Wrap } from 'styled-system/jsx';
import { useTranslations, validateLocale } from '~/i18n/utils';
import { Link } from '../ui/link';
import { Text } from '../ui/text';

const locale = validateLocale(Astro.params.locale) ? Astro.params.locale : 'en';
const t = useTranslations(locale);
---

<Wrap
  _print={{ display: 'none' }}
  w="full"
  py="8"
  px="8"
  justifyContent="space-between"
  alignItems="center"
  bg="bg.default"
  color="fg.muted"
  borderTop="1px solid"
  borderColor="border.subtle"
  fontSize="sm"
>
  <Text>{t('common.copyright')}</Text>
  <Link
    target="_blank"
    rel="noreferrer"
    href="https://github.com/hamzaabamboo/ham-san.net"
    _hover={{ color: 'fg.default' }}
    transition="colors"
  >
    {t('common.view-source')}
  </Link>
</Wrap>
