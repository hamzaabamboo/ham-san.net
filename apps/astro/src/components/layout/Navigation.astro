---
import { languages } from '~/i18n/ui';
import { getLangFromUrl, useTranslations } from '~/i18n/utils';
import { BrandMark } from '~/components/brand/BrandMark';
import { Sidebar } from './Sidebar';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const getURLWithLanguage = (value: string) => {
  return `/${lang}${value}`;
};

const getCurrentURLWithLanguage = (language: string) => {
  const [, , ...currentPath] = Astro.url.pathname.split('/');
  return `/${language}/${currentPath.join('/')}`;
};

const NAVIGATION_LINKS = [
  { label: t('common.projects'), value: '/projects' },
  { label: t('common.note'), value: '/notes' },
  { label: t('common.hobbies'), value: '/hobbies' },
  { label: t('common.event'), value: '/events' },
  { label: t('common.about-me'), value: '/about' },
  { label: t('common.contact'), value: '/contact' }
];
---

<script>
  const nav = document.getElementById('main-nav');
  const updateNav = () => {
    if (!nav) return;
    if (window.scrollY > 50) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  };
  window.addEventListener('scroll', updateNav);
  updateNav();
</script>

<nav id="main-nav" class="shell-nav">
  <a href={getURLWithLanguage('/')} class="shell-nav-brand">
    <BrandMark />
    <span class="shell-nav-brand-text">Ham</span>
  </a>

  <div class="shell-nav-links">
    {
      NAVIGATION_LINKS.map(({ label, value }) => {
        const fullPath = getURLWithLanguage(value);
        const isCurrent =
          value === '/' ? Astro.url.pathname === fullPath : Astro.url.pathname.startsWith(fullPath);

        return (
          <a href={fullPath} class="shell-nav-link" aria-current={isCurrent ? 'page' : undefined}>
            {label}
          </a>
        );
      })
    }
  </div>

  <div class="shell-nav-actions">
    <div class="shell-nav-lang-group">
      {
        Object.entries(languages)
          .filter((entry) => entry[0] !== lang)
          .map((entry) => (
            <a href={getCurrentURLWithLanguage(entry[0])} class="shell-nav-lang">
              {entry[0]}
            </a>
          ))
      }
    </div>
    <Sidebar links={NAVIGATION_LINKS} locale={lang} pathname={Astro.url.pathname} client:visible />
  </div>
</nav>
