---
import { Box, Grid, HStack, Stack } from 'styled-system/jsx';
import { Heading } from '~/components/ui/heading';
import { Text } from '~/components/ui/text';
import type { Languages } from '~/i18n/ui';
import { useTranslations } from '~/i18n/utils';

interface Props {
  locale: Languages;
}

const { locale } = Astro.props as Props;
const t = useTranslations(locale);
---

<Grid
  gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)' }}
  borderTop="1px solid"
  borderColor="#524533"
>
  <Stack
    p="8"
    gap="3"
    borderRight={{ md: '1px solid' }}
    borderBottom={{ base: '1px solid', md: 'none' }}
    borderColor="#524533"
  >
    <Text
      fontFamily="JetBrains Mono, monospace"
      fontSize="xs"
      textTransform="uppercase"
      letterSpacing="widest"
      color="#4c4e4e">{t('home.status-current-phase')}</Text
    >
    <Heading fontSize="2xl">{t('home.status-phase-title')}</Heading>
  </Stack>

  <Stack p="8" gap="3" bg="#1c1b1b">
    <Text
      fontFamily="JetBrains Mono, monospace"
      fontSize="xs"
      textTransform="uppercase"
      letterSpacing="widest"
      color="#4c4e4e">{t('home.status-availability')}</Text
    >
    <HStack gap="3" alignItems="start">
      <Box position="relative" w="3" h="3" mt="2.5" flexShrink="0">
        <Box w="3" h="3" bg="emerald.500" />
        <Box
          position="absolute"
          inset="0"
          w="3"
          h="3"
          bg="emerald.500"
          className="animate-ping"
          opacity="0.5"
        />
      </Box>
      <Heading fontSize="2xl">{t('home.status-availability-title')}</Heading>
    </HStack>
  </Stack>
</Grid>
