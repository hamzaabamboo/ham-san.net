---
import { Box, Container, Flex, Grid, Stack } from 'styled-system/jsx';
import { getMediaUrl } from 'utils/media';
import SpecLabel from '~/components/common/SpecLabel';
import { Heading } from '~/components/ui/heading';
import { Text } from '~/components/ui/text';
import { graphQLSdk } from '~/graphql';
import type { ProjectPreviewFragment } from '~/graphql/generated/client';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import StatusRow from '~/components/home/StatusRow.astro';
import { withLastGood } from '~/utils/cms-cache';
import { pickLocale } from '~/utils/fallbackLocale';
import { projectMonogram } from '~/utils/monogram';
import { cleanProjectCopy } from '~/utils/project-copy';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.home')} | ${t('common.name')}`;

const cmsLocale = locale === 'ja' ? 'ja' : 'en';

let homepageData: any = null;
let projects: ProjectPreviewFragment[] = [];
let homeUnavailable = false;

try {
  const data = await withLastGood(`home:${cmsLocale}`, () =>
    graphQLSdk.fetchHomePage({ locale: cmsLocale })
  );
  homepageData = data?.homepage;
  const rawProjects = data?.projects ?? [];
  projects = rawProjects
    .map((p) => pickLocale(p, locale))
    .filter((p): p is ProjectPreviewFragment => !!p)
    .map((p) => cleanProjectCopy(p));
} catch {
  homepageData = null;
  projects = [];
  homeUnavailable = true;
}

const introImage =
  getMediaUrl(
    homepageData?.introductionImage?.url,
    { height: 700 },
    import.meta.env.PUBLIC_API_URL
  ) || null;

const heroProjects = projects.slice(0, 3);
const yearPartFormatter = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  timeZone: 'Asia/Tokyo'
});
const yearLabel = (year?: string) =>
  year
    ? (yearPartFormatter
        .formatToParts(new Date(`${year}-01-01T00:00:00+09:00`))
        .find((part) => part.type === 'year')?.value ?? year)
    : undefined;

Astro.response.headers.set(
  'CDN-Cache-Control',
  homeUnavailable ? 'public, max-age=60, must-revalidate' : 'public, max-age=3600, must-revalidate'
);
---

<MainLayout title={pageTitle} description={t('home.hero-subtitle').replace(/<[^>]*>/g, '')}>
  <Container maxW="breakpoint-xl" className="page-shell">
    <Stack py={{ base: '8', md: '10' }} gap="0">
      <Grid
        gridTemplateColumns={{ base: '1fr', lg: 'minmax(0, 1.6fr) 400px' }}
        gap="12"
        px={{ base: '0', lg: '6' }}
        py={{ base: '20', lg: '32' }}
        borderBottom="1px solid"
        borderColor="#524533"
      >
        <Stack gap="8">
          <Box
            display="inline-flex"
            alignItems="center"
            px="3"
            py="1"
            bg="#353534"
            border="1px solid"
            borderColor="#524533"
            fontFamily="JetBrains Mono, monospace"
            fontSize="10px"
            textTransform="uppercase"
            letterSpacing="0.12em"
            color="#ffd597"
            w="fit-content"
          >
            {t('home.operational-status')}
          </Box>
          <Heading
            as="h1"
            fontSize={{ base: '5xl', md: '6xl', lg: '7xl' }}
            lineHeight={locale === 'th' ? '1.15' : locale === 'ja' ? '1.05' : '0.95'}
            fontStyle="italic"
            style={locale === 'ja' ? { wordBreak: 'auto-phrase' } : undefined}
          >
            {t('home.hero-heading-prefix')}
            <Box as="span" display="block" color="#ffb000">
              {t('home.hero-heading-emphasis')}
            </Box>
          </Heading>
          <p class="hero-subtitle" set:html={t('home.hero-subtitle')} />
          <Flex gap="4" wrap="wrap" pt="2">
            <a
              href={`/${locale}/projects`}
              class="home-hero-cta home-hero-cta-primary blocky-shadow blocky-shadow-hover"
            >
              {t('home.view-my-work')}
            </a>
            <a href={`/${locale}/hobbies`} class="home-hero-cta cta-secondary">
              {t('home.explore-hobbies')}
            </a>
          </Flex>
        </Stack>
        <Stack gap="2">
          <Box
            position="relative"
            border="1px solid"
            borderColor="#524533"
            p="4"
            bg="#0e0e0e"
            overflow="hidden"
            minH={{ base: '360px', lg: 'auto' }}
          >
            <Box aspectRatio="1 / 1" overflow="hidden" position="relative">
              {
                introImage ? (
                  <img
                    src={introImage}
                    alt="Profile"
                    style={{
                      width: '100%',
                      height: '100%',
                      objectFit: 'cover',
                      filter: 'saturate(1.12) contrast(1.04)',
                      opacity: 0.92
                    }}
                  />
                ) : (
                  <Box
                    position="relative"
                    w="100%"
                    h="100%"
                    bg="#0e0e0e"
                    className="fallback-grid-lines"
                    overflow="hidden"
                  >
                    <Box
                      position="absolute"
                      bottom="-20px"
                      right="-10px"
                      fontFamily="Newsreader, serif"
                      fontStyle="italic"
                      fontSize="280px"
                      lineHeight="1"
                      color="#e5e2e1"
                      opacity="0.04"
                      userSelect="none"
                      pointerEvents="none"
                      aria-hidden="true"
                    >
                      H
                    </Box>
                    <Box
                      position="absolute"
                      top="50%"
                      left="50%"
                      transform="translate(-50%, -50%)"
                      fontFamily="JetBrains Mono, monospace"
                      fontSize="10px"
                      textTransform="uppercase"
                      letterSpacing="0.15em"
                      color="#524533"
                      textAlign="center"
                    >
                      {t('home.no-photo')}
                    </Box>
                  </Box>
                )
              }
            </Box>
          </Box>
        </Stack>
      </Grid>

      <Box px={{ base: '0', lg: '6' }}>
        <StatusRow locale={locale} />
      </Box>

      <Box
        px={{ base: '0', lg: '6' }}
        py={{ base: '8', lg: '16' }}
        borderBottom="1px solid"
        borderColor="#524533"
      >
        <Stack gap="2" mb="12">
          <Text fontFamily="JetBrains Mono, monospace" fontSize="xs" color="#ffd597"
            >{t('home.about-me')}</Text
          >
          <Heading as="h2" fontSize="5xl" fontStyle="italic">{t('home.bench-heading')}</Heading>
          <Text color="#9f8e78" fontSize="sm" maxW="lg">
            {t('home.bench-subtitle')}
          </Text>
        </Stack>
        <Grid gridTemplateColumns={{ base: '1fr', md: 'repeat(12, 1fr)' }} gap="6">
          <Box
            gridColumn={{ base: 'span 1', md: 'span 7' }}
            position="relative"
            border="1px solid"
            borderColor="#524533"
            bg="#1c1b1b"
            p="8"
            className="blocky-shadow-sm"
          >
            <Stack gap="6">
              <Heading as="h3" fontSize="4xl" fontStyle="italic">
                {t('home.bench-manifesto-heading')}{locale === 'ja' ? '' : ' '}
                <Box as="span" fontStyle="italic">{t('home.bench-manifesto-emphasis')}</Box>
              </Heading>
              <Text color="#c7c6c6" lineHeight="relaxed">
                {t('home.bench-manifesto-body')}
              </Text>
              <Flex gap="2" wrap="wrap">
                <Box
                  px="3"
                  py="1"
                  bg="#353534"
                  border="1px solid"
                  borderColor="#524533"
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase">{t('home.bench-principle-clear')}</Box
                >
                <Box
                  px="3"
                  py="1"
                  bg="#353534"
                  border="1px solid"
                  borderColor="#524533"
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase">{t('home.bench-principle-useful')}</Box
                >
                <Box
                  px="3"
                  py="1"
                  bg="#353534"
                  border="1px solid"
                  borderColor="#524533"
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase">{t('home.bench-principle-maintainable')}</Box
                >
              </Flex>
            </Stack>
          </Box>

          <Box
            gridColumn={{ base: 'span 1', md: 'span 5' }}
            position="relative"
            border="1px solid"
            borderColor="#524533"
            bg="#1c1b1b"
            p="8"
            className="blocky-shadow-sm"
          >
            <SpecLabel>{t('home.bench-tools-label')}</SpecLabel>
            <Grid mt="6" gridTemplateColumns="1fr 1fr" gap="4">
              <Stack borderLeft="2px solid" borderLeftColor="#ffb000" pl="4" gap="1">
                <Text fontFamily="JetBrains Mono, monospace" fontSize="10px" color="#4c4e4e"
                  >{t('home.bench-tools-frontend')}</Text
                >
                <Text fontFamily="Manrope, sans-serif" fontWeight="bold" fontSize="lg"
                  >React / Next.js</Text
                >
              </Stack>
              <Stack borderLeft="2px solid" borderLeftColor="#ffb000" pl="4" gap="1">
                <Text fontFamily="JetBrains Mono, monospace" fontSize="10px" color="#4c4e4e"
                  >{t('home.bench-tools-styling')}</Text
                >
                <Text fontFamily="Manrope, sans-serif" fontWeight="bold" fontSize="lg"
                  >Tailwind CSS</Text
                >
              </Stack>
              <Stack borderLeft="2px solid" borderLeftColor="#ffb000" pl="4" gap="1">
                <Text fontFamily="JetBrains Mono, monospace" fontSize="10px" color="#4c4e4e"
                  >{t('home.bench-tools-design')}</Text
                >
                <Text fontFamily="Manrope, sans-serif" fontWeight="bold" fontSize="lg"
                  >Figma / WebGL</Text
                >
              </Stack>
              <Stack borderLeft="2px solid" borderLeftColor="#ffb000" pl="4" gap="1">
                <Text fontFamily="JetBrains Mono, monospace" fontSize="10px" color="#4c4e4e"
                  >{t('home.bench-tools-scripting')}</Text
                >
                <Text fontFamily="Manrope, sans-serif" fontWeight="bold" fontSize="lg"
                  >Node.js / Python</Text
                >
              </Stack>
            </Grid>
          </Box>
        </Grid>
      </Box>

      <Box
        px={{ base: '0', lg: '6' }}
        py={{ base: '16', lg: '20' }}
        borderTop="1px solid"
        borderColor="#524533"
      >
        <Box mb="12" borderBottom="1px solid" borderColor="#524533" pb="6">
          <Heading as="h2" fontSize="5xl" fontStyle="italic">
            {t('home.featured-projects')}
          </Heading>
        </Box>
        {
          heroProjects.length > 0 ? (
            <Grid
              gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)', lg: 'repeat(3, 1fr)' }}
              gap="0"
              borderTop="1px solid"
              borderLeft="1px solid"
              borderColor="#524533"
              mb="20"
            >
              {heroProjects.map((project) => {
                const imgSrc = project.banner?.url
                  ? getMediaUrl(project.banner.url, { height: 600 }, import.meta.env.PUBLIC_API_URL)
                  : project.media?.[0]?.url
                    ? getMediaUrl(
                        project.media[0].url,
                        { height: 600 },
                        import.meta.env.PUBLIC_API_URL
                      )
                    : null;
                return (
                  <a
                    href={`/${locale}/projects/${project.slug}`}
                    class="project-card"
                    style="display:flex;flex-direction:column;height:100%;border-right:1px solid #524533;border-bottom:1px solid #524533;overflow:hidden;background:#131313;cursor:pointer;text-decoration:none;color:inherit"
                  >
                    <Box
                      position="relative"
                      aspectRatio="1 / 1"
                      overflow="hidden"
                      className="group"
                    >
                      {imgSrc ? (
                        <>
                          <img
                            src={imgSrc}
                            alt=""
                            style="width:100%;height:100%;object-fit:cover;filter:saturate(1.08) contrast(1.04);transition:filter 500ms, transform 500ms"
                            class="project-card-img"
                          />
                          <Box
                            position="absolute"
                            inset="0"
                            bg="linear-gradient(180deg, rgba(14,14,14,0.06), rgba(14,14,14,0.36))"
                            className="project-card-overlay"
                            style={{ transition: 'opacity 300ms' }}
                          />
                        </>
                      ) : (
                        <Box
                          position="relative"
                          w="100%"
                          h="100%"
                          bg="#0e0e0e"
                          className="fallback-grid-lines"
                        >
                          <Box
                            position="absolute"
                            bottom="-10px"
                            right="0"
                            fontFamily="Newsreader, serif"
                            fontStyle="italic"
                            fontSize="140px"
                            lineHeight="1"
                            color="#e5e2e1"
                            opacity="0.05"
                            userSelect="none"
                            pointerEvents="none"
                            aria-hidden="true"
                          >
                            {projectMonogram(project.title)}
                          </Box>
                          <Box
                            position="absolute"
                            bottom="0"
                            left="0"
                            right="0"
                            h="2px"
                            bg="#ffb000"
                            opacity="0.3"
                          />
                        </Box>
                      )}
                    </Box>
                    <Box p="6" display="flex" flexDirection="column" flex="1">
                      <Flex justify="space-between" align="start" mb="2">
                        <Text
                          fontFamily="Manrope, sans-serif"
                          fontWeight="bold"
                          fontSize="xl"
                          textTransform="uppercase"
                          letterSpacing="0"
                        >
                          {project.title}
                        </Text>
                      </Flex>
                      <Text
                        color="#c7c6c6"
                        fontSize="sm"
                        fontFamily="Newsreader, serif"
                        fontStyle="italic"
                        mb="6"
                      >
                        {project.description}
                      </Text>
                      <Flex
                        mt="auto"
                        pt="4"
                        borderTop="1px solid"
                        borderColor="#524533"
                        justify="space-between"
                        align="center"
                        opacity="0.5"
                        className="project-card-footer"
                        style={{
                          marginTop: 'auto',
                          paddingTop: '1rem',
                          transition: 'opacity 300ms'
                        }}
                      >
                        <Text fontFamily="JetBrains Mono, monospace" fontSize="10px">
                          {yearLabel(project.date?.slice(0, 4)) ?? t('common.projects')}
                        </Text>
                        <span
                          class="material-symbols-outlined"
                          style="font-size:14px"
                          aria-hidden="true"
                        >
                          north_east
                        </span>
                      </Flex>
                    </Box>
                  </a>
                );
              })}
            </Grid>
          ) : (
            <Box
              border="1px solid"
              borderColor="#524533"
              bg="#1c1b1b"
              p={{ base: '8', md: '12' }}
              mb="20"
              textAlign="center"
            >
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.15em"
                color="#9f8e78"
                mb="4"
              >
                status: unavailable
              </Text>
              <Heading as="h3" fontSize={{ base: '2xl', md: '3xl' }} fontStyle="italic" mb="3">
                {t('home.projects-empty-title')}
              </Heading>
              <Text color="#524533" fontSize="sm">
                {t('home.projects-empty-description')}
              </Text>
            </Box>
          )
        }
        <Stack gap="8">
          <Flex align="center" gap="4">
            <Heading as="h2" fontSize="4xl" fontStyle="italic">
              {t('home.life-heading')}
            </Heading>
            <Box h="1px" flex="1" bg="#524533" />
          </Flex>
          <Grid gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)' }} gap="6">
            <a
              href={`/${locale}/hobbies/6c2d00b7-dc75-4f45-b286-bf1cbf9e5284`}
              class="card-hover-amber"
              style="display:flex;align-items:center;gap:1rem;padding:1rem;border:1px solid #524533;background-color:#1c1b1b;text-decoration:none;color:inherit"
            >
              <span
                class="material-symbols-outlined"
                style="color: #FFB000; font-size: 2.25rem;"
                aria-hidden="true">dark_mode</span
              >
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0"
              >
                {t('home.life-darkroom')}
              </Text>
            </a>
            <a
              href={`/${locale}/hobbies`}
              class="card-hover-amber"
              style="display:flex;align-items:center;gap:1rem;padding:1rem;border:1px solid #524533;background-color:#1c1b1b;text-decoration:none;color:inherit"
            >
              <span
                class="material-symbols-outlined"
                style="color: #FFB000; font-size: 2.25rem;"
                aria-hidden="true">category</span
              >
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0"
              >
                {t('home.life-skill-toys')}
              </Text>
            </a>
          </Grid>
        </Stack>
      </Box>
    </Stack>
  </Container>
</MainLayout>
