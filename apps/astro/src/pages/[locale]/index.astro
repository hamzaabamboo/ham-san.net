---
import { FaArrowRight, FaGithub } from 'react-icons/fa';
import { Box, Container, Flex, Grid, GridItem, Stack, Wrap } from 'styled-system/jsx';
import { getMediaUrl } from 'utils/media';
import { Marquee } from '~/components/common/Marquee';
import BentoGrid from '~/components/home/BentoGrid.astro';
import { BrandMark } from '~/components/brand/BrandMark';
import { TagBadge } from '~/components/tags/TagBadge';
import { Button } from '~/components/ui/button';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { HeroBackground } from '~/components/home/HeroBackground';
import { graphQLSdk } from '~/graphql';
import type { ProjectPreviewFragment, TagFragment } from '~/graphql/generated/client';
import { pickLocale } from '~/utils/fallbackLocale';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.home')} | ${t('common.name')}`;

const data = await graphQLSdk.fetchHomePage({
  locale: locale === 'ja' ? 'ja' : 'en'
});

const homepageData = data?.homepage;
const rawProjects = data?.projects ?? [];
const projects = rawProjects
  .map((p) => pickLocale(p, locale))
  .filter((p): p is ProjectPreviewFragment => !!p);

const introImage =
  getMediaUrl(
    homepageData?.introductionImage?.url,
    { height: 600 },
    import.meta.env.PUBLIC_API_URL
  ) || '/images/placeholder-project.jpg';

Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=3600, must-revalidate');
---

<MainLayout title={pageTitle}>
  <Box position="relative" minH="100dvh" overflow="hidden" display="flex" alignItems="center">
    <HeroBackground client:idle />
    <Container maxW="breakpoint-xl" position="relative" zIndex={1}>
      <Grid
        gap="8"
        gridTemplateColumns={{ base: '1fr', lg: 'minmax(0, 1.4fr) minmax(320px, 0.8fr)' }}
      >
        <Stack gap="8" maxW="4xl">
          <Wrap
            display="inline-flex"
            alignItems="center"
            gap="3"
            px="3"
            py="2"
            bg="bg.default/70"
            border="1px solid"
            borderColor="border.subtle"
            fontFamily="JetBrains Mono, monospace"
            fontSize="10px"
            textTransform="uppercase"
            letterSpacing="0.12em"
            color="amber.500"
          >
            <BrandMark size={18} />
            atelier.exe
          </Wrap>
          <Heading
            as="h1"
            fontSize={{ base: '5xl', md: '7xl', lg: '8xl' }}
            fontWeight="bold"
            letterSpacing="-0.04em"
            color="fg.default"
            lineHeight="0.9"
            fontStyle="italic"
          >
            {t('home.hero-heading-prefix')} <br />
            <Box color="amber.500" display="inline-block">{t('home.hero-heading-emphasis')}</Box>
          </Heading>

          <Text fontSize={{ base: 'xl', md: '2xl' }} color="fg.muted" lineHeight="1.7" maxW="2xl">
            {homepageData?.heroSubtitle ?? t('home.hero-subtitle')}
          </Text>

          <Flex gap="4" pt="6" wrap="wrap">
            <Button
              asChild
              size="2xl"
              colorPalette="amber"
              variant="solid"
              fontWeight="bold"
              borderRadius="none"
            >
              <Link href={`/${locale}/projects`}>
                {t('home.view-my-work')}
              </Link>
            </Button>
            <Button asChild size="2xl" variant="outline" fontWeight="bold" borderRadius="none">
              <Link href="https://github.com/hamzaabamboo" target="_blank">
                <FaGithub /> GitHub
              </Link>
            </Button>
          </Flex>
        </Stack>
        <GridItem>
          <Stack
            h="full"
            minH={{ base: '340px', lg: '100%' }}
            border="1px solid"
            borderColor="border.subtle"
            bg="bg.default/85"
            p="6"
            justifyContent="space-between"
            backdropFilter="blur(8px)"
          >
            <Stack gap="4">
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.14em"
                color="amber.500"
              >
                hardware_manifest
              </Text>
              <Box
                border="1px solid"
                borderColor="border.subtle"
                bg="bg.muted"
                overflow="hidden"
                aspectRatio="1 / 1"
              >
                <img
                  src={introImage}
                  alt="Profile"
                  style={{
                    width: '100%',
                    height: '100%',
                    objectFit: 'cover',
                    filter: 'grayscale(1)'
                  }}
                />
              </Box>
            </Stack>
            <Stack gap="3">
              <Wrap gap="2">
                <Box
                  border="1px solid"
                  borderColor="border.subtle"
                  px="2"
                  py="1"
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  color="fg.muted"
                >
                  Frontend
                </Box>
                <Box
                  border="1px solid"
                  borderColor="border.subtle"
                  px="2"
                  py="1"
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  color="fg.muted"
                >
                  Design Systems
                </Box>
                <Box
                  border="1px solid"
                  borderColor="border.subtle"
                  px="2"
                  py="1"
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  color="fg.muted"
                >
                  Curiosity
                </Box>
              </Wrap>
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                color="fg.subtle"
                textTransform="uppercase"
                letterSpacing="0.12em"
              >
                Tokyo / Bangkok / Remote
              </Text>
            </Stack>
          </Stack>
        </GridItem>
      </Grid>
    </Container>

    <Box
      position="absolute"
      bottom="10"
      left="50%"
      transform="translateX(-50%)"
      animation="bounce 2s infinite"
      color="fg.muted"
    >
      <Box w="1px" h="12" bg="currentColor" />
    </Box>
  </Box>

  <Marquee client:load />

  <Box py="24" borderTop="1px solid" borderColor="border.subtle">
    <Container maxW="breakpoint-xl">
      <Stack gap="16">
        <Flex justify="space-between" align="center">
          <Heading fontSize={{ base: '4xl', md: '6xl' }} fontStyle="italic" color="fg.default"
            >{t('home.featured-projects')}</Heading
          >
          <Button asChild variant="link" colorPalette="gray" borderRadius="none">
            <Link href={`/${locale}/projects`}>
              {t('home.find-out-more')}
              <FaArrowRight />
            </Link>
          </Button>
        </Flex>

        <Grid
          gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)', xl: 'repeat(3, 1fr)' }}
          gap="6"
        >
          {
            projects.map((project, idx) => (
              <Box key={idx}>
                <Link
                  href={`/${locale}/projects/${project.slug}`}
                  display="block"
                  transition="all 0.3s"
                  _hover={{ transform: 'translate(-2px, -2px)' }}
                  h="full"
                >
                  <Box
                    bg="bg.default"
                    borderRadius="md"
                    overflow="hidden"
                    h="full"
                    display="flex"
                    flexDirection="column"
                    border="1px solid"
                    borderColor="border.subtle"
                  >
                    <Box
                      h="64"
                      bg="bg.muted"
                      style={{
                        backgroundImage: `url(${(() => {
                          const url = project.media?.[0]?.url;
                          if (url)
                            return getMediaUrl(
                              url,
                              { height: 400 },
                              import.meta.env.PUBLIC_API_URL
                            );
                          return '/images/placeholder-project.jpg';
                        })()})`
                      }}
                      bgSize="cover"
                      bgPosition="center"
                      borderBottom="1px solid"
                      borderColor="border.subtle"
                      filter="grayscale(1)"
                    />

                    <Stack p="4" gap="2" flex="1">
                      <Text
                        fontFamily="JetBrains Mono, monospace"
                        fontSize="10px"
                        color="amber.500"
                        textTransform="uppercase"
                        letterSpacing="0.12em"
                      >
                        project_{String(idx + 1).padStart(2, '0')}
                      </Text>
                      <Heading
                        fontSize="4xl"
                        fontStyle="italic"
                        color="fg.default"
                        lineHeight="0.95"
                      >
                        {project.title}
                      </Heading>

                      <Flex
                        gap="2"
                        fontSize="xs"
                        color="fg.muted"
                        align="center"
                        fontFamily="JetBrains Mono, monospace"
                      >
                        {project.category?.name && <Box>{project.category.name}</Box>}
                      </Flex>

                      {project.tags && project.tags.length > 0 && (
                        <Flex align="center" gap="2" wrap="wrap">
                          <Text fontSize="xs" fontWeight="bold" color="fg.muted">
                            {t('common.tags')}:
                          </Text>
                          {project.tags
                            .filter((tag): tag is TagFragment => !!tag)
                            .map((tag) => (
                              <TagBadge tag={tag} size="sm" />
                            ))}
                        </Flex>
                      )}

                      {project.description && (
                        <Text color="fg.muted" lineClamp={3} fontSize="sm" mt="2">
                          {project.description}
                        </Text>
                      )}
                    </Stack>
                  </Box>
                </Link>
              </Box>
            ))
          }
        </Grid>
      </Stack>
    </Container>
  </Box>

  <Container maxW="breakpoint-xl" py="24">
    <Stack gap="12">
      <Heading
        fontSize={{ base: '4xl', lg: '6xl' }}
        color="fg.default"
        textAlign="center"
        fontStyle="italic"
      >
        {t('home.about-me')}
      </Heading>

      <BentoGrid introImage={introImage} locale={locale} />
    </Stack>
  </Container>
</MainLayout>
