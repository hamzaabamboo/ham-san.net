---
import {
  FaDiscord,
  FaEnvelope,
  FaFacebook,
  FaGithub,
  FaLink,
  FaLinkedin,
  FaPrint,
  FaTwitter
} from 'react-icons/fa';
import { Box, Container, Grid, Stack, Wrap } from 'styled-system/jsx';
import { LinkItem } from '~/components/common/LinkItem';
import { InteractiveNamecard } from '~/components/namecard/InteractiveNamecard';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { NAMECARDS } from '~/constants/namecard';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.contact')} | ${t('common.name')}`;

const items = [
  {
    label: t('contact.email'),
    value: 'hamzaabamboo@gmail.com',
    url: 'mailto:hamzaabamboo@gmail.com',
    icon: FaEnvelope
  },
  {
    label: t('contact.twitter'),
    value: '@HamP_punipuni',
    url: 'https://twitter.com/HamP_punipuni',
    icon: FaTwitter
  },
  {
    label: t('contact.github'),
    value: 'hamzaabamboo',
    url: 'https://github.com/hamzaabamboo',
    icon: FaGithub
  },
  {
    label: t('contact.linkedin'),
    value: 'tvittayapalotai',
    url: 'https://www.linkedin.com/in/tvittayapalotai/',
    icon: FaLinkedin
  },
  {
    label: t('contact.facebook'),
    value: 'hamPpunipuni',
    url: 'https://www.facebook.com/hamPpunipuni',
    icon: FaFacebook
  },
  {
    label: 'Discord',
    value: 'hamp',
    url: 'https://discordapp.com/users/260776161032798208',
    icon: FaDiscord
  },
  {
    label: 'Eventernote',
    value: 'HamP_punipuni',
    url: 'https://www.eventernote.com/users/HamP_punipuni',
    icon: FaLink
  }
];
---

<MainLayout title={pageTitle}>
  <Container w="full" maxW="breakpoint-xl" py="8">
    <Stack gap="10">
      <Stack
        gap="4"
        borderLeftWidth="2px"
        borderLeftStyle="solid"
        borderLeftColor="amber.500"
        pl="6"
      >
        <Text
          fontFamily="JetBrains Mono, monospace"
          fontSize="10px"
          textTransform="uppercase"
          letterSpacing="0.12em"
          color="amber.500"
        >
          signal_intercept
        </Text>
        <Heading as="h1" fontSize={{ base: '5xl', md: '7xl' }} fontStyle="italic">
          Initiate contact.
        </Heading>
        <Text color="fg.muted" fontSize="lg" maxW="2xl">
          The workshop is open for thoughtful collaboration, frontend systems work, and interesting
          side paths.
        </Text>
      </Stack>
      <Grid gridTemplateColumns={{ base: '1fr', lg: '320px minmax(0, 1fr)' }} gap="8">
        <Stack gap="6">
          <Box border="1px solid" borderColor="border.subtle" bg="bg.subtle" p="6">
            <Text
              fontFamily="JetBrains Mono, monospace"
              fontSize="10px"
              textTransform="uppercase"
              letterSpacing="0.12em"
              color="amber.500"
              mb="4"
            >
              node_status
            </Text>
            <Stack gap="3">
              <Text fontFamily="JetBrains Mono, monospace" fontSize="xs">v2.0.4-stable</Text>
              <Text color="fg.muted" fontSize="sm"
                >Digital namecards, direct channels, and public profiles.</Text
              >
            </Stack>
          </Box>
          <Grid gridTemplateColumns="repeat(2, 1fr)" gap="3">
            <Link href={`/${locale}/namecard/default`}>
              <Box border="1px solid" borderColor="border.subtle" p="4" bg="bg.default">
                <Text
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  color="fg.subtle"
                >
                  01/
                </Text>
                <Text mt="2" fontWeight="bold">Standard</Text>
              </Box>
            </Link>
            <Link href={`/${locale}/namecard/all`}>
              <Box border="1px solid" borderColor="border.subtle" p="4" bg="bg.default">
                <Text
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  color="fg.subtle"
                >
                  02/
                </Text>
                <Text mt="2" fontWeight="bold">All Variants</Text>
              </Box>
            </Link>
          </Grid>
        </Stack>
        <Stack gap="8">
          <Stack gap="4">
            <Text
              fontFamily="JetBrains Mono, monospace"
              fontSize="10px"
              textTransform="uppercase"
              letterSpacing="0.12em"
              color="fg.subtle"
            >
              social_connectors
            </Text>
            <Grid gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)' }} gap="3">
              {
                items.map(({ icon, label, value, url }) => {
                  return (
                    <LinkItem
                      data={{
                        title: label,
                        url: url
                      }}
                      Icon={icon}
                      linkText={value}
                    />
                  );
                })
              }
            </Grid>
          </Stack>
          <Stack gap="4">
            <Wrap justifyContent="space-between" alignItems="center">
              <Heading as="h2" fontSize="4xl" fontStyle="italic">{t('contact.name-card')}</Heading>
              <Link
                href={`/${locale}/namecard/all`}
                display="inline-flex"
                alignItems="center"
                gap="2"
              >
                <FaPrint />
                <Text>View all</Text>
              </Link>
            </Wrap>
            <Grid gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)' }} gap="6">
              {
                NAMECARDS.slice(0, 2).map((card) => (
                  <Link href={`/${locale}/namecard/${card.variant}`}>
                    <Box border="1px solid" borderColor="border.subtle" bg="bg.default" p="4">
                      <InteractiveNamecard data={card} />
                    </Box>
                  </Link>
                ))
              }
            </Grid>
          </Stack>
        </Stack>
      </Grid>
    </Stack>
  </Container>
</MainLayout>
