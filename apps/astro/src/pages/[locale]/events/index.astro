                      ))}
                    </div>
                  </div>
                </div>
              </section>
            </div>
          </div>
        )
      }
    </section>
  </Container>
</MainLayout>

<script>
  const updateHeatmapMonthLabels = (shell: Element) => {
    const days = shell.querySelector('.event-report__heatmap-days');
    if (!days) return;
    const boundary = days.getBoundingClientRect().right;
    shell.querySelectorAll<HTMLElement>('.event-report__heatmap-months span').forEach((label) => {
      label.style.visibility = label.getBoundingClientRect().left < boundary ? 'hidden' : '';
    });
  };

  const scrollHeatmaps = () => {
    document.querySelectorAll('.event-report__heatmap-shell').forEach((shell) => {
      shell.scrollLeft = shell.scrollWidth;
      updateHeatmapMonthLabels(shell);
      if (!(shell as HTMLElement).dataset.monthLabelsBound) {
        (shell as HTMLElement).dataset.monthLabelsBound = 'true';
        shell.addEventListener('scroll', () => updateHeatmapMonthLabels(shell), {
          passive: true
        });
      }
    });
  };

  scrollHeatmaps();
  document.addEventListener('astro:page-load', scrollHeatmaps);
</script>
