---
import MainLayout from '~/layouts/MainLayout.astro';

import { cleanArticleContent } from 'outline/article';
import { Box, Container, Stack } from 'styled-system/jsx';
import { Markdown } from '~/components/lib/Markdown';
import { Heading } from '~/components/ui/heading';
import { Text } from '~/components/ui/text';
import { useTranslations, validateLocale } from '~/i18n/utils';
import { outlineClient } from '~/utils/outline-api';
import { getOutlineSettings } from '~/utils/outline-settings';

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.event')} | ${t('common.name')}`;

let content: string | undefined = undefined;

try {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);
  const settings = await getOutlineSettings();
  if (settings?.events) {
    const eventData = await outlineClient.POST('/documents.info', {
      body: { id: settings.events.replace('/doc/', '') },
      signal: controller.signal
    });
    content = cleanArticleContent(eventData.data?.data?.text) ?? undefined;
  }
  clearTimeout(timeout);
} catch {
  // CMS unavailable or timeout — render fallback
}
---

<MainLayout title={pageTitle} description={t('common.events-description')}>
  <Container maxW="breakpoint-xl" w="full" py="8">
    <Stack gap="8">
      <Stack gap="4" borderLeftWidth="2px" borderLeftStyle="solid" borderLeftColor="#ffb000" pl="6">
        <Text
          fontFamily="JetBrains Mono, monospace"
          fontSize="10px"
          textTransform="uppercase"
          letterSpacing="0.12em"
          color="#ffd597"
        >
          events
        </Text>
        <Heading as="h1" fontSize={{ base: '5xl', md: '7xl' }} fontStyle="italic">
          {t('common.event')}
        </Heading>
        <Text color="#c7c6c6" fontSize="lg" maxW="2xl">
          {t('common.events-description')}
        </Text>
      </Stack>
      {
        !content ? (
          <Box border="1px solid" borderColor="#524533" bg="#1c1b1b" p={{ base: '8', md: '12' }}>
            <Stack gap="4" alignItems="center" textAlign="center" py="12">
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.12em"
                color="#9f8e78"
              >
                status: unavailable
              </Text>
              <Heading as="h2" fontSize={{ base: '3xl', md: '4xl' }} fontStyle="italic">
                {t('common.events-empty-title')}
              </Heading>
              <Text color="#c7c6c6" maxW="md" lineHeight="1.7">
                {t('common.events-empty-description')}
              </Text>
            </Stack>
          </Box>
        ) : (
          <Box border="1px solid" borderColor="#524533" bg="#1c1b1b" overflow="hidden">
            <Box borderBottom="1px solid" borderColor="#524533" px={{ base: '4', md: '8' }} py="4">
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.12em"
                color="#ffb000"
              >
                {t('common.events-source-note')}
              </Text>
            </Box>
            <Box
              className="events-content-wrapper"
              p={{ base: '4', md: '8' }}
              maxH={{ base: 'none', md: '80vh' }}
              overflowY={{ base: 'visible', md: 'auto' }}
            >
              <Markdown
                content={content}
                linksPrefix={import.meta.env.PUBLIC_OUTLINE_URL}
                assetsPrefix={import.meta.env.PUBLIC_OUTLINE_URL}
                disableInternalLinks
              />
            </Box>
          </Box>
        )
      }
    </Stack>
  </Container>
</MainLayout>

<style is:global>
  .events-content-wrapper p {
    font-size: 0.8125rem;
    color: #9f8e78;
    line-height: 1.5;
  }

  .events-content-wrapper p:has(> a:only-child) {
    font-size: 0.6875rem;
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.04em;
    opacity: 0.6;
  }

  .events-content-wrapper a {
    color: #ffb000;
    text-decoration: none;
  }

  .events-content-wrapper a:hover {
    text-decoration: underline;
  }

  .events-content-wrapper .ov-x_auto {
    overflow-x: visible !important;
    overflow: visible !important;
  }

  .events-content-wrapper table {
    margin-top: 1.5rem;
    border-collapse: collapse;
    width: 100%;
    min-width: 0 !important;
    table-layout: fixed;
  }

  .events-content-wrapper thead {
    position: sticky !important;
    top: 0 !important;
    z-index: 1;
    background: #1c1b1b;
  }

  .events-content-wrapper thead th {
    border-bottom: 2px solid #524533 !important;
    padding-top: 0.625rem;
    padding-bottom: 0.625rem;
  }

  .events-content-wrapper tbody tr:nth-child(even) {
    background: rgba(42, 42, 42, 0.25);
  }

  .events-content-wrapper tbody td:first-child {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    color: #9f8e78;
    white-space: nowrap;
    width: 3.5rem;
  }

  .events-content-wrapper tbody td {
    overflow: visible !important;
    overflow-wrap: anywhere;
    text-overflow: initial !important;
    white-space: normal !important;
    word-break: normal;
  }

  .events-content-wrapper tbody td a {
    white-space: normal !important;
  }

  .events-content-wrapper tbody td:last-child {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.04em;
    color: #524533;
  }

  .events-content-wrapper tbody td:last-child p {
    font-family: inherit;
    font-size: inherit;
    letter-spacing: inherit;
    color: inherit;
  }

  @media (max-width: 480px) {
    .events-content-wrapper th:nth-child(3),
    .events-content-wrapper td:nth-child(3) {
      display: none;
    }
  }
</style>
