              <section id="rankings" class="event-report__section">
                <div class="event-report__section-head">
                  <h2>{t('common.events-report-rankings')}</h2>
                </div>
                <div class="event-report__grid event-report__grid--three">
                  <div class="event-report__panel">
                    <div class="event-report__panel-head">
                      <h2>{t('common.events-report-top-artists')}</h2>
                      <span>{t('common.events-report-top-50')}</span>
                    </div>
                    <ol class="event-report__rank-list">
                      {report.topArtists.slice(0, rankListVisible).map((artist) => (
                        <li
                          style={`--size: ${(artist.count / Math.max(report.topArtists[0]?.count ?? 1, 1)) * 100}%`}
                        >
                          <span>{artist.name}</span>
                          <i />
                          <strong>{formatter.format(artist.count)}</strong>
                        </li>
                      ))}
                    </ol>
                    {report.topArtists.length > rankListVisible ? (
                      <details class="event-report__rank-more">
                        <summary>{`${t('events.show-all')} (${formatter.format(report.topArtists.length)})`}</summary>
                        <ol class="event-report__rank-list" start={rankListVisible + 1}>
                          {report.topArtists.slice(rankListVisible, 50).map((artist) => (
                            <li
                              style={`--size: ${(artist.count / Math.max(report.topArtists[0]?.count ?? 1, 1)) * 100}%`}
                            >
                              <span>{artist.name}</span>
                              <i />
                              <strong>{formatter.format(artist.count)}</strong>
                            </li>
                          ))}
                        </ol>
                      </details>
                    ) : null}
                  </div>

                  <div class="event-report__panel">
                    <div class="event-report__panel-head">
                      <h2>{t('common.events-report-top-venues')}</h2>
                      <span>{t('common.events-report-top-50')}</span>
                    </div>
                    <ol class="event-report__rank-list">
                      {report.topVenues.slice(0, rankListVisible).map((venue) => (
                        <li
                          style={`--size: ${(venue.count / Math.max(report.topVenues[0]?.count ?? 1, 1)) * 100}%`}
