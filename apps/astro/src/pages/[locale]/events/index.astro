                    <div class="event-report__panel-head">
                      <h2>{t('common.events-report-yearly')}</h2>
                    </div>
                    <svg class="event-report__svg-chart" viewBox="0 0 720 260" role="img">
                      <title>{t('common.events-report-yearly')}</title>
                      <line x1="36" y1="220" x2="700" y2="220" />
                      {yearlyChartData.map((item, index) => {
                        const x =
                          yearlyChartData.length === 1
                            ? 340
                            : 40 + (index / (yearlyChartData.length - 1)) * 640;
                        const height = (item.count / maxYearlyChartCount) * 170;

                        const showLabel =
                          (yearlyChartData.length - 1 - index) % yearLabelStep === 0;

                        return (
                          <>
                            <rect x={x - 10} y={220 - height} width="20" height={height} />
                            {showLabel ? (
                              <>
                                <text x={x} y={210 - height}>
                                  {formatter.format(item.count)}
                                </text>
                                <text x={x} y="244">
                                  {yearLabel(item.year)}
                                </text>
                              </>
                            ) : null}
                          </>
                        );
                      })}
                      <polyline points={yearlyLinePoints} />
                    </svg>
                  </div>

                  <div class="event-report__panel event-report__panel--wide">
                    <div class="event-report__panel-head">
                      <h2>{t('common.events-report-months')}</h2>
                    </div>
                    <svg class="event-report__svg-chart" viewBox="0 0 720 280" role="img">
                      <title>{t('common.events-report-months')}</title>
                      <line x1="36" y1="220" x2="700" y2="220" />
                      {monthlyChartData.map((item, index) => {
                        const width = 620 / Math.max(monthlyChartData.length, 1);
                        const x = 50 + index * width;
                        const height = (item.count / maxMonthlyChartCount) * 170;
                        const showTick =
                          (monthlyChartData.length - 1 - index) % monthTickStep === 0;
                        const showYear = index === 0 || item.month.slice(5, 7) === '01';

                        return (
                          <>
                            <rect
                              x={x}
                              y={220 - height}
                              width={Math.max(width - 6, 6)}
                              height={height}
                            />
                            {showTick ? (
                              <>
                                <text x={x + width / 2} y={210 - height}>
                                  {formatter.format(item.count)}
