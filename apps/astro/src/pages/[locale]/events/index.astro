                      </details>
                    ) : null}
                  </div>

                  <div class="event-report__panel">
                    <div class="event-report__panel-head">
                      <h2>{t('events.busiest-months')}</h2>
                    </div>
                    <div class="event-report__month-list">
                      {busiestMonths.map((month) => (
                        <div class="event-report__month">
                          <div>
                            <span>{monthLabel(month.month)}</span>
                            <strong>{formatter.format(month.count)}</strong>
