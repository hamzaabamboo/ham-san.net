---
import MainLayout from '~/layouts/MainLayout.astro';
import { withLastGoodState } from '~/utils/cms-cache';
import '~/styles/events-report.css';

import { Container } from 'styled-system/jsx';
import { useTranslations, validateLocale } from '~/i18n/utils';
import {
  EVENTERNOTE_PROFILE_URL,
  EVENTERNOTE_USERNAME,
  buildEventernoteReport,
  getEventernoteReport,
  type EventernoteReport
} from '~/utils/eventernote-report';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.event')} | ${t('common.name')}`;

let rawReport: EventernoteReport | undefined;
let fetchError = false;

try {
  const { value, fromCache } = await withLastGoodState('events:report', () =>
    getEventernoteReport()
  );
  rawReport = fromCache ? { ...value, cached: true } : value;
} catch {
  fetchError = true;
}

const yearOptions = [
  ...(rawReport?.yearlyBreakdown.filter((item) => item.count > 0).map((item) => item.year) ?? [])
].reverse();
const requestedYear = Astro.url.searchParams.get('year');
const selectedYear = requestedYear && /^\d{4}$/.test(requestedYear) ? requestedYear : 'all';
const filteredEvents =
  rawReport && selectedYear !== 'all'
    ? rawReport.events.filter((event) => event.dateKey.startsWith(selectedYear))
    : undefined;
const report =
  rawReport && selectedYear !== 'all'
    ? filteredEvents?.length
      ? {
          ...buildEventernoteReport(
            rawReport.profile,
            filteredEvents,
            new Date(rawReport.fetchedAt).getTime(),
            `${selectedYear}-12-31`,
            `${selectedYear}-01-01`
          ),
          fetchedAt: rawReport.fetchedAt,
          cached: rawReport.cached
        }
      : undefined
    : rawReport;
const emptyYear = Boolean(rawReport && selectedYear !== 'all' && !report);

const formatter = new Intl.NumberFormat(locale);
const dateFormatter = new Intl.DateTimeFormat(locale, {
  dateStyle: 'medium',
  timeZone: 'Asia/Tokyo'
});
const timeFormatter = new Intl.DateTimeFormat(locale, {
  dateStyle: 'medium',
  timeStyle: 'short',
  timeZone: 'Asia/Tokyo'
});
const percentFormatter = new Intl.NumberFormat(locale, {
  maximumFractionDigits: 0,
  style: 'percent'
});
const decimalFormatter = new Intl.NumberFormat(locale, {
  maximumFractionDigits: 1
});
const monthFormatter = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  month: 'short',
  timeZone: 'Asia/Tokyo'
});
const weekendRate = report?.totalEvents
  ? percentFormatter.format(report.weekendEvents / report.totalEvents)
  : '0%';
const busiestMonths = [...(report?.monthlyBreakdown ?? [])]
  .sort((a, b) => b.count - a.count)
  .slice(0, 12);
const maxMonthCount = Math.max(...busiestMonths.map((item) => item.count), 1);
const maxWeekdayCount = Math.max(...(report?.weekdayBreakdown.map((item) => item.count) ?? []), 1);
const maxMonthOfYearCount = Math.max(
  ...(report?.monthOfYearBreakdown.map((item) => item.count) ?? []),
  1
);
const maxDailyActivityCount = Math.max(
  ...(report?.dailyActivity.map((item) => item.count) ?? []),
  1
);
const latestFavoriteCumulative = report?.cumulativeFavoriteArtists.at(-1)?.values ?? [];
const lineStyles = [
  { color: '#ffb000', dash: 'none' },
  { color: '#ffd597', dash: '6 4' },
  { color: '#c7c6c6', dash: '2 3' },
  { color: '#9f8e78', dash: '10 4 2 4' },
  { color: '#765c2f', dash: '1 4' }
];
const monthlyChartData = (report?.monthlyBreakdown ?? []).slice(-18);
const maxMonthlyChartCount = Math.max(...monthlyChartData.map((item) => item.count), 1);
const monthTickStep = Math.max(1, Math.ceil(monthlyChartData.length / 9));
const favoriteCumulativeMax = Math.max(
  ...(report?.cumulativeFavoriteArtists ?? []).flatMap((month) =>
    month.values.map((item) => item.count)
  ),
  1
);
const yearlyChartData = report?.yearlyBreakdown ?? [];
const yearLabelStep = Math.max(1, Math.ceil(yearlyChartData.length / 7));
const cumulativeYearMarks = (report?.cumulativeFavoriteArtists ?? [])
  .map((item, index) => ({ month: item.month, index }))
  .filter((item) => item.month.slice(5, 7) === '01');
const cumulativeYearStep = Math.max(1, Math.ceil(cumulativeYearMarks.length / 7));
const maxYearlyChartCount = Math.max(...yearlyChartData.map((item) => item.count), 1);
const maxCumulativeChartCount = Math.max(...yearlyChartData.map((item) => item.cumulative), 1);
const yearlyLinePoints = yearlyChartData
  .map((item, index) => {
    const x = yearlyChartData.length === 1 ? 40 : 40 + (index / (yearlyChartData.length - 1)) * 640;
    const y = 220 - (item.cumulative / maxCumulativeChartCount) * 170;
    return `${x},${y}`;
  })
  .join(' ');
const averageEventsPerActiveDay = report?.activeDays
  ? (report.totalEvents / report.activeDays).toFixed(2)
  : '0.00';
const averageEventsPerYear = report?.yearlyBreakdown.length
  ? (report.totalEvents / report.yearlyBreakdown.length).toFixed(1)
  : '0.0';
const pct1 = (value: number) => `${decimalFormatter.format(value)}%`;
const dateLabel = (date?: string) =>
  date ? dateFormatter.format(new Date(`${date}T00:00:00+09:00`)) : '-';
const monthLabel = (month?: string) =>
  month ? monthFormatter.format(new Date(`${month}-01T00:00:00+09:00`)) : '-';
const yearPartFormatter = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  timeZone: 'Asia/Tokyo'
});
const yearLabel = (year: string) =>
  yearPartFormatter
    .formatToParts(new Date(`${year}-01-01T00:00:00+09:00`))
    .find((part) => part.type === 'year')?.value ?? year;
const reportPeriodLabel =
  selectedYear === 'all' ? t('common.events-report-all-years') : yearLabel(selectedYear);
const dateRangeLabel = report?.dateRange?.split(' - ').map(dateLabel).join(' - ') ?? '';
const windowLabels: Record<string, string> = {
  'this-year': t('common.events-report-window-this-year'),
  'last-30-days': t('common.events-report-window-last-30-days'),
  'last-6-months': t('common.events-report-window-last-6-months'),
  'last-year': t('common.events-report-window-last-year'),
  'last-2-years': t('common.events-report-window-last-2-years'),
  'last-3-years': t('common.events-report-window-last-3-years'),
  'all-time': t('common.events-report-window-all-time')
};
const weekdayLabels: Record<string, string> = {
  Monday: t('common.events-report-weekday-monday'),
  Tuesday: t('common.events-report-weekday-tuesday'),
  Wednesday: t('common.events-report-weekday-wednesday'),
  Thursday: t('common.events-report-weekday-thursday'),
  Friday: t('common.events-report-weekday-friday'),
  Saturday: t('common.events-report-weekday-saturday'),
  Sunday: t('common.events-report-weekday-sunday')
};
const weekdayLabel = (weekday?: string) => {
  if (!weekday) return '-';
  return weekdayLabels[weekday] ?? weekday;
};
const weekdayOrder = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
const weekdayShortFormatter = new Intl.DateTimeFormat(locale, {
  weekday: 'short',
  timeZone: 'UTC'
});
const weekdayShort = (weekday: string) =>
  weekdayShortFormatter.format(new Date(Date.UTC(2024, 0, 1 + weekdayOrder.indexOf(weekday))));
const monthOrder = [
  'Jan',
  'Feb',
  'Mar',
  'Apr',
  'May',
  'Jun',
  'Jul',
  'Aug',
  'Sep',
  'Oct',
  'Nov',
  'Dec'
];
const monthShortFormatter = new Intl.DateTimeFormat(locale, { month: 'short', timeZone: 'UTC' });
const monthShort = (name: string) =>
  monthShortFormatter.format(new Date(Date.UTC(2024, monthOrder.indexOf(name), 1)));
const dayUnit = (count: number) =>
  count === 1 ? t('common.events-report-day-unit') : t('common.events-report-days-unit');

const cumulativeLine = (artist: string, data = report?.cumulativeFavoriteArtists ?? []) => {
  return data
    .map((month, monthIndex) => {
      const x = data.length === 1 ? 56 : 56 + (monthIndex / (data.length - 1)) * 624;
      const value = month.values.find((item) => item.name === artist)?.count ?? 0;
      const y = 230 - (value / favoriteCumulativeMax) * 180;
      return `${x},${y}`;
    })
    .join(' ');
};

const heatmapDays = (() => {
  const days = report?.dailyActivity ?? [];
  if (!days.length) return [];
  const activity = new Map(days.map((day) => [day.date, day.count]));
  const start = new Date(`${days[0].date}T00:00:00+09:00`);
  const end = new Date(`${days[days.length - 1].date}T00:00:00+09:00`);
  const items: { date: string; count: number; weekday: number; month: string }[] = [];

  for (const cursor = new Date(start); cursor <= end; cursor.setUTCDate(cursor.getUTCDate() + 1)) {
    const date = new Intl.DateTimeFormat('en-CA', {
      timeZone: 'Asia/Tokyo',
      year: 'numeric',
      month: '2-digit',
      day: '2-digit'
    }).format(cursor);
    items.push({
      date,
      count: activity.get(date) ?? 0,
      weekday: new Date(`${date}T00:00:00Z`).getUTCDay(),
      month: new Intl.DateTimeFormat(locale, {
        month: 'short',
        timeZone: 'Asia/Tokyo'
      }).format(new Date(`${date}T00:00:00+09:00`))
    });
  }

  return items.slice(-210);
})();
let heatmapWeek = 0;
const heatmapCells = heatmapDays.map((day, index) => {
  if (index > 0 && day.weekday === 0) heatmapWeek++;
  return { ...day, week: heatmapWeek };
});
const heatmapWeekCount = heatmapWeek + 1;
const heatmapMonthMarks = heatmapCells
  .filter(
    (day, index) => index === 0 || day.date.slice(0, 7) !== heatmapCells[index - 1].date.slice(0, 7)
  )
  .reduce<typeof heatmapCells>((marks, mark) => {
    const previous = marks.at(-1);
    if (!previous || mark.week - previous.week >= 2) marks.push(mark);
    return marks;
  }, []);
const heatmapWindowLabel = heatmapDays.length
  ? `${dateLabel(heatmapDays[0].date)} - ${dateLabel(heatmapDays[heatmapDays.length - 1].date)}`
  : '';
const rankListVisible = 12;
const shareItems = (items: { name: string; count: number }[], total: number) => {
  const top = items.slice(0, 10);
  const maxCount = Math.max(top[0]?.count ?? 1, 1);
  return top.map((item) => ({
    name: item.name,
    count: item.count,
    size: (item.count / maxCount) * 100,
    share: total ? (item.count / total) * 100 : 0
  }));
};
const venueShares = shareItems(report?.topVenues ?? [], report?.totalEvents ?? 0);
const artistShares = shareItems(report?.topArtists ?? [], report?.totalArtistAppearances ?? 0);
const favoriteAttendanceTotal = report?.favoriteArtistAttendance.reduce(
  (total, artist) => ({
    attended: total.attended + artist.attended,
    missed: total.missed + artist.missed,
    total: total.total + artist.total
  }),
  { attended: 0, missed: 0, total: 0 }
);
const favoriteAttendancePct = favoriteAttendanceTotal?.total
  ? (favoriteAttendanceTotal.attended / favoriteAttendanceTotal.total) * 100
  : 0;
const bestFavoriteAttendance = [...(report?.favoriteArtistAttendance ?? [])].sort(
  (a, b) => b.pct - a.pct || b.attended - a.attended || a.name.localeCompare(b.name)
)[0];
const eventingStyle = report
  ? report.multiEventDayStats.maxEventsInDay >= 10
    ? {
        icon: 'bolt',
        label: t('common.events-report-your-style'),
        value: t('common.events-report-style-machine'),
        sub: t('common.events-report-style-machine-sub')
      }
    : report.avgEventsPerMonth >= 20
      ? {
          icon: 'local_fire_department',
          label: t('common.events-report-your-style'),
          value: t('common.events-report-style-full-time'),
          sub: t('common.events-report-style-full-time-sub')
        }
      : report.weekendStats.weekendEventPercentage >= 80
        ? {
            icon: 'weekend',
            label: t('common.events-report-your-style'),
            value: t('common.events-report-style-weekend'),
            sub: t('common.events-report-style-weekend-sub')
          }
        : {
            icon: 'explore',
            label: t('common.events-report-your-style'),
            value: t('common.events-report-style-balanced'),
            sub: t('common.events-report-style-balanced-sub')
          }
  : undefined;

const secondaryStats = report
  ? [
      {
        label: t('common.events-report-active-days'),
        value: formatter.format(report.activeDays),
        meta: `${formatter.format(report.multiEventDays)} ${t('common.events-report-multi-days')}`
      },
      {
        label: t('common.events-report-weekend-rate'),
        value: weekendRate,
        meta: `${formatter.format(report.weekendEvents)} / ${formatter.format(report.totalEvents)}`
      },
      {
        label: t('common.events-report-events-per-day'),
        value: averageEventsPerActiveDay,
        meta: t('common.events-report-active-days')
      },
      {
        label: t('common.events-report-events-per-year'),
        value: averageEventsPerYear,
        meta: `${formatter.format(report.yearlyBreakdown.length)} ${
          report.yearlyBreakdown.length === 1
            ? t('common.events-report-year')
            : t('common.events-report-years')
        }`
      },
      {
        label: t('common.events-report-artist-appearances'),
        value: formatter.format(report.totalArtistAppearances),
        meta: t('common.events-report-total-appearances')
      },
      {
        label: t('common.events-report-days-spent'),
        value: percentFormatter.format(report.daysSpentPercentage / 100),
        meta: `${formatter.format(report.activeDays)} / ${formatter.format(report.totalDaysInRange)}`
      },
      {
        label: t('common.events-report-max-day'),
        value: formatter.format(report.maxEventsInDay?.count ?? 0),
        meta: dateLabel(report.maxEventsInDay?.name)
      },
      {
        label: t('common.events-report-followers'),
        value: formatter.format(report.profile.followers),
        meta: `${formatter.format(report.profile.following)} ${t('common.events-report-following')}`
      }
    ]
  : [];

const heroStats = report
  ? [
      {
        label: t('common.events-report-period'),
        value: reportPeriodLabel
      },
      {
        label: t('common.events-report-total'),
        value: formatter.format(report.totalEvents)
      },
      {
        label: t('common.events-report-next'),
        value: formatter.format(report.nextEvents.length)
      },
      {
        label: t('common.events-report-artists'),
        value: report.topArtists[0]?.name ?? '-'
      }
    ]
  : [];

const overviewGroups = report
  ? [
      {
        title: t('common.events-report-summary'),
        items: [
          {
            label: t('common.events-report-total-events'),
            value: formatter.format(report.totalEvents),
            meta: dateRangeLabel
          },
          {
            label: t('common.events-report-unique-venues-full'),
            value: formatter.format(report.uniqueVenues),
            meta: ''
          },
          {
            label: t('common.events-report-unique-artists-full'),
            value: formatter.format(report.uniqueArtists),
            meta: `${formatter.format(report.totalArtistAppearances)} ${t('common.events-report-appearances')}`
          },
          {
            label: t('common.events-report-without-favorites'),
            value: pct1(report.eventsWithoutFavoritesPercentage),
            meta: `${formatter.format(report.eventsWithoutFavorites)} / ${formatter.format(report.totalEvents)}`
          }
        ]
      },
      {
        title: t('common.events-report-activity-group'),
        items: [
          {
            label: t('common.events-report-avg-month'),
            value: decimalFormatter.format(report.avgEventsPerMonth),
            meta: ''
          },
          {
            label: t('common.events-report-days-active'),
            value: pct1(report.daysSpentPercentage),
            meta: `${formatter.format(report.activeDays)} / ${formatter.format(report.totalDaysInRange)}`
          },
          {
            label: t('common.events-report-most-active-day'),
            kind: 'context',
            value: weekdayLabel(report.favoriteDay?.name),
            meta: `${formatter.format(report.favoriteDay?.count ?? 0)} ${t('common.events-report-events-unit')}`
          },
          {
            label: t('common.events-report-busiest-month'),
            kind: 'context',
            value: monthLabel(report.busiestMonth?.month),
            meta: `${formatter.format(report.busiestMonth?.count ?? 0)} ${t('common.events-report-events-unit')}`
          },
          {
            label: t('common.events-report-weekend-active'),
            value: pct1(report.weekendStats.weekendPercentage),
            meta: `${formatter.format(report.weekendStats.weekendsWithEvents)} / ${formatter.format(report.weekendStats.totalWeekends)}`
          },
          {
            label: t('common.events-report-weekend-events'),
            value: pct1(report.weekendStats.weekendEventPercentage),
            meta: `${formatter.format(report.weekendStats.weekendEventCount)} / ${formatter.format(report.totalEvents)}`
          },
          {
            label: t('common.events-report-weekday-events'),
            value: pct1(report.weekendStats.weekdayEventPercentage),
            meta: `${formatter.format(report.weekendStats.weekdayEventCount)} / ${formatter.format(report.totalEvents)}`
          }
        ]
      },
      {
        title: t('common.events-report-multi-event-days-group'),
        items: [
          {
            label: t('common.events-report-multi-event-days'),
            value: pct1(report.multiEventDayStats.daysWithMultipleEventsPercentage),
            meta: `${formatter.format(report.multiEventDayStats.daysWithMultipleEvents)} / ${formatter.format(report.multiEventDayStats.totalDaysWithEvents)}`
          },
          {
            label: t('common.events-report-multi-venue-days'),
            value: pct1(report.multiEventDayStats.daysWithMultipleVenuesPercentage),
            meta: `${formatter.format(report.multiEventDayStats.daysWithMultipleVenues)} / ${formatter.format(report.multiEventDayStats.totalDaysWithEvents)}`
          },
          {
            label: t('common.events-report-max-events-day'),
            value: formatter.format(report.multiEventDayStats.maxEventsInDay),
            meta: dateLabel(report.multiEventDayStats.maxEventsInDayDate)
          },
          {
            label: t('common.events-report-max-venues-day-short'),
            value: formatter.format(report.multiEventDayStats.maxVenuesInDay),
            meta: dateLabel(report.multiEventDayStats.maxVenuesInDayDate)
          }
        ]
      },
      {
        title: t('common.events-report-streaks'),
        items: [
          {
            label: t('common.events-report-current-daily'),
            value: formatter.format(report.streaks.daily.currentStreak),
            meta: report.streaks.daily.isActive
              ? `${t('common.events-report-since')} ${dateLabel(report.streaks.daily.currentStreakStartDate)}`
              : t('common.events-report-days-unit')
          },
          {
            label: t('common.events-report-current-weekly'),
            value: formatter.format(report.streaks.weekly.currentStreak),
            meta: report.streaks.weekly.isActive
              ? `${t('common.events-report-since')} ${dateLabel(report.streaks.weekly.currentStreakStartDate)}`
              : t('common.events-report-weeks-unit')
          },
          {
            label: t('common.events-report-longest-daily'),
            value: formatter.format(report.streaks.daily.longestStreak),
            meta: `${dateLabel(report.streaks.daily.longestStreakStartDate)} - ${dateLabel(report.streaks.daily.longestStreakEndDate)}`
          },
          {
            label: t('common.events-report-longest-weekly'),
            value: formatter.format(report.streaks.weekly.longestStreak),
            meta: `${dateLabel(report.streaks.weekly.longestStreakStartDate)} - ${dateLabel(report.streaks.weekly.longestStreakEndDate)}`
          }
        ]
      }
    ]
  : [];

const highlightCards =
  report && eventingStyle
    ? [
        eventingStyle,
        {
          icon: 'crown',
          label: t('common.events-report-most-seen-artist'),
          value: report.topArtists[0]?.name ?? '-',
          sub: `${formatter.format(report.topArtists[0]?.count ?? 0)} ${t('common.events-report-events-together')}`
        },
        {
          icon: 'social_leaderboard',
          label: t('common.events-report-most-loyal'),
          value: bestFavoriteAttendance?.name ?? '-',
          sub: bestFavoriteAttendance
            ? `${pct1(bestFavoriteAttendance.pct)} ${t('common.events-report-attendance-rate')} (${formatter.format(
                bestFavoriteAttendance.attended
              )}/${formatter.format(bestFavoriteAttendance.total)})`
            : '-'
        },
        {
          icon: 'home',
          label: t('common.events-report-home-venue'),
          value: report.topVenues[0]?.name ?? '-',
          sub: `${formatter.format(report.topVenues[0]?.count ?? 0)} ${t('common.events-report-visits')}`
        },
        {
          icon: 'local_fire_department',
          label: t('common.events-report-longest-streak'),
          value: `${formatter.format(report.streaks.daily.longestStreak)} ${dayUnit(report.streaks.daily.longestStreak)}`,
          sub: t('common.events-report-weekly-best').replace(
            '{n}',
            formatter.format(report.streaks.weekly.longestStreak)
          )
        },
        {
          icon: 'bolt',
          label: t('common.events-report-personal-record'),
          value: `${formatter.format(report.multiEventDayStats.maxEventsInDay)} ${t('common.events-report-events-in-one-day')}`,
          sub: dateLabel(report.multiEventDayStats.maxEventsInDayDate)
        },
        {
          icon: 'bar_chart',
          label: t('common.events-report-busiest-month'),
          value: monthLabel(report.busiestMonth?.month),
          sub: `${formatter.format(report.busiestMonth?.count ?? 0)} ${t('common.events-report-events-unit')}`
        },
        {
          icon: 'event',
          label: t('common.events-report-favorite-day'),
          value: weekdayLabel(report.favoriteDay?.name),
          sub: `${formatter.format(report.favoriteDay?.count ?? 0)} ${t('common.events-report-events-on-this-day')}`
        }
      ]
    : [];

const reportSections = report
  ? [
      { id: 'overview', label: t('common.events-report-overview') },
      { id: 'highlights', label: t('common.events-report-highlights') },
      { id: 'charts', label: t('common.events-report-charts') },
      { id: 'rhythm', label: t('common.events-report-rhythm') },
      { id: 'activity', label: t('common.events-report-activity') },
      { id: 'events', label: t('common.events-report-events') },
      { id: 'rankings', label: t('common.events-report-rankings') }
    ]
  : [];
---

<MainLayout title={pageTitle} description={t('common.events-description')}>
  <Container maxW="breakpoint-xl" w="full" py={{ base: '6', md: '10' }}>
    <section class="event-report">
      <header class="event-report__hero">
        <div class="event-report__hero-copy">
          <p class="event-report__kicker">{t('common.events-report-kicker')}</p>
          <h1>{t('common.event')}</h1>
          <p>{t('common.events-description')}</p>
        </div>
        <div class="event-report__identity">
          <div>
            <p>{EVENTERNOTE_USERNAME}</p>
            <span>{report?.profile.displayName ?? `@${EVENTERNOTE_USERNAME}`}</span>
          </div>
          {
            heroStats.length ? (
              <div class="event-report__hero-stats" aria-label={t('events.aria-hero-stats')}>
                {heroStats.map((stat) => (
                  <article>
                    <span>{stat.label}</span>
                    <strong>{stat.value}</strong>
                  </article>
                ))}
              </div>
            ) : null
          }
          <div class="event-report__actions">
            <a href={EVENTERNOTE_PROFILE_URL} target="_blank" rel="noreferrer">
              <span class="material-symbols-outlined" aria-hidden="true">open_in_new</span>
              {t('common.events-report-source-profile')}
            </a>
          </div>
        </div>
      </header>

      {
        fetchError || !report ? (
          <section class="event-report__fallback" aria-live="polite">
            <span class="material-symbols-outlined" aria-hidden="true">
              {emptyYear ? 'event_busy' : 'cloud_off'}
