                <span>{report.profile.bio}</span>
              </section>

              <nav class="event-report__jump-nav" aria-label={t('events.aria-sections')}>
                {reportSections.map((section) => (
                  <a href={`#${section.id}`}>{section.label}</a>
                ))}
              </nav>

              <section class="event-report__section event-report__section--controls">
                <div class="event-report__section-head">
                  <h2>{t('common.events-report-filter')}</h2>
                </div>
                <nav class="event-report__year-filter" aria-label={t('events.aria-year-filter')}>
                  <a
                    href={`/${locale}/events`}
                    data-active={selectedYear === 'all' ? 'true' : 'false'}
                    aria-current={selectedYear === 'all' ? 'page' : undefined}
                  >
                    {t('common.events-report-all-years')}
                  </a>
                  {yearOptions.map((year) => (
                    <a
                      href={`/${locale}/events?year=${year}`}
