                    </span>
                    <span>
                      <strong>{formatter.format(report.uniqueVenues)}</strong>
                      {t('common.events-report-venues-unit')}
                    </span>
                    <span>
                      <strong>{formatter.format(report.uniqueArtists)}</strong>
                      {t('common.events-report-artists-unit')}
                    </span>
                  </div>
                </div>
                <div class="event-report__highlight-grid">
                  {highlightCards.map((item) => (
                    <article>
                      <span class="material-symbols-outlined" aria-hidden="true">
                        {item.icon}
