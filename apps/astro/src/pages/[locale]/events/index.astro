                        const x =
                          report.cumulativeFavoriteArtists.length === 1
                            ? 56
                            : 56 +
                              (mark.index / (report.cumulativeFavoriteArtists.length - 1)) * 624;

                        if ((cumulativeYearMarks.length - 1 - markIndex) % cumulativeYearStep !== 0)
