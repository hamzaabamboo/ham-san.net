---
import { Container, Grid, Stack } from 'styled-system/jsx';
import { TagBadge } from '~/components/tags/TagBadge';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { graphQLSdk } from '~/graphql';
import { Enum_Tag_Type } from '~/graphql/generated/client';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import { sortTags } from '~/utils/tags';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const data = await graphQLSdk.fetchAboutMe({ locale: locale === 'ja' ? 'ja' : 'en' });
const tags = sortTags(
  (data.tags ?? []).filter(
    (tag): tag is NonNullable<(typeof data.tags)[number]> =>
      !!tag?.slug && !!tag?.title && tag.type !== Enum_Tag_Type.NonDev
  )
);
---

<MainLayout>
  <Container maxW="breakpoint-xl" py="8">
    <Stack gap="10">
      <Stack
        gap="4"
        borderLeftWidth="2px"
        borderLeftStyle="solid"
        borderLeftColor="amber.500"
        pl="6"
      >
        <Text
          fontFamily="JetBrains Mono, monospace"
          fontSize="10px"
          textTransform="uppercase"
          letterSpacing="0.12em"
          color="amber.500"
        >
          taxonomy_index
        </Text>
        <Heading as="h1" fontSize={{ base: '5xl', md: '7xl' }} fontStyle="italic">
          {t('common.tags')}
        </Heading>
        <Text color="fg.muted" fontSize="lg" maxW="2xl">
          Skills, domains, and recurring themes connected across projects and experience.
        </Text>
      </Stack>
      <Grid
        gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)', xl: 'repeat(3, 1fr)' }}
        gap="4"
      >
        {
          tags.map((tag) => (
            <Link href={`/${locale}/tags/${tag.slug}`}>
              <Stack
                border="1px solid"
                borderColor="border.subtle"
                bg="bg.default"
                p="5"
                _hover={{ transform: 'translate(-2px, -2px)' }}
                transition="transform 0.2s ease"
              >
                <Text
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  letterSpacing="0.12em"
                  color="fg.subtle"
                >
                  {t(
                    `common.${String(tag.type).replaceAll('_', '-').toLowerCase()}` as 'common.frontend'
                  )}
                </Text>
                <TagBadge tag={tag} showCount size="md" />
              </Stack>
            </Link>
          ))
        }
      </Grid>
    </Stack>
  </Container>
</MainLayout>
