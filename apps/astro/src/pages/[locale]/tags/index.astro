---
import { toKebabCase } from 'utils/kebab-case';
import { Box, Container, Flex, Stack, Wrap } from 'styled-system/jsx';
import { TagBadge } from '~/components/tags/TagBadge';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { graphQLSdk } from '~/graphql';
import { withLastGood } from '~/utils/cms-cache';
import { Enum_Tag_Type } from '~/graphql/generated/client';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import { sortTags, tagSlug } from '~/utils/tags';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);

let tags: any[] = [];

try {
  const cmsLocale = locale === 'ja' ? 'ja' : 'en';
  const data = await withLastGood(`about:${cmsLocale}`, () =>
    graphQLSdk.fetchAboutMe({ locale: cmsLocale })
  );
  tags = sortTags(
    (data.tags ?? []).filter(
      (tag: any): tag is NonNullable<(typeof data.tags)[number]> =>
        !!tag?.slug && !!tag?.title && tag.type !== Enum_Tag_Type.NonDev
    )
  );
} catch {
  // CMS unavailable — render with empty data
}

const PRIMARY_TYPES = [Enum_Tag_Type.Frontend, Enum_Tag_Type.ProgrammingLanguage];

const primaryTags = tags.filter((tag) => PRIMARY_TYPES.includes(tag.type as Enum_Tag_Type));
const secondaryTags = tags.filter((tag) => !PRIMARY_TYPES.includes(tag.type as Enum_Tag_Type));

const groupByType = (list: typeof tags) =>
  list.reduce<Record<string, typeof tags>>((acc, tag) => {
    const type = String(tag.type ?? 'Others');
    if (!acc[type]) acc[type] = [];
    acc[type].push(tag);
    return acc;
  }, {});

const primaryGroups = groupByType(primaryTags);
const secondaryGroups = groupByType(secondaryTags);

const pageTitle = `${t('common.tags')} | ${t('common.name')}`;
---

<MainLayout title={pageTitle} description={t('common.tags-description')}>
  <Container maxW="breakpoint-xl" py="8">
    <Stack gap="12">
      <Stack gap="4" borderLeftWidth="2px" borderLeftStyle="solid" borderLeftColor="#ffb000" pl="6">
        <Heading as="h1" fontSize={{ base: '5xl', md: '7xl' }} fontStyle="italic">
          {t('common.tags')}
        </Heading>
        <Text color="#c7c6c6" fontSize="lg" maxW="2xl">
          {t('common.tags-description')}
        </Text>
      </Stack>

      {
        tags.length === 0 ? (
          <Box
            border="1px solid"
            borderColor="#524533"
            bg="#1c1b1b"
            borderRadius="0"
            p={{ base: '8', md: '12' }}
          >
            <Stack gap="4" alignItems="center" textAlign="center" py="12">
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.12em"
                color="#9f8e78"
              >
                {t('note.status-unavailable')}
              </Text>
              <Heading as="h2" fontSize={{ base: '3xl', md: '4xl' }} fontStyle="italic">
                {t('common.tags-empty-title')}
              </Heading>
              <Text color="#c7c6c6" maxW="md" lineHeight="1.7">
                {t('common.tags-empty-description')}
              </Text>
            </Stack>
          </Box>
        ) : (
          <>
            {Object.entries(primaryGroups).map(([type, groupTags]) => (
              <Stack gap="6">
                <Flex alignItems="center" gap="4">
                  <Text
                    fontFamily="JetBrains Mono, monospace"
                    fontSize="10px"
                    textTransform="uppercase"
                    letterSpacing="0.12em"
                    color="#ffd597"
                    flexShrink="0"
                  >
                    {t(`common.${toKebabCase(type)}` as 'common.frontend')}
                  </Text>
                  <div style="flex:1;height:1px;background:#524533" />
                </Flex>
                <Wrap gap="3">
                  {groupTags.map((tag) => (
                    <Link href={`/${locale}/tags/${tagSlug(tag)}`} display="block">
                      <Box
                        border="1px solid"
                        borderColor="#524533"
                        bg="#1c1b1b"
                        px="4"
                        py="3"
                        _hover={{ transform: 'translate(-2px, -2px)', borderColor: '#ffb000' }}
                        transition="all 0.2s ease"
                      >
                        <TagBadge tag={tag} showCount size="md" />
                      </Box>
                    </Link>
                  ))}
                </Wrap>
              </Stack>
            ))}

            {Object.entries(secondaryGroups).map(([type, groupTags]) => (
              <Stack gap="6">
                <Flex alignItems="center" gap="4">
                  <Text
                    fontFamily="JetBrains Mono, monospace"
                    fontSize="10px"
                    textTransform="uppercase"
                    letterSpacing="0.12em"
                    color="#9f8e78"
                    flexShrink="0"
                  >
                    {t(`common.${toKebabCase(type)}` as 'common.frontend')}
                  </Text>
                  <div style="flex:1;height:1px;background:#524533" />
                </Flex>
                <Wrap gap="3">
                  {groupTags.map((tag) => (
                    <Link href={`/${locale}/tags/${tagSlug(tag)}`} display="block">
                      <Box
                        border="1px solid"
                        borderColor="#524533"
                        bg="#1c1b1b"
                        px="4"
                        py="3"
                        _hover={{ transform: 'translate(-2px, -2px)', borderColor: '#ffb000' }}
                        transition="all 0.2s ease"
                      >
                        <TagBadge tag={tag} showCount size="md" />
                      </Box>
                    </Link>
                  ))}
                </Wrap>
              </Stack>
            ))}
          </>
        )
      }
    </Stack>
  </Container>
</MainLayout>
