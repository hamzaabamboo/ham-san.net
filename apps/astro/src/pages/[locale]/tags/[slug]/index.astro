---
import { FaArrowLeft } from 'react-icons/fa';
import { Container, Divider, Grid, GridItem, Stack, Wrap } from 'styled-system/jsx';
import { formatMonthSpan, formatMonthYear, parseDate } from 'utils/date';
import { toKebabCase } from 'utils/kebab-case';
import { Markdown } from '~/components/lib/Markdown';
import { ProjectCard } from '~/components/projects/ProjectCard';
import { TagBadge } from '~/components/tags/TagBadge';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { graphQLSdk } from '~/graphql';
import { withLastGood } from '~/utils/cms-cache';
import type {
  ExperienceFragment,
  GetTagBySlugQuery,
  ProjectPreviewFragment,
  TagFragment
} from '~/graphql/generated/client';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import { cleanProjectCopy } from '~/utils/project-copy';
import { sortTags, tagSlug } from '~/utils/tags';

export const prerender = false;

const { locale, slug } = Astro.params;
type TagData = NonNullable<GetTagBySlugQuery['tags'][number]>;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

let tagData: TagData | undefined;
let tagUnavailable = false;
const cmsLocale = locale === 'ja' ? 'ja' : 'en';
try {
  tagData = await withLastGood(
    `tag:${slug}`,
    async () => {
      const data = await graphQLSdk.getTagBySlug({ slug });
      let tag = data?.tags?.[0] ?? undefined;
      if (!tag) {
        const aboutData = await withLastGood(`about:${cmsLocale}`, () =>
          graphQLSdk.fetchAboutMe({ locale: cmsLocale })
        );
        const match = (aboutData.tags ?? []).find(
          (candidate) => !!candidate?.title && !!candidate.slug && tagSlug(candidate) === slug
        );
        if (match?.slug && match.slug !== slug) {
          const bySlug = await graphQLSdk.getTagBySlug({ slug: match.slug });
          tag = bySlug?.tags?.[0] ?? undefined;
        }
      }
      return tag;
    },
    (tag) => !!tag
  );
} catch {
  tagUnavailable = true;
}

if (!tagUnavailable && !tagData) {
  return Astro.redirect(`/${locale}/404`);
}

if (tagUnavailable) {
  Astro.response.status = 503;
}

const title = tagData?.title;
const type = tagData?.type;
const experienceItems = (tagData?.experiences ?? []).filter(
  (e): e is ExperienceFragment & { id: string } => !!e
);
const projectItems = (tagData?.projects ?? [])
  .filter((p): p is ProjectPreviewFragment & { id: string } => !!p)
  .map((p) => cleanProjectCopy(p));
const nonNullTags = (tags: Array<TagFragment | null>) => tags.filter((t): t is TagFragment => !!t);
const t = useTranslations(locale);
const pageTitle = `${title ?? t('common.tags')} | ${t('common.name')}`;

if (!tagUnavailable) {
  Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=86400, must-revalidate');
}
---

<MainLayout title={pageTitle}>
  <Container maxW="breakpoint-xl" py="8" w="full">
    <Stack gap="8">
      <Link href={`/${locale}/tags`}>
        <Wrap
          fontSize="xs"
          fontFamily="JetBrains Mono, monospace"
          alignItems="center"
          color="#c7c6c6"
          _hover={{ color: '#ffb000' }}
        >
          <FaArrowLeft />
          <Text>{t('common.tags')}</Text>
        </Wrap>
      </Link>
      {
        tagUnavailable && (
          <Stack
            gap="4"
            alignItems="center"
            textAlign="center"
            py="12"
            border="1px solid"
            borderColor="#524533"
            bg="#1c1b1b"
            p={{ base: '8', md: '12' }}
          >
            <Text
              fontFamily="JetBrains Mono, monospace"
              fontSize="10px"
              textTransform="uppercase"
              letterSpacing="0.12em"
              color="#9f8e78"
            >
              {t('note.status-unavailable')}
            </Text>
            <Heading as="h1" fontSize={{ base: '3xl', md: '4xl' }} fontStyle="italic">
              {t('common.tags-empty-title')}
            </Heading>
            <Text color="#c7c6c6" maxW="md" lineHeight="1.7">
              {t('common.tags-empty-description')}
            </Text>
          </Stack>
        )
      }
      {
        !tagUnavailable && (
          <>
            <Stack
              gap="4"
              borderLeftWidth="2px"
              borderLeftStyle="solid"
              borderLeftColor="#ffb000"
              pl="6"
            >
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.12em"
                color="#ffd597"
              >
                {t('common.tags')}
              </Text>
              <Stack gap="1">
                <Heading as="h1" fontSize={{ base: '5xl', md: '7xl' }} fontStyle="italic">
                  {title}
                </Heading>
                <Wrap fontSize="sm" color="#9f8e78" fontFamily="JetBrains Mono, monospace">
                  {type && <Text>{t(`common.${toKebabCase(type) as 'frontend'}`)}</Text>}
                </Wrap>
              </Stack>
            </Stack>

            {experienceItems.map((experience) => {
              const { title, content, position, tags, start, end } = experience;
              const startDate = start ? parseDate(start as string) : null;
              const endDate = end ? parseDate(end as string) : null;
              const duration = startDate
                ? formatMonthSpan(startDate, endDate ?? new Date(), locale)
                : '';
              return (
                <Stack border="1px solid" borderColor="#524533" bg="#1c1b1b" p="6">
                  <Heading as="h2" fontSize="4xl" fontStyle="italic">
                    {title}
                  </Heading>
                  <Wrap fontSize="sm" color="#9f8e78" fontFamily="JetBrains Mono, monospace">
                    {position && <Text>{`${position}\u00A0|`}</Text>}
                    {startDate && (
                      <Text>
                        {formatMonthYear(startDate, locale)} -{' '}
                        {endDate ? formatMonthYear(endDate, locale) : t('common.present')}
                        {duration ? ` (${duration})` : ''}
                      </Text>
                    )}
                  </Wrap>
                  {tags && (
                    <Wrap fontSize="sm" gap="2" rowGap="2" alignItems="center">
                      <Text>{t('common.tags')}</Text>
                      {sortTags(nonNullTags(tags)).map(
                        (tag) =>
                          tag && (
                            <Link href={`/${locale}/tags/${tagSlug(tag)}`} display="inline-flex">
                              <TagBadge tag={tag} size="sm" />
                            </Link>
                          )
                      )}
                    </Wrap>
                  )}
                  {content && <Markdown content={content} />}
                </Stack>
              );
            })}
            <Divider borderColor="#524533" />
            {projectItems.length > 0 && (
              <Heading as="h2" fontSize={{ base: '2xl', md: '3xl' }} fontStyle="italic">
                {t('project.projects')}
              </Heading>
            )}
            <Grid
              gridTemplateColumns="repeat(auto-fill, minmax(200px, 1fr))"
              alignItems={{ base: 'start', md: 'stretch' }}
            >
              {projectItems.map((project) => (
                <GridItem>
                  <ProjectCard data={project} locale={locale} />
                </GridItem>
              ))}
            </Grid>
          </>
        )
      }
    </Stack>
  </Container>
</MainLayout>
