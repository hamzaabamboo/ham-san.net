---
import { Container, Flex, Box, Grid, Stack } from 'styled-system/jsx';
import { ProjectCard } from '~/components/projects/ProjectCard';
import { Heading } from '~/components/ui/heading';
import { Text } from '~/components/ui/text';
import { TagBadge } from '~/components/tags/TagBadge';
import { graphQLSdk } from '~/graphql';
import type { TagFragment } from '~/graphql/generated/client';
import { useTranslations, validateLocale } from '~/i18n/utils';
import { pickLocale } from '~/utils/fallbackLocale';
import MainLayout from '~/layouts/MainLayout.astro';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const data = await graphQLSdk.fetchProjects({ limit: 75 });

const projects = (data?.projects ?? []).map((p) => pickLocale(p, locale)).filter((p) => !!p);

const t = useTranslations(locale);
const pageTitle = `${t('common.projects')} | ${t('common.name')}`;

const projectGroups = projects.reduce<Record<string, typeof projects>>((acc, project) => {
  const key = project.isActive ? t('project.active') : t('project.inactive');
  acc[key] ??= [];
  acc[key].push(project);
  return acc;
}, {});

const nonNullTags = (tags: Array<TagFragment | null>) => tags.filter((t): t is TagFragment => !!t);

Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=86400, must-revalidate');
---

<MainLayout title={pageTitle}>
  <Container maxW="breakpoint-xl">
    <Stack py="8" gap="12" w="full">
      <Stack
        gap="4"
        borderLeftWidth="2px"
        borderLeftStyle="solid"
        borderLeftColor="amber.500"
        pl="6"
      >
        <Text
          fontFamily="JetBrains Mono, monospace"
          fontSize="10px"
          textTransform="uppercase"
          letterSpacing="0.12em"
          color="amber.500"
        >
          index / main_archive
        </Text>
        <Heading as="h1" fontSize={{ base: '5xl', md: '8xl' }} fontStyle="italic">
          Work & experiments.
        </Heading>
        <Text maxW="2xl" color="fg.muted" fontSize="lg">
          Frontend systems, interaction prototypes, and digital tools. Commercial work and personal
          lab artifacts, organized as a working archive.
        </Text>
      </Stack>
      {
        [t('project.active'), t('project.inactive')].map((group: keyof typeof projectGroups) => {
          const groupProjects = projectGroups[group];
          if (!groupProjects || groupProjects.length === 0) return null;

          return (
            <Stack gap="6">
              <Flex align="center" gap="4">
                <Text
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  letterSpacing="0.12em"
                  color="fg.subtle"
                >
                  {group === t('project.active') ? 'commercial_work' : 'personal_lab'}
                </Text>
                <Box h="1px" flex={1} bg="border.subtle" />
              </Flex>
              <Heading as="h2" fontSize="4xl" fontStyle="italic">
                {group}
              </Heading>
              <Grid
                gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)', xl: 'repeat(3, 1fr)' }}
                gap="6"
              >
                {groupProjects.map((project, idx) => (
                  <Box key={idx}>
                    <ProjectCard data={project} locale={locale} />
                    {project.tags && (
                      <Flex align="center" gap="2" wrap="wrap" mt="3">
                        {nonNullTags(project.tags)
                          .slice(0, 4)
                          .map((tag) => (
                            <TagBadge tag={tag} size="sm" />
                          ))}
                      </Flex>
                    )}
                  </Box>
                ))}
              </Grid>
            </Stack>
          );
        })
      }
    </Stack>
  </Container>
</MainLayout>
