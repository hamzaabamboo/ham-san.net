---
import { Box, Container, Flex, Grid, Stack, Wrap } from 'styled-system/jsx';
import { getMediaUrl } from 'utils/media';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { graphQLSdk } from '~/graphql';
import { useTranslations, validateLocale } from '~/i18n/utils';
import { withLastGood } from '~/utils/cms-cache';
import { pickLocale } from '~/utils/fallbackLocale';
import { cleanProjectCopy } from '~/utils/project-copy';
import MainLayout from '~/layouts/MainLayout.astro';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

let projects: any[] = [];
let projectsUnavailable = false;

try {
  const data = await withLastGood('projects', () => graphQLSdk.fetchProjects({ limit: 75 }));
  projects = (data?.projects ?? [])
    .map((p) => pickLocale(p, locale))
    .filter((p: any) => !!p)
    .map((p) => cleanProjectCopy(p as any));
} catch {
  projectsUnavailable = true;
}

const t = useTranslations(locale);
const pageTitle = `${t('common.projects')} | ${t('common.name')}`;

const activeProjects = projects.filter((p) => p.isActive);
const featuredProjects = activeProjects.slice(0, 6);
const overflowProjects = activeProjects.slice(6);
const inactiveProjects = projects.filter((p) => !p.isActive);
const archiveProjects = [...overflowProjects, ...inactiveProjects];
const archiveGridProjects = archiveProjects.slice(0, 9);
const latestProjectYear = projects.reduce((latest, project) => {
  const year = project.date?.slice(0, 4);
  return year && year > latest ? year : latest;
}, '----');
const yearPartFormatter = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  timeZone: 'Asia/Tokyo'
});
const yearLabel = (year?: string) =>
  year && /^\d{4}$/.test(year)
    ? (yearPartFormatter
        .formatToParts(new Date(`${year}-01-01T00:00:00+09:00`))
        .find((part) => part.type === 'year')?.value ?? year)
    : year;

if (projectsUnavailable) {
  Astro.response.status = 503;
} else {
  Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=86400, must-revalidate');
}
---

<MainLayout title={pageTitle} description={t('project.intro')}>
  <Container maxW="breakpoint-xl" className="page-shell">
    <Stack py="10" gap="16">
      <Stack gap="6" position="relative" pt="4">
        <Box
          position="absolute"
          top="0"
          left="0"
          px="2"
          py="1"
          bg="#353534"
          border="1px solid"
          borderColor="#524533"
        >
          <Text
            fontFamily="JetBrains Mono, monospace"
            fontSize="10px"
            textTransform="uppercase"
            color="#ffd597"
          >
            {t('project.projects')}
          </Text>
        </Box>
        <Heading
          as="h1"
          fontSize={{ base: '5xl', md: '8xl' }}
          fontStyle="italic"
          lineHeight="0.92"
          mt="8"
        >
          {t('project.page-heading')}
        </Heading>
        <Text
          maxW="2xl"
          color="#c7c6c6"
          fontSize="lg"
          borderLeft="1px solid"
          borderLeftColor="#ffb000"
          pl="6"
          py="2"
        >
          {t('project.intro')}
        </Text>
      </Stack>

      <Grid
        gridTemplateColumns={{ base: '1fr', md: 'repeat(3, 1fr)' }}
        gap="1px"
        bg="#524533"
        border="1px solid"
        borderColor="#524533"
      >
        <Stack bg="#131313" p="5" gap="2">
          <Text
            fontFamily="JetBrains Mono, monospace"
            fontSize="10px"
            textTransform="uppercase"
            color="#9f8e78"
          >
            {t('project.active')}
          </Text>
          <Text fontFamily="JetBrains Mono, monospace" fontSize="3xl" color="#ffb000">
            {featuredProjects.length}
          </Text>
        </Stack>
        <Stack className="contact-panel" p="5" gap="2">
          <Text
            fontFamily="JetBrains Mono, monospace"
            fontSize="10px"
            textTransform="uppercase"
            color="#9f8e78"
          >
            {t('project.inactive')}
          </Text>
          <Text fontFamily="JetBrains Mono, monospace" fontSize="3xl" color="#ffb000">
            {archiveProjects.length}
          </Text>
        </Stack>
        <Stack bg="#131313" p="5" gap="2">
          <Text
            fontFamily="JetBrains Mono, monospace"
            fontSize="10px"
            textTransform="uppercase"
            color="#9f8e78"
          >
            {t('project.latest')}
          </Text>
          <Text fontFamily="JetBrains Mono, monospace" fontSize="3xl" color="#ffd597">
            {yearLabel(latestProjectYear)}
          </Text>
        </Stack>
      </Grid>

      {
        projects.length === 0 ? (
          <Box border="1px solid" borderColor="#524533" bg="#1c1b1b" p={{ base: '8', md: '12' }}>
            <Stack gap="4" alignItems="center" textAlign="center" py="12">
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.12em"
                color="#9f8e78"
              >
                {t('project.status-unavailable')}
              </Text>
              <Heading as="h2" fontSize={{ base: '3xl', md: '4xl' }} fontStyle="italic">
                {t('project.empty-title')}
              </Heading>
              <Text color="#c7c6c6" maxW="md" lineHeight="1.7">
                {t('project.empty-description')}
              </Text>
            </Stack>
          </Box>
        ) : (
          <>
            <Stack gap="10">
              <Flex align="center" gap="4" overflow="hidden">
                <Text
                  fontSize="2xl"
                  fontWeight="black"
                  textTransform="uppercase"
                  letterSpacing="-0.05em"
                  flexShrink="0"
                >
                  {t('project.active')}
                </Text>
                <Box h="1px" w="full" bg="#524533" />
              </Flex>
              <Grid
                gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)' }}
                gap="1px"
                bg="#524533"
                border="1px solid"
                borderColor="#524533"
              >
                {featuredProjects.map((project) => {
                  const imageUrl =
                    getMediaUrl(
                      project.media?.[0]?.url,
                      { height: 480 },
                      import.meta.env.PUBLIC_API_URL
                    ) ?? '/images/placeholder-project.jpg';
                  const hasImage = !!project.media?.[0]?.url;
                  return (
                    <Link
                      href={`/${locale}/projects/${project.slug}`}
                      display="block"
                      w="full"
                      bg="#131313"
                      textDecorationLine="none"
                      className="group"
                      _hover={{ bg: '#0e0e0e' }}
                      transition="background-color 0.2s ease"
                    >
                      <Stack p="6" h="full" position="relative" overflow="hidden">
                        {hasImage ? (
                          <Box
                            position="relative"
                            aspectRatio="16 / 9"
                            border="1px solid"
                            borderColor="#524533"
                            overflow="hidden"
                            className="image-archival"
                            mb="6"
                          >
                            <img
                              src={imageUrl}
                              alt=""
                              style={{ width: '100%', height: '100%', objectFit: 'cover' }}
                            />
                          </Box>
                        ) : (
                          <Box
                            position="relative"
                            aspectRatio="16 / 9"
                            border="1px solid"
                            borderColor="#524533"
                            overflow="hidden"
                            className="fallback-grid-lines"
                            display="grid"
                            placeItems="center"
                            mb="6"
                            aria-hidden="true"
                          >
                            <Box
                              fontFamily="Newsreader, serif"
                              fontStyle="italic"
                              fontSize="96px"
                              lineHeight="1"
                              color="#ffb000"
                              opacity="0.3"
                              userSelect="none"
                            >
                              {project.title?.charAt(0)?.toUpperCase()}
                            </Box>
                          </Box>
                        )}
                        <Flex justifyContent="space-between" alignItems="start" mb="2">
                          <Heading
                            as="h2"
                            fontSize="2xl"
                            fontWeight="extrabold"
                            fontStyle="normal"
                            fontFamily="Manrope, sans-serif"
                            transition="color 0.2s ease"
                            className="group-hover-amber group-hover-underline"
                          >
                            {project.title}
                          </Heading>
                          <Text
                            fontFamily="JetBrains Mono, monospace"
                            fontSize="sm"
                            color="#9f8e78"
                          >
                            {yearLabel(project.date?.slice(0, 4))}
                          </Text>
                        </Flex>
                        {project.category?.name && (
                          <Flex gap="2" mb="4">
                            <Box
                              bg="#2a2a2a"
                              border="1px solid"
                              borderColor="#524533"
                              px="2"
                              py="0.5"
                            >
                              <Text
                                fontFamily="JetBrains Mono, monospace"
                                fontSize="9px"
                                textTransform="uppercase"
                              >
                                {project.category.name}
                              </Text>
                            </Box>
                          </Flex>
                        )}
                        {project.tags?.length > 0 && (
                          <Wrap gap="2" mb="4">
                            {project.tags
                              .filter(Boolean)
                              .slice(0, 3)
                              .map((tag: any) => (
                                <Box
                                  bg="#1c1b1b"
                                  border="1px solid"
                                  borderColor="#524533"
                                  px="2"
                                  py="0.5"
                                >
                                  <Text
                                    fontFamily="JetBrains Mono, monospace"
                                    fontSize="9px"
                                    textTransform="uppercase"
                                    color="#9f8e78"
                                  >
                                    {tag.title}
                                  </Text>
                                </Box>
                              ))}
                          </Wrap>
                        )}
                        <Text color="#c7c6c6" fontSize="sm" lineHeight="1.7" mb="6">
                          {project.description}
                        </Text>
                        <Flex gap="2" alignItems="center" mt="auto" className="view-execution-link">
                          <Text
                            fontFamily="JetBrains Mono, monospace"
                            fontSize="11px"
                            textTransform="uppercase"
                            letterSpacing="0.08em"
                            color="#ffb000"
                          >
                            {t('project.view-execution')}
                          </Text>
                          <Text
                            color="#ffb000"
                            fontSize="sm"
                            transition="margin-left 0.2s ease"
                            className="arrow-icon"
                          >
                            →
                          </Text>
                        </Flex>
                      </Stack>
                    </Link>
                  );
                })}
              </Grid>
            </Stack>

            <Stack gap="10">
              <Flex align="center" gap="4" overflow="hidden">
                <Text
                  fontSize="2xl"
                  fontWeight="black"
                  textTransform="uppercase"
                  letterSpacing="-0.05em"
                  flexShrink="0"
                >
                  {t('project.inactive')}
                </Text>
                <Box h="1px" w="full" bg="#524533" />
              </Flex>
              <Grid
                gridTemplateColumns={{ base: '1fr', md: 'repeat(3, 1fr)' }}
                gap="8"
                alignItems="start"
              >
                {archiveGridProjects.map((project) => {
                  return (
                    <Link
                      href={`/${locale}/projects/${project.slug}`}
                      display="block"
                      w="full"
                      position="relative"
                      overflow="hidden"
                      bg="#1c1b1b"
                      border="1px solid"
                      borderColor="#524533"
                      p="6"
                      textDecorationLine="none"
                      className="group blocky-shadow blocky-shadow-hover"
                    >
                      <Box
                        position="absolute"
                        bottom="-24px"
                        right="-8px"
                        fontFamily="Newsreader, serif"
                        fontStyle="italic"
                        fontSize="120px"
                        lineHeight="1"
                        color="#e5e2e1"
                        opacity="0.04"
                        userSelect="none"
                        pointerEvents="none"
                        aria-hidden="true"
                      >
                        {project.title?.charAt(0)?.toUpperCase()}
                      </Box>
                      <Flex justifyContent="space-between" alignItems="center" mb="2">
                        <Heading
                          as="h3"
                          fontSize="lg"
                          fontWeight="bold"
                          fontStyle="normal"
                          fontFamily="Manrope, sans-serif"
                          className="group-hover-underline"
                        >
                          {project.title}
                        </Heading>
                        <Text
                          fontFamily="JetBrains Mono, monospace"
                          fontSize="10px"
                          color="#9f8e78"
                        >
                          {yearLabel(project.date?.slice(0, 4))}
                        </Text>
                      </Flex>
                      <Text color="#c7c6c6" fontSize="xs" lineHeight="1.7" mb="4">
                        {project.description}
                      </Text>
                      {project.links?.length > 0 && (
                        <Wrap gap="2" mb="4">
                          {project.links
                            .filter((link: any) => link?.url)
                            .slice(0, 2)
                            .map((link: any) => (
                              <Box border="1px solid" borderColor="#524533" px="2" py="0.5">
                                <Text
                                  fontFamily="JetBrains Mono, monospace"
                                  fontSize="9px"
                                  textTransform="uppercase"
                                  color="#9f8e78"
                                >
                                  {link.title ?? link.type}
                                </Text>
                              </Box>
                            ))}
                        </Wrap>
                      )}
                      <Text
                        fontFamily="JetBrains Mono, monospace"
                        fontSize="9px"
                        color="#ffb000"
                        opacity="0"
                        transition="opacity 0.2s ease"
                        className="group-hover-reveal"
                      >
                        {t('project.view-execution')}
                      </Text>
                    </Link>
                  );
                })}
              </Grid>
              {archiveProjects.length > 9 && (
                <Stack gap="1px" bg="#524533" border="1px solid" borderColor="#524533">
                  {archiveProjects.slice(9).map((project) => (
                    <Link
                      href={`/${locale}/projects/${project.slug}`}
                      display="block"
                      w="full"
                      bg="#1c1b1b"
                      p="4"
                      textDecorationLine="none"
                      className="group"
                      _hover={{ bg: '#131313' }}
                      transition="background-color 0.2s ease"
                    >
                      <Flex
                        justifyContent="space-between"
                        alignItems="center"
                        gap="4"
                        flexWrap="wrap"
                      >
                        <Stack gap="1" minW="0">
                          <Heading
                            as="h3"
                            fontSize="md"
                            fontWeight="bold"
                            fontStyle="normal"
                            fontFamily="Manrope, sans-serif"
                            className="group-hover-amber group-hover-underline"
                            transition="color 0.2s ease"
                          >
                            {project.title}
                          </Heading>
                          {project.category?.name && (
                            <Text
                              fontFamily="JetBrains Mono, monospace"
                              fontSize="9px"
                              textTransform="uppercase"
                              color="#9f8e78"
                            >
                              {project.category.name}
                            </Text>
                          )}
                        </Stack>
                        <Flex gap="4" alignItems="center" flexShrink="0">
                          <Text
                            fontFamily="JetBrains Mono, monospace"
                            fontSize="10px"
                            color="#9f8e78"
                          >
                            {yearLabel(project.date?.slice(0, 4))}
                          </Text>
                          <Text color="#ffb000" fontSize="sm">
                            →
                          </Text>
                        </Flex>
                      </Flex>
                    </Link>
                  ))}
                </Stack>
              )}
            </Stack>
          </>
        )
      }
    </Stack>
  </Container>
</MainLayout>
