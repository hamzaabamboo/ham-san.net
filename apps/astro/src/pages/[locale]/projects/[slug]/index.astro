---
import { FaArrowLeft } from 'react-icons/fa';
import { Box, Container, Divider, HStack, Stack, Wrap, styled } from 'styled-system/jsx';
import { formatMonthYear, parseDate } from 'utils/date';
import { getMediaUrl } from 'utils/media';
import { Carousel } from '~/components/common/Carousel';
import { LinkItem } from '~/components/common/LinkItem';
import { Markdown } from '~/components/lib/Markdown';
import { TagBadge } from '~/components/tags/TagBadge';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { graphQLSdk } from '~/graphql';
import type { ProjectFragment, TagFragment } from '~/graphql/generated/client';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';

export const prerender = false;

const { locale, slug } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const data = await graphQLSdk.getProjectBySlug({ slug });
const project = data?.projects?.[0] as (ProjectFragment & { id: string }) | undefined;
const { content, title, banner, links, media, category, date, finishedDate, tags } = project ?? {};
const bannerUrl = getMediaUrl(banner?.url, {}, import.meta.env.PUBLIC_API_URL);
const bannerName = banner?.name;
const images = (media ?? [])
  .filter((d): d is { name: string; url: string } => !!d)
  .map((d) => getMediaUrl(d.url, {}, import.meta.env.PUBLIC_API_URL))
  .filter((d): d is string => !!d);
const nonNullTags = (items: Array<TagFragment | null>) =>
  items.filter((t): t is TagFragment => !!t);
const nonNullLinks = (links ?? []).filter((l): l is NonNullable<typeof l> => !!l);
const t = useTranslations(locale);
const pageTitle = `${title ?? t('common.projects')} | ${t('common.name')}`;

Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=86400, must-revalidate');
---

<MainLayout title={pageTitle}>
  <Container maxW="breakpoint-xl" py="8" w="full">
    <Box bg="bg.default" p={{ base: '6', md: '10' }} border="1px solid" borderColor="border.subtle">
      <Stack gap="8">
        <Link href={`/${locale}/projects`}>
          <Wrap
            fontFamily="JetBrains Mono, monospace"
            fontSize="xs"
            alignItems="center"
            color="fg.muted"
            _hover={{ color: 'amber.400' }}
            transition="colors"
          >
            <FaArrowLeft />
            <Text>{t('project.back-to-projects')}</Text>
          </Wrap>
        </Link>
        {
          bannerUrl && (
            <Box overflow="hidden" border="1px solid" borderColor="border.subtle">
              <styled.img
                src={bannerUrl}
                alt={bannerName ?? title ?? undefined}
                objectFit="cover"
                objectPosition="center"
                width="full"
                aspectRatio="16 / 9"
                backgroundColor="bg.muted"
                filter="grayscale(1)"
              />
            </Box>
          )
        }
        <Stack gap="4">
          <Stack gap="2">
            <Text
              fontFamily="JetBrains Mono, monospace"
              fontSize="10px"
              textTransform="uppercase"
              letterSpacing="0.12em"
              color="amber.500"
            >
              project_dossier
            </Text>
            <Heading
              as="h1"
              fontSize={{ base: '5xl', md: '7xl' }}
              fontStyle="italic"
              lineHeight="0.95"
            >
              {title}
            </Heading>
            <Wrap fontSize="sm" color="fg.subtle" fontFamily="JetBrains Mono, monospace">
              <Text fontWeight="bold" color="amber.500">{category?.name}</Text>
              <Text color="border.default">|</Text>
              <Text>
                {formatMonthYear(parseDate(date as string), locale)} -{' '}
                {
                  finishedDate
                    ? formatMonthYear(parseDate(finishedDate as string), locale)
                    : t('common.present')
                }
              </Text>
            </Wrap>
          </Stack>
          {
            tags && (
              <HStack>
                <Text fontWeight="bold" fontSize="sm" color="fg.muted">
                  {t('common.tags')}:
                </Text>
                <Wrap>
                  {nonNullTags(tags).map((tag) => (
                    <Link href={`/${locale}/tags/${tag.slug}`}>
                      <TagBadge tag={tag} showCount size="sm" />
                    </Link>
                  ))}
                </Wrap>
              </HStack>
            )
          }
          {
            links && (
              <Stack gap="2">
                {nonNullLinks.map((l) => {
                  return <LinkItem data={l} />;
                })}
              </Stack>
            )
          }
        </Stack>

        <Divider borderColor="border.subtle" />
        {content && <Markdown content={content} assetsPrefix={import.meta.env.PUBLIC_API_URL} />}
        {
          images.length > 0 && (
            <Stack gap="6">
              <Heading as="h2" fontSize="4xl" fontStyle="italic">
                {t('project.screenshots')}
              </Heading>
              <Carousel client:visible images={images} />
            </Stack>
          )
        }
      </Stack>
    </Box>
  </Container>
</MainLayout>
