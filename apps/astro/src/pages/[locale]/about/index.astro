---
import { Box, Container, Grid, Stack, Wrap } from 'styled-system/jsx';
import { formatMonthSpan, formatMonthYear, parseDate } from 'utils/date';
import { toKebabCase } from 'utils/kebab-case';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { graphQLSdk } from '~/graphql';
import { withLastGood } from '~/utils/cms-cache';
import type { TagFragment } from '~/graphql/generated/client';
import { Enum_Tag_Type } from '~/graphql/generated/client';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import { pickLocale } from '~/utils/fallbackLocale';
import { sortTags } from '~/utils/tags';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.about-me')} | ${t('common.name')}`;

const formatDateRange = (start?: string, end?: string) => {
  const startText = start ? formatMonthYear(parseDate(start), locale) : '';
  const endText = end ? formatMonthYear(parseDate(end), locale) : t('common.present');
  if (!startText) return endText === t('common.present') ? '' : endText;
  return `${startText} - ${endText}`;
};

const formatDuration = (start?: string, end?: string) => {
  if (!start) return '';
  const startDate = parseDate(start);
  const endDate = end ? parseDate(end) : new Date();
  return formatMonthSpan(startDate, endDate, locale);
};

const extractFirstParagraph = (md: string): string => {
  const lines = md.split('\n');
  const paragraphs: string[] = [];
  let current = '';
  for (const line of lines) {
    if (/^#{1,6}\s/.test(line)) break;
    if (line.trim() === '') {
      if (current) {
        paragraphs.push(current.trim());
        current = '';
      }
      if (paragraphs.length >= 1) break;
      continue;
    }
    if (/^[-*]\s/.test(line.trim())) break;
    current += (current ? ' ' : '') + line.trim();
  }
  if (current) paragraphs.push(current.trim());
  return (paragraphs[0] ?? '')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, '')
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1')
    .replace(/https?:\/\/\S+/g, '')
    .replace(/`([^`]*)`/g, '$1')
    .replace(/(\*\*|__)(.*?)\1/g, '$2')
    .replace(/(\*|_)(.*?)\1/g, '$2')
    .replace(/(?:^|(?<=[.!?]))[^.!?]*\bas follows\b[.:]?\s*$/i, '')
    .replace(/(?:^|(?<=。))[^。]*（以下参照）[。：:]?\s*$/, '')
    .replace(/\s+/g, ' ')
    .trim();
};

const nonNullTags = (tags: Array<TagFragment | null>) => tags.filter((t): t is TagFragment => !!t);

const groupByType = <T extends { type: Enum_Tag_Type }>(items: T[]) =>
  items.reduce<Record<string, T[]>>((acc, item) => {
    acc[item.type] ??= [];
    acc[item.type].push(item);
    return acc;
  }, {});

const cmsLocale = locale === 'ja' ? 'ja' : 'en';

let aboutMe: any = null;
let educations: any[] | null = null;
let experiences: any[] | null = null;
let tags: any[] | null = null;
let aboutUnavailable = false;

try {
  const result = await withLastGood(`about:${cmsLocale}`, () =>
    graphQLSdk.fetchAboutMe({ locale: cmsLocale })
  );
  aboutMe = result.aboutMe;
  educations = result.educations;
  experiences = result.experiences;
  tags = result.tags;
} catch {
  aboutUnavailable = true;
}

const skillTags = (tags?.filter(
  (tag: any): tag is NonNullable<typeof tag> & { type: Enum_Tag_Type } =>
    !!tag?.title && !!tag?.slug && !!tag?.type && tag.type !== Enum_Tag_Type.NonDev
) ?? []) as Array<NonNullable<NonNullable<typeof tags>[number]> & { type: Enum_Tag_Type }>;

const skills = groupByType(skillTags);
const profileFocus = skillTags.slice(0, 4);

Astro.response.headers.set(
  'CDN-Cache-Control',
  aboutUnavailable ? 'public, max-age=60, must-revalidate' : 'public, max-age=3600, must-revalidate'
);
---

<MainLayout title={pageTitle} description={t('about-me.hero-summary')}>
  <Container maxW="breakpoint-xl" w="full" className="page-shell">
    <Stack py="10" gap="12">
      <Stack borderLeft="4px solid" borderLeftColor="#ffb000" pl="8" py="4">
        <Box
          px="2"
          py="1"
          bg="#353534"
          border="1px solid"
          borderColor="#524533"
          mb="4"
          w="fit-content"
        >
          <Text
            fontFamily="JetBrains Mono, monospace"
            fontSize="10px"
            textTransform="uppercase"
            color="#dbdbdb"
            letterSpacing="0.1em"
          >
            {t('about-me.eyebrow')}
          </Text>
        </Box>
        <Heading
          as="h1"
          fontSize={{ base: '5xl', md: '7xl' }}
          fontStyle="italic"
          lineHeight="0.95"
          mb="4"
        >
          {t('about-me.hero-title')}
        </Heading>
        <Text maxW="2xl" fontSize="lg" color="#c7c6c6" lineHeight="1.8">
          {
            locale === cmsLocale
              ? (aboutMe?.introduction ?? t('about-me.hero-summary'))
              : t('about-me.hero-summary')
          }
        </Text>
      </Stack>

      <Grid gridTemplateColumns={{ base: '1fr', xl: '0.8fr 1.2fr' }} gap="12">
        <Stack gap="16" order={{ base: 2, xl: 2 }}>
          <Stack gap="8">
            <Wrap alignItems="center" gap="4">
              <span
                class="material-symbols-outlined"
                style="color: #ffb000; font-size: 1.25rem;"
                aria-hidden="true">timeline</span
              >
              <Heading as="h2" fontSize="3xl" fontStyle="italic">{t('common.experiences')}</Heading>
              <Box h="1px" flex="1" bg="#524533" />
            </Wrap>
            {
              experiences && experiences.length > 0 ? (
                <Box position="relative" pl={{ base: '6', md: '12' }}>
                  <Box
                    position="absolute"
                    left="0"
                    top="0"
                    bottom="0"
                    w="1px"
                    className="spine-gradient"
                  />
                  <Stack gap="12">
                    {experiences.map((d, idx) => {
                      const exp = pickLocale(d, locale);
                      if (!exp) return null;
                      const { title, content, position, tags: expTags } = exp;
                      const dateRange = formatDateRange(exp.start as string, exp.end as string);
                      const duration = formatDuration(exp.start as string, exp.end as string);
                      const blurb = content ? extractFirstParagraph(content) : '';
                      return (
                        <Box position="relative">
                          <Box
                            className={
                              idx === 0 ? 'timeline-node timeline-node-active' : 'timeline-node'
                            }
                            position="absolute"
                            left={{ base: '-30px', md: '-52px' }}
                            top="2rem"
                            w="10px"
                            h="10px"
                            border="2px solid"
                          />
                          <Stack
                            border="1px solid"
                            borderColor="#524533"
                            bg="#1c1b1b"
                            p="8"
                            className="blocky-shadow blocky-shadow-hover exp-card-hover"
                          >
                            <Stack gap="1">
                              <Heading
                                as="h3"
                                fontSize="xl"
                                fontWeight="bold"
                                fontStyle="normal"
                                textTransform="uppercase"
                                letterSpacing="-0.02em"
                              >
                                {position}
                              </Heading>
                              <Text
                                fontFamily="JetBrains Mono, monospace"
                                fontSize="xs"
                                color="#ffb000"
                              >
                                {(title ?? '').toUpperCase()} // {dateRange}
                                {duration && ` (${duration})`}
                              </Text>
                            </Stack>
                            {expTags && nonNullTags(expTags).length > 0 && (
                              <Wrap gap="2" mt="4">
                                {sortTags(nonNullTags(expTags))
                                  .slice(0, 3)
                                  .map(
                                    (s) =>
                                      s.slug && (
                                        <Link
                                          href={`/${locale}/tags/${s.slug}`}
                                          display="inline-flex"
                                          minW="44px"
                                          minH="44px"
                                          alignItems="center"
                                        >
                                          <Box
                                            px="2"
                                            py="1"
                                            border="1px solid"
                                            borderColor="#524533"
                                            fontFamily="JetBrains Mono, monospace"
                                            fontSize="10px"
                                            textTransform="uppercase"
                                            color="#dbdbdb"
                                          >
                                            {s.title}
                                          </Box>
                                        </Link>
                                      )
                                  )}
                              </Wrap>
                            )}
                            {blurb && (
                              <Text color="#c7c6c6" fontSize="md" lineHeight="1.8" mt="5">
                                {blurb}
                              </Text>
                            )}
                          </Stack>
                        </Box>
                      );
                    })}
                  </Stack>
                </Box>
              ) : (
                <Box
                  border="1px solid"
                  borderColor="#524533"
                  bg="#1c1b1b"
                  p={{ base: '6', md: '8' }}
                >
                  <Stack alignItems="center" textAlign="center" py="8" gap="4">
                    <Text
                      fontFamily="JetBrains Mono, monospace"
                      fontSize="10px"
                      textTransform="uppercase"
                      letterSpacing="0.15em"
                      color="#9f8e78"
                    >
                      {t('note.status-unavailable')}
                    </Text>
                    <Heading as="h3" fontSize={{ base: '2xl', md: '3xl' }} fontStyle="italic">
                      {t('about-me.timeline-empty-title')}
                    </Heading>
                    <Text color="#c7c6c6" maxW="sm" lineHeight="1.7" fontSize="sm">
                      {t('about-me.timeline-empty-description')}
                    </Text>
                  </Stack>
                </Box>
              )
            }
          </Stack>

          <Box pt="8" borderTop="1px solid" borderColor="#524533">
            <Stack gap="4">
              <Text fontSize="lg" lineHeight="1.8" fontFamily="Newsreader, serif">
                {t('about-me.bio-integrity')}
              </Text>
              <Text fontSize="lg" lineHeight="1.8" fontFamily="Newsreader, serif">
                {t('about-me.bio-subtractive')}
              </Text>
            </Stack>
          </Box>
        </Stack>

        <Stack gap="8" order={{ base: 1, xl: 1 }}>
          <Box
            position="relative"
            border="2px solid"
            borderColor="#524533"
            bg="#0e0e0e"
            overflow="hidden"
            className="blocky-shadow"
            p="6"
          >
            <Stack gap="6">
              <Stack
                border="1px solid"
                borderColor="#524533"
                bg="linear-gradient(135deg, rgba(255, 176, 0, 0.06), transparent 42%), #131313"
                p="5"
                gap="4"
              >
                <Text
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  letterSpacing={locale === 'th' ? 'normal' : '0.12em'}
                  color="#ffb000"
                >
                  {t('about-me.current-stack')}
                </Text>
                <Wrap gap="2">
                  {
                    profileFocus.length > 0 ? (
                      profileFocus.map((tag) => (
                        <Link
                          href={tag.slug ? `/${locale}/tags/${tag.slug}` : '#'}
                          display="inline-flex"
                          minH="36px"
                          alignItems="center"
                        >
                          <Box
                            px="2"
                            py="1"
                            border="1px solid"
                            borderColor="#524533"
                            fontFamily="JetBrains Mono, monospace"
                            fontSize="10px"
                            textTransform="uppercase"
                            color="#dbdbdb"
                          >
                            {tag.title}
                          </Box>
                        </Link>
                      ))
                    ) : (
                      <Text
                        fontFamily="JetBrains Mono, monospace"
                        fontSize="10px"
                        textTransform="uppercase"
                        color="#9f8e78"
                      >
                        {t('common.records-pending')}
                      </Text>
                    )
                  }
                </Wrap>
              </Stack>
              <Box
                position="relative"
                border="1px solid"
                borderColor="#ffb000"
                minH="28"
                overflow="hidden"
                className="fallback-grid-lines"
              >
                <Box
                  position="absolute"
                  inset="4"
                  border="1px solid"
                  borderColor="rgba(255, 176, 0, 0.35)"
                />
                <Text
                  position="absolute"
                  left="4"
                  bottom="3"
                  fontFamily="Newsreader, serif"
                  fontSize="5xl"
                  fontStyle="italic"
                  lineHeight="1"
                >
                  Ham
                </Text>
                <Text
                  position="absolute"
                  right="6"
                  top="6"
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  color="#ffb000"
                >
                  WEB / UI
                </Text>
              </Box>
            </Stack>
          </Box>
          <Stack border="1px solid" borderColor="#524533" bg="#2a2a2a" p="8">
            <Heading as="h2" fontSize="3xl" fontStyle="italic" mb="8"
              >{t('common.education')}</Heading
            >
            <Stack gap="0">
              {
                educations && educations.length > 0 ? (
                  educations.map((d, i) => {
                    const edu = pickLocale(d, locale);
                    if (!edu) return null;
                    return (
                      <Box
                        className={
                          i > 0 ? 'education-entry education-entry-separated' : 'education-entry'
                        }
                        pb="6"
                        borderColor="#524533"
                      >
                        <Text
                          fontFamily="JetBrains Mono, monospace"
                          fontSize="xs"
                          color="#ffb000"
                          mb="1"
                        >
                          {formatDateRange(edu.start as string, edu.end as string)}
                        </Text>
                        <Heading
                          as="h3"
                          fontSize="sm"
                          fontStyle="normal"
                          fontWeight="bold"
                          textTransform="uppercase"
                          letterSpacing="-0.02em"
                        >
                          {edu.title}
                        </Heading>
                        {edu.description && !/^\s*[（(]なし[)）]\s*$/.test(edu.description) && (
                          <Text color="#c7c6c6" fontSize="sm" mt="1">
                            {edu.description}
                          </Text>
                        )}
                      </Box>
                    );
                  })
                ) : (
                  <Box py="4">
                    <Text
                      fontFamily="JetBrains Mono, monospace"
                      fontSize="10px"
                      textTransform="uppercase"
                      letterSpacing="0.15em"
                      color="#9f8e78"
                    >
                      {t('common.records-pending')}
                    </Text>
                  </Box>
                )
              }
            </Stack>
          </Stack>
          <Stack bg="#ffb000" p="8">
            <Heading
              as="h2"
              fontSize="3xl"
              fontWeight="bold"
              fontStyle="italic"
              color="#432c00"
              mb="6"
            >
              {t('about-me.methodology')}
            </Heading>
            <Text color="#432c00" lineHeight="1.8" mb="4">
              {t('about-me.methodology-body')}
            </Text>
            <Text color="#432c00" lineHeight="1.8" fontWeight="bold">
              {t('about-me.methodology-coda')}
            </Text>
          </Stack>
          <Stack gap="8">
            <Wrap alignItems="center" gap="4">
              <Heading as="h2" fontSize="3xl" fontStyle="italic">{t('about-me.skills')}</Heading>
              <Box h="1px" flex="1" bg="#524533" />
            </Wrap>
            {
              Object.keys(skills)
                .slice(0, 2)
                .map((key) => {
                  const sorted = skills[key]
                    .sort((a, b) => (b.projects?.length ?? 0) - (a.projects?.length ?? 0))
                    .slice(0, 4);
                  return (
                    <Stack gap="4">
                      <Text
                        fontFamily="JetBrains Mono, monospace"
                        fontSize="10px"
                        textTransform="uppercase"
                        color="#ffb000"
                        letterSpacing={locale === 'th' ? 'normal' : '0.1em'}
                      >
                        {t(`common.${toKebabCase(key) as 'frontend'}`)}
                      </Text>
                      <Wrap gap="2">
                        {sorted.map((s) => (
                          <Link
                            href={s.slug ? `/${locale}/tags/${s.slug}` : '#'}
                            display="inline-flex"
                            minH="36px"
                            alignItems="center"
                          >
                            <Box
                              px="2"
                              py="1"
                              border="1px solid"
                              borderColor="#524533"
                              fontFamily="JetBrains Mono, monospace"
                              fontSize="10px"
                              textTransform="uppercase"
                              color="#dbdbdb"
                            >
                              {s.title}
                            </Box>
                          </Link>
                        ))}
                      </Wrap>
                    </Stack>
                  );
                })
            }
            <Stack gap="4">
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                color="#ffb000"
                letterSpacing={locale === 'th' ? 'normal' : '0.1em'}
              >
                {t('about-me.tools')}
              </Text>
              <Wrap gap="2">
                {
                  ['VS Code', 'Figma', 'Git', 'Docker', 'Node.js', 'Blender'].map((tool) => (
                    <Box
                      px="2"
                      py="1"
                      border="1px solid"
                      borderColor="#524533"
                      fontFamily="JetBrains Mono, monospace"
                      fontSize="10px"
                      textTransform="uppercase"
                      color="#dbdbdb"
                    >
                      {tool}
                    </Box>
                  ))
                }
              </Wrap>
            </Stack>
          </Stack>
        </Stack>
      </Grid>
    </Stack>

    <section class="credentials-grid">
      <div class="credentials-cell">
        <span>{t('about-me.credentials-certification')}</span>
        <span class="credentials-value">{t('about-me.credentials-certification-value')}</span>
      </div>
      <div class="credentials-cell">
        <span>{t('about-me.credentials-location')}</span>
        <span class="credentials-value-alt">{t('about-me.credentials-location-value')}</span>
      </div>
      <div class="credentials-cell">
        <span>{t('about-me.credentials-availability')}</span>
        <span class="credentials-value">{t('about-me.credentials-availability-value')}</span>
      </div>
      <div class="credentials-cell">
        <span>{t('about-me.credentials-signal')}</span>
        <a href="mailto:hello@ham-san.net" class="credentials-signal" style="text-transform:none"
          >hello@ham-san.net</a
        >
      </div>
    </section>
  </Container>
</MainLayout>
