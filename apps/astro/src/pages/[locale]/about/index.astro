---
import { Box, Container, Divider, Grid, Stack, Wrap } from 'styled-system/jsx';
import { formatDistanceBetween, formatMonthYear, parseDate } from 'utils/date';
import { toKebabCase } from 'utils/kebab-case';
import { Markdown } from '~/components/lib/Markdown';
import { TagBadge } from '~/components/tags/TagBadge';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { graphQLSdk } from '~/graphql';
import type { TagFragment } from '~/graphql/generated/client';
import { Enum_Tag_Type } from '~/graphql/generated/client';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import { pickLocale } from '~/utils/fallbackLocale';
import { sortTags } from '~/utils/tags';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.about-me')} | ${t('common.name')}`;

const formatDateRange = (start?: string, end?: string) => {
  const startText = start ? formatMonthYear(parseDate(start), locale) : '';
  const endText = end ? formatMonthYear(parseDate(end), locale) : t('common.present');
  if (!startText) return endText === t('common.present') ? '' : endText;
  return `${startText} - ${endText}`;
};

const formatDuration = (start?: string, end?: string) => {
  if (!start) return '';
  const startDate = parseDate(start);
  const endDate = end ? parseDate(end) : new Date();
  const startText = formatMonthYear(startDate, locale);
  const endText = end ? formatMonthYear(endDate, locale) : t('common.present');
  if (!startText || (end && !endText)) return '';
  return formatDistanceBetween(startDate, endDate, locale);
};

const nonNullTags = (tags: Array<TagFragment | null>) => tags.filter((t): t is TagFragment => !!t);

const groupByType = <T extends { type: Enum_Tag_Type }>(items: T[]) =>
  items.reduce<Record<string, T[]>>((acc, item) => {
    acc[item.type] ??= [];
    acc[item.type].push(item);
    return acc;
  }, {});

const { aboutMe, educations, experiences, tags } = await graphQLSdk.fetchAboutMe({
  locale: 'en'
});

const skillTags = (tags?.filter(
  (tag): tag is NonNullable<typeof tag> & { type: Enum_Tag_Type } =>
    !!tag?.title && !!tag?.slug && !!tag?.type && tag.type !== Enum_Tag_Type.NonDev
) ?? []) as Array<NonNullable<(typeof tags)[number]> & { type: Enum_Tag_Type }>;

const skills = groupByType(skillTags);

Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=3600, must-revalidate');
---

<MainLayout title={pageTitle}>
  <Container maxW="breakpoint-xl" w="full">
    <Grid
      gridTemplateColumns={{ base: '1fr', xl: 'minmax(280px, 0.9fr) minmax(0, 1.5fr)' }}
      border="1px solid"
      borderColor="border.subtle"
    >
      <Stack
        gap="10"
        p={{ base: '6', md: '8' }}
        bg="bg.subtle"
        borderRightWidth={{ xl: '1px' }}
        borderRightStyle={{ xl: 'solid' }}
        borderRightColor={{ xl: 'border.subtle' }}
      >
        <Stack gap="4">
          <Text
            fontFamily="JetBrains Mono, monospace"
            fontSize="10px"
            textTransform="uppercase"
            letterSpacing="0.12em"
            color="amber.500"
          >
            dossier_id: 9942-x
          </Text>
          <Heading
            as="h1"
            fontSize={{ base: '5xl', md: '7xl' }}
            fontStyle="italic"
            lineHeight="0.95"
          >
            The archive of construction.
          </Heading>
          <Text color="fg.muted" fontSize="lg" lineHeight="1.8">
            {aboutMe?.introduction}
          </Text>
        </Stack>
        <Stack gap="8">
          <Stack gap="4">
            <Text
              fontFamily="JetBrains Mono, monospace"
              fontSize="10px"
              textTransform="uppercase"
              letterSpacing="0.12em"
              color="fg.subtle"
            >
              material inventory
            </Text>
            <Grid gap="4">
              {
                skills &&
                  Object.keys(skills).map((key) => {
                    return (
                      <Box borderBottom="1px solid" borderColor="border.subtle" pb="4">
                        <Text
                          fontSize="xs"
                          textTransform="uppercase"
                          letterSpacing="0.12em"
                          color="fg.subtle"
                          mb="3"
                        >
                          {t(`common.${toKebabCase(key) as 'frontend'}`)}
                        </Text>
                        <Wrap>
                          {[...skills[key]]
                            .sort((a, b) => (b.projects?.length ?? 0) - (a.projects?.length ?? 0))
                            .map(
                              (s) =>
                                s.slug && (
                                  <Link href={`/${locale}/tags/${s.slug}`}>
                                    <TagBadge tag={s} showCount />
                                  </Link>
                                )
                            )}
                        </Wrap>
                      </Box>
                    );
                  })
              }
            </Grid>
          </Stack>
        </Stack>
      </Stack>
      <Stack p={{ base: '6', md: '8' }} gap="12">
        <Stack gap="6">
          <Heading as="h2" fontSize="4xl" fontStyle="italic" id="experiences">
            {t('common.experiences')}
          </Heading>
          <Box position="relative" pl={{ base: '0', md: '10' }}>
            <Box
              display={{ base: 'none', md: 'block' }}
              position="absolute"
              left="1"
              top="0"
              bottom="0"
              w="1px"
              bg="linear-gradient(180deg, transparent, #FFB000, transparent)"
            />
            <Stack gap="10">
              {
                experiences?.map((d) => {
                  const exp = pickLocale(d, locale);
                  if (!exp) return null;
                  const { title, content, position, tags: expTags } = exp;
                  const start = exp.start as string;
                  const end = exp.end as string;
                  return (
                    <Box position="relative">
                      <Box
                        display={{ base: 'none', md: 'block' }}
                        position="absolute"
                        left="-8"
                        top="2"
                        w="3"
                        h="3"
                        bg="bg.canvas"
                        border="2px solid"
                        borderColor="amber.500"
                      />
                      <Stack
                        border="1px solid"
                        borderColor="border.subtle"
                        bg="bg.default"
                        p="6"
                        gap="4"
                      >
                        <Wrap justifyContent="space-between" gap="4">
                          <Stack gap="1">
                            <Heading as="h3" fontSize="4xl" fontStyle="italic">
                              {title}
                            </Heading>
                            <Text
                              fontSize="sm"
                              textTransform="uppercase"
                              letterSpacing="0.12em"
                              color="amber.500"
                            >
                              {position}
                            </Text>
                          </Stack>
                          <Text
                            fontFamily="JetBrains Mono, monospace"
                            fontSize="xs"
                            color="fg.subtle"
                          >
                            {formatDateRange(start, end)}
                            {formatDuration(start, end) && ` (${formatDuration(start, end)})`}
                          </Text>
                        </Wrap>
                        {expTags && (
                          <Wrap fontSize="sm" gap="2" rowGap="2" alignItems="center">
                            {sortTags(nonNullTags(expTags)).map(
                              (s) =>
                                s.slug && (
                                  <Link href={`/${locale}/tags/${s.slug}`} display="inline-flex">
                                    <TagBadge tag={s} showCount size="sm" />
                                  </Link>
                                )
                            )}
                          </Wrap>
                        )}
                        {content && <Markdown content={content} />}
                      </Stack>
                    </Box>
                  );
                })
              }
            </Stack>
          </Box>
        </Stack>
        <Divider borderColor="border.subtle" />
        <Stack gap="6">
          <Heading as="h2" fontSize="4xl" fontStyle="italic" id="education">
            {t('common.education')}
          </Heading>
          <Grid gap="6">
            {
              educations?.map((d) => {
                const edu = pickLocale(d, locale);
                if (!edu) return null;
                const { title, description, content } = edu;
                const start = edu.start as string;
                const end = edu.end as string;
                return (
                  <Stack border="1px solid" borderColor="border.subtle" bg="bg.default" p="6">
                    <Heading as="h3" fontSize="3xl" fontStyle="italic">
                      {title}
                    </Heading>
                    <Wrap fontSize="sm" color="fg.muted">
                      <Text>{description}</Text> <Text>|</Text>
                      <Text>{formatDateRange(start, end)}</Text>
                    </Wrap>
                    {content && <Markdown content={content} />}
                  </Stack>
                );
              })
            }
          </Grid>
        </Stack>
      </Stack>
    </Grid>
  </Container>
</MainLayout>
