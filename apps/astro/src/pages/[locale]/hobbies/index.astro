---
import MainLayout from '~/layouts/MainLayout.astro';
import { Box, Container, Grid, Stack } from 'styled-system/jsx';
import { css, cx } from 'styled-system/css';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { HobbyTypeGlyph } from '~/components/hobbies/HobbyTypeGlyph';
import { useTranslations, validateLocale } from '~/i18n/utils';
import { outlineClient, outlineServerUrl } from '~/utils/outline-api';
import { orderHobbyCards } from '~/utils/hobby-cards';
import { getOutlineSettings } from '~/utils/outline-settings';
import { parseHobbyContent } from '~/utils/hobby-content';
import { getOutlineAssetProxyPath, resolveOutlineAssetUrl } from '~/utils/outline-assets';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.hobbies')} | ${t('common.name')}`;
const monoMetaText = css({
  fontFamily: 'JetBrains Mono, monospace',
  fontSize: '10px',
  letterSpacing: '0.08em',
  textTransform: 'uppercase'
});
const thaiMetaText = css({
  fontFamily: 'var(--font-body)',
  fontSize: 'xs',
  letterSpacing: '0',
  textTransform: 'none'
});
const metaTextClass = locale === 'th' ? thaiMetaText : monoMetaText;
const unavailableMetaTextClass =
  locale === 'th'
    ? thaiMetaText
    : cx(
        monoMetaText,
        css({
          letterSpacing: '0.12em'
        })
      );
const hobbyThumbnail = css({
  display: 'block',
  w: 'full',
  h: 'full',
  objectFit: 'cover',
  filter: 'saturate(1.06) contrast(1.02)'
});
const hobbyRow = css({
  pos: 'relative',
  transition: 'background-color 160ms ease, border-color 160ms ease',
  _hover: {
    bg: 'rgba(255, 176, 0, 0.035)',
    borderColor: '#765c2f'
  }
});
const hobbyVisual = css({
  pos: 'relative',
  display: 'grid',
  placeItems: 'center',
  w: { base: '7.5rem', md: '9rem' },
  maxW: 'full',
  aspectRatio: '4 / 3',
  border: '1px solid #524533',
  bg: '#131313',
  overflow: 'hidden',
  '&::before': {
    pos: 'absolute',
    inset: '0',
    content: '""',
    opacity: '0.85'
  },
  '&[data-embed="photo-gallery"]::before': {
    bg: 'radial-gradient(circle at 30% 20%, rgba(245, 158, 11, 0.24), transparent 34%), linear-gradient(135deg, rgba(255, 176, 0, 0.13), transparent 58%)'
  },
  '&[data-embed="typing-stats"]::before': {
    bg: 'linear-gradient(135deg, rgba(20, 184, 166, 0.2), transparent 46%), linear-gradient(315deg, rgba(99, 102, 241, 0.14), transparent 52%)'
  },
  '&[data-embed="piano-chords"]::before': {
    bg: 'linear-gradient(135deg, rgba(250, 250, 240, 0.14), transparent 42%), linear-gradient(315deg, rgba(168, 85, 247, 0.18), transparent 58%)'
  },
  '&[data-embed="darts-board"]::before': {
    bg: 'radial-gradient(circle at 72% 18%, rgba(132, 204, 22, 0.18), transparent 34%), linear-gradient(135deg, rgba(220, 38, 38, 0.14), transparent 52%)'
  },
  '&[data-embed="rubik-algorithms"]::before': {
    bg: 'linear-gradient(135deg, rgba(239, 68, 68, 0.18), transparent 38%), linear-gradient(225deg, rgba(34, 197, 94, 0.14), transparent 46%), linear-gradient(315deg, rgba(59, 130, 246, 0.14), transparent 54%)'
  },
  '&[data-embed="link-library"]::before': {
    bg: 'linear-gradient(135deg, rgba(56, 189, 248, 0.16), transparent 44%), linear-gradient(315deg, rgba(250, 204, 21, 0.12), transparent 54%)'
  },
  '&[data-embed="field-notes"]::before': {
    bg: 'linear-gradient(135deg, rgba(255, 176, 0, 0.16), transparent 44%), linear-gradient(315deg, rgba(45, 212, 191, 0.09), transparent 54%)'
  },
  '&[data-visual="image"]::before': {
    bg: 'linear-gradient(180deg, transparent 38%, rgba(0, 0, 0, 0.54))'
  }
});
const hobbyVisualGlyph = css({
  pos: 'relative',
  zIndex: '1',
  transform: 'scale(0.72)',
  opacity: '0.92'
});
const hobbyVisualIndex = css({
  pos: 'absolute',
  right: '2',
  bottom: '1',
  zIndex: '2',
  color: '#ffcf70',
  fontFamily: 'JetBrains Mono, monospace',
  fontSize: '10px',
  letterSpacing: '0.08em'
});

let hobbiesList: any[] | undefined = undefined;

try {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 7000);
  const settings = await getOutlineSettings();

  if (settings?.['hobbies-collection']) {
    const res = await outlineClient.POST('/documents.list', {
      body: { collectionId: settings['hobbies-collection'] },
      signal: controller.signal
    });
    clearTimeout(timeout);

    const allDocuments = res.data?.data ?? [];
    const childrenByParent = new Map<string, { id: string; title: string }[]>();

    allDocuments.forEach((document: any) => {
      if (!document.parentDocumentId) return;
      const children = childrenByParent.get(document.parentDocumentId) ?? [];
      children.push({
        id: document.id,
        title: document.title ?? 'Untitled'
      });
      childrenByParent.set(document.parentDocumentId, children);
    });

    const rootDocuments = allDocuments.filter((d: any) => !d.parentDocumentId);
    hobbiesList = rootDocuments.map((document: any) => ({
      ...document,
      childPages: childrenByParent.get(document.id) ?? []
    }));
  } else {
    clearTimeout(timeout);
  }
} catch {}

const outlineAssetPrefix = outlineServerUrl.replace('/api', '');
const outlineAssetProxyPath = getOutlineAssetProxyPath(locale);
const resolveHobbyAssetUrl = (rawUrl?: string) =>
  resolveOutlineAssetUrl(rawUrl, {
    assetsPrefix: outlineAssetPrefix,
    assetProxyBasePath: outlineAssetProxyPath
  });

const getEmbedType = (hobby: { embeds: { type: string }[] }) =>
  hobby.embeds[0]?.type ?? 'field-notes';
const getEmbedLabel = (type?: string) => {
  switch (type) {
    case 'photo-gallery':
      return t('hobbies.embed-photo-gallery');
    case 'twitter-feed':
      return t('hobbies.embed-twitter-feed');
    case 'rubik-algorithms':
      return t('hobbies.embed-rubik-algorithms');
    case 'typing-stats':
      return t('hobbies.embed-typing-stats');
    case 'darts-board':
      return t('hobbies.embed-darts-board');
    case 'link-library':
      return t('hobbies.embed-link-library');
    case 'piano-chords':
      return t('hobbies.embed-piano-chords');
    default:
      return t('hobbies.embed-field-notes');
  }
};
const getEmbedDescription = (type?: string) => {
  switch (type) {
    case 'photo-gallery':
      return t('hobbies.embed-photo-gallery-description');
    case 'twitter-feed':
      return t('hobbies.embed-twitter-feed-description');
    case 'rubik-algorithms':
      return t('hobbies.embed-rubik-algorithms-description');
    case 'typing-stats':
      return t('hobbies.embed-typing-stats-description');
    case 'darts-board':
      return t('hobbies.embed-darts-board-description');
    case 'link-library':
      return t('hobbies.embed-link-library-description');
    case 'piano-chords':
      return t('hobbies.embed-piano-chords-description');
    default:
      return t('hobbies.embed-field-notes-description');
  }
};
const shouldLocalizeSourceSummary = (value?: string) =>
  locale !== 'en' &&
  !!value &&
  /[A-Za-z]{3}/.test(value) &&
  !/[\u0E00-\u0E7F\u3040-\u30ff\u3400-\u9fff]/.test(value);
const getStatusLabel = (status: 'active' | 'inactive') =>
  status === 'inactive' ? t('hobbies.status-inactive') : t('hobbies.status-active');
const hasExplicitStatus = (meta: Record<string, unknown>) =>
  typeof meta.status === 'string' || typeof meta.active === 'boolean';
const hasSourceContent = (hobby: {
  body?: string;
  images?: string[];
  links?: { href: string; label: string }[];
  childPages?: { id: string; title: string }[];
}) =>
  !!hobby.body?.trim() ||
  !!hobby.images?.length ||
  !!hobby.links?.length ||
  !!hobby.childPages?.length;
const getEffectiveStatus = (hobby: {
  status: 'active' | 'inactive';
  meta: Record<string, unknown>;
  body?: string;
  images?: string[];
  links?: { href: string; label: string }[];
  childPages?: { id: string; title: string }[];
}) => {
  if (hasExplicitStatus(hobby.meta)) return hobby.status;
  return hasSourceContent(hobby) ? hobby.status : 'inactive';
};

const formatUpdated = (date?: string | null) =>
  date
    ? new Intl.DateTimeFormat(locale, { year: 'numeric', month: 'short', day: 'numeric' }).format(
        new Date(date)
      )
    : t('hobbies.no-date');
const formatNestedDescription = (childPages?: { title: string }[]) => {
  const titles = (childPages ?? [])
    .map((child) => child.title)
    .filter(Boolean)
    .slice(0, 3);
  if (titles.length === 0) return '';
  if (titles.length === 1) return titles[0];
  if (titles.length === 2) return `${titles[0]} / ${titles[1]}`;
  return `${titles.slice(0, -1).join(' / ')} / ${titles.at(-1)}`;
};

const hobbies = hobbiesList
  ? orderHobbyCards(
      hobbiesList.map((h) => {
        const content = parseHobbyContent({
          title: h.title,
          text: h.text,
          fallbackUpdatedAt: h.updatedAt ?? h.createdAt
        });
        const childPages = h.childPages ?? [];
        const embedType = content.embeds[0]?.type ?? 'field-notes';
        const sourceSummary = shouldLocalizeSourceSummary(content.description)
          ? getEmbedDescription(embedType)
          : content.description;
        const nestedSummary = formatNestedDescription(childPages);
        const localizedNestedSummary = shouldLocalizeSourceSummary(nestedSummary)
          ? getEmbedDescription(embedType)
          : nestedSummary;
        const resolvedImages = content.images
          .map(resolveHobbyAssetUrl)
          .filter((image): image is string => !!image);
        return {
          ...h,
          ...content,
          banner: resolveHobbyAssetUrl(content.banner ?? content.images[0]),
          images: resolvedImages,
          description:
            sourceSummary || localizedNestedSummary || t('hobbies.empty-source-description'),
          updatedLabel: formatUpdated(content.updatedAt),
          childPages,
          status: getEffectiveStatus({
            ...content,
            images: resolvedImages,
            childPages
          })
        };
      })
    )
  : [];
---

<MainLayout title={pageTitle} description={t('hobbies.description')}>
  <Container maxW="breakpoint-xl" w="full" py={{ base: '6', md: '10' }} className="page-shell">
    <Stack gap={{ base: '8', md: '10' }}>
      <Stack gap="4" maxW="4xl">
        <Heading as="h1" fontSize={{ base: '4xl', md: '6xl' }} lineHeight="1">
          {t('hobbies.page-heading')}
        </Heading>
        <Text color="#c7c6c6" fontSize={{ base: 'lg', md: 'xl' }} lineHeight="1.7" maxW="3xl">
          {t('hobbies.description')}
        </Text>
      </Stack>

      {
        hobbies.length === 0 ? (
          <Box border="1px solid" borderColor="#524533" bg="#171615" p={{ base: '6', md: '8' }}>
            <Stack gap="4" py="8">
              <Text className={unavailableMetaTextClass} color="#9f8e78">
                {t('hobbies.status-unavailable')}
              </Text>
              <Heading as="h2" fontSize={{ base: '2xl', md: '3xl' }}>
                {t('hobbies.empty-title')}
              </Heading>
              <Text color="#c7c6c6" maxW="md" lineHeight="1.7">
                {t('hobbies.empty-description')}
              </Text>
            </Stack>
          </Box>
        ) : (
          <>
            <Stack borderTop="1px solid" borderColor="#524533">
              {hobbies.map((hobby, index) => {
                const embedType = getEmbedType(hobby);
                const readableEmbedType = getEmbedLabel(embedType);
                const cardMetrics = [
                  [t('hobbies.metric-status'), getStatusLabel(hobby.status)],
                  [t('hobbies.metric-updated'), hobby.updatedLabel],
                  ...(hobby.links?.length
                    ? [[t('hobbies.metric-links'), String(hobby.links.length)]]
                    : []),
                  ...(hobby.childPages?.length
                    ? [[t('hobbies.metric-pages'), String(hobby.childPages.length)]]
                    : [])
                ];

                return (
                  <Link
                    href={`/${locale}/hobbies/${hobby.id}`}
                    display="grid"
                    gridTemplateColumns={{
                      base: '1fr',
                      md: 'minmax(10rem, 2fr) minmax(0, 5fr) minmax(10rem, 2fr)'
                    }}
                    gap={{ base: '4', md: '8' }}
                    alignItems={{ md: 'center' }}
                    py={{ base: '5', md: '6' }}
                    borderBottom="1px solid"
                    borderColor="#524533"
                    className={cx('group', hobbyRow)}
                  >
                    <Stack gap="2">
                      <Box
                        className={hobbyVisual}
                        data-embed={embedType}
                        data-visual={hobby.banner ? 'image' : 'glyph'}
                      >
                        {hobby.banner ? (
                          <img src={hobby.banner} alt="" class={hobbyThumbnail} loading="lazy" />
                        ) : (
                          <HobbyTypeGlyph
                            type={embedType}
                            label={readableEmbedType}
                            size="hero"
                            className={hobbyVisualGlyph}
                          />
                        )}
                        <span class={hobbyVisualIndex}>{String(index + 1).padStart(2, '0')}</span>
                      </Box>
                      <Text className={metaTextClass} color="#9f8e78">
                        {readableEmbedType}
                      </Text>
                      <Heading as="h2" fontSize={{ base: '2xl', md: '3xl' }} lineHeight="1.15">
                        {hobby.title}
                      </Heading>
                    </Stack>
                    <Text color="#c7c6c6" lineHeight="1.7" overflowWrap="anywhere">
                      {hobby.description}
                    </Text>
                    <Grid
                      gridTemplateColumns="repeat(2, minmax(0, 1fr))"
                      gap="3"
                      color="#9f8e78"
                      className={metaTextClass}
                    >
                      {cardMetrics.map(([label, value]) => (
                        <Stack gap="1">
                          <Text color="#dbdbdb">{label}</Text>
                          <Text>{value}</Text>
                        </Stack>
                      ))}
                    </Grid>
                  </Link>
                );
              })}
            </Stack>

            <Grid
              gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)' }}
              gap={{ base: '8', md: '12' }}
              pt={{ base: '4', md: '8' }}
            >
              <Stack>
                <Heading as="h3" fontSize="2xl" mb="4">
                  {t('hobbies.learning-resources')}
                </Heading>
                <Stack as="ul" gap="3">
                  {hobbies.map((hobby) => {
                    const itemEmbedLabel = getEmbedLabel(getEmbedType(hobby));
                    return (
                      <Link
                        href={`/${locale}/hobbies/${hobby.id}`}
                        display="flex"
                        minH="44px"
                        justifyContent="space-between"
                        alignItems="center"
                        borderBottom="1px solid"
                        borderColor="#524533"
                        pb="2"
                        className="group"
                      >
                        <Text color="#c7c6c6" className="group-hover-amber">
                          {hobby.title}
                        </Text>
                        <Text color="#9f8e78" className={metaTextClass}>
                          {itemEmbedLabel}
                        </Text>
                      </Link>
                    );
                  })}
                </Stack>
              </Stack>
              <Stack gap="4">
                <Heading as="h3" fontSize="2xl" mb="4">
                  {t('hobbies.source-note')}
                </Heading>
                <Text color="#c7c6c6" lineHeight="1.8">
                  {t('hobbies.source-index-note')}
                </Text>
                <Link
                  href={`/${locale}/contact`}
                  display="inline-flex"
                  alignItems="center"
                  minH="44px"
                  alignSelf="start"
                  color="#ffb000"
                  fontWeight="700"
                  className="group-hover-underline"
                >
                  {t('hobbies.send-message')}
                </Link>
              </Stack>
            </Grid>
          </>
        )
      }
    </Stack>
  </Container>
</MainLayout>
