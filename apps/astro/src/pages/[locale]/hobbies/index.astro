                            letterSpacing="0.08em"
                            fontFamily="Manrope, sans-serif"
                          >
                            {t('hobbies.browse-gallery')}
                          </Box>
                          <Box
                            px="6"
                            py="2"
                            border="1px solid"
                            borderColor="#9f8e78"
                            color="#c7c6c6"
                            fontWeight="medium"
                            fontSize="sm"
