---
import MainLayout from '~/layouts/MainLayout.astro';
import { Box, Container, Grid, Stack } from 'styled-system/jsx';
import { BrandMark } from '~/components/brand/BrandMark';
import { HobbyTypeGlyph } from '~/components/hobbies/HobbyTypeGlyph';
import { hobbyStyles } from '~/components/hobbies/hobbyStyles';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { useTranslations, validateLocale } from '~/i18n/utils';
import { outlineClient, outlineServerUrl } from '~/utils/outline-api';
import { orderHobbyCards } from '~/utils/hobby-cards';
import { getOutlineSettings } from '~/utils/outline-settings';
import { parseHobbyContent } from '~/utils/hobby-content';
import { getOutlineAssetProxyPath, resolveOutlineAssetUrl } from '~/utils/outline-assets';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.hobbies')} | ${t('common.name')}`;

let hobbiesList: any[] | undefined = undefined;

try {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 7000);
  const settings = await getOutlineSettings();
  if (settings?.['hobbies-collection']) {
    const res = await outlineClient.POST('/documents.list', {
      body: { collectionId: settings['hobbies-collection'] },
      signal: controller.signal
    });
    clearTimeout(timeout);
    const allDocuments = res.data?.data ?? [];
    const rootDocuments = allDocuments.filter((d: any) => !d.parentDocumentId);
    const childPages = await Promise.all(
      rootDocuments.map(async (document: any) => {
        try {
          const childRes = await Promise.race([
            outlineClient.POST('/documents.list', {
              body: { parentDocumentId: document.id }
            }),
            new Promise<undefined>((resolve) => setTimeout(() => resolve(undefined), 2500))
          ]);
          return (childRes?.data?.data ?? []).map((child: any) => ({
            id: child.id,
            title: child.title ?? 'Untitled'
          }));
        } catch {
          return [];
        }
      })
    );
    hobbiesList = rootDocuments.map((document: any, index: number) => ({
      ...document,
      childPages: childPages[index] ?? []
    }));
  } else {
    clearTimeout(timeout);
  }
} catch {
  // CMS unavailable or timeout — render fallback
}

const outlineAssetPrefix = outlineServerUrl.replace('/api', '');
const outlineAssetProxyPath = getOutlineAssetProxyPath(locale);
const resolveHobbyAssetUrl = (rawUrl?: string) =>
  resolveOutlineAssetUrl(rawUrl, {
    assetsPrefix: outlineAssetPrefix,
    assetProxyBasePath: outlineAssetProxyPath
  });

const getEmbedType = (hobby: { embeds: { type: string }[] }) =>
  hobby.embeds[0]?.type ?? 'field-notes';
const getEmbedLabel = (type?: string) => {
  switch (type) {
    case 'photo-gallery':
      return t('hobbies.embed-photo-gallery');
    case 'twitter-feed':
      return t('hobbies.embed-twitter-feed');
    case 'rubik-algorithms':
      return t('hobbies.embed-rubik-algorithms');
    case 'typing-stats':
      return t('hobbies.embed-typing-stats');
    case 'darts-board':
      return t('hobbies.embed-darts-board');
    case 'link-library':
      return t('hobbies.embed-link-library');
    case 'piano-chords':
      return t('hobbies.embed-piano-chords');
    default:
      return t('hobbies.embed-field-notes');
  }
};
const getStatusLabel = (status: 'active' | 'inactive') =>
  status === 'inactive' ? t('hobbies.status-inactive') : t('hobbies.status-active');
const hasExplicitStatus = (meta: Record<string, unknown>) =>
  typeof meta.status === 'string' || typeof meta.active === 'boolean';
const hasSourceContent = (hobby: {
  body?: string;
  images?: string[];
  links?: { href: string; label: string }[];
  childPages?: { id: string; title: string }[];
}) =>
  !!hobby.body?.trim() ||
  !!hobby.images?.length ||
  !!hobby.links?.length ||
  !!hobby.childPages?.length;
const getEffectiveStatus = (hobby: {
  status: 'active' | 'inactive';
  meta: Record<string, unknown>;
  body?: string;
  images?: string[];
  links?: { href: string; label: string }[];
  childPages?: { id: string; title: string }[];
}) => {
  if (hasExplicitStatus(hobby.meta)) return hobby.status;
  return hasSourceContent(hobby) ? hobby.status : 'inactive';
};
const getPreviewLinks = (hobby: { links?: { href: string; label: string }[] }) =>
  (hobby.links ?? [])
    .filter((link) =>
      /(photo|photos|flickr|instagram|500px|imgur|typingstats|keymash|monkeytype|typeracer|github|docs\.google|plonkit|shopify|manual)/i.test(
        `${link.label} ${link.href}`
      )
    )
    .slice(0, 4);

const formatUpdated = (date?: string | null) =>
  date
    ? new Intl.DateTimeFormat(locale, { year: 'numeric', month: 'short', day: 'numeric' }).format(
        new Date(date)
      )
    : t('hobbies.no-date');
const formatNestedDescription = (childPages?: { title: string }[]) => {
  const titles = (childPages ?? [])
    .map((child) => child.title)
    .filter(Boolean)
    .slice(0, 3);
  if (titles.length === 0) return '';
  if (titles.length === 1) return titles[0];
  if (titles.length === 2) return `${titles[0]} / ${titles[1]}`;
  return `${titles.slice(0, -1).join(' / ')} / ${titles.at(-1)}`;
};

const hobbies = hobbiesList
  ? orderHobbyCards(
      hobbiesList.map((h) => {
        const content = parseHobbyContent({
          title: h.title,
          text: h.text,
          fallbackUpdatedAt: h.updatedAt ?? h.createdAt
        });
        const childPages = h.childPages ?? [];
        const resolvedImages = content.images
          .map(resolveHobbyAssetUrl)
          .filter((image): image is string => !!image);
        return {
          ...h,
          ...content,
          banner: resolveHobbyAssetUrl(content.banner ?? content.images[0]),
          images: resolvedImages,
          description:
            content.description ||
            formatNestedDescription(childPages) ||
            t('hobbies.empty-source-description'),
          updatedLabel: formatUpdated(content.updatedAt),
          childPages,
          status: getEffectiveStatus({
            ...content,
            images: resolvedImages,
            childPages
          })
        };
      })
    )
  : [];
const featuredHobbies = hobbies.filter(hasSourceContent).slice(0, 4);
---

<MainLayout title={pageTitle} description={t('hobbies.description')}>
  <Container maxW="breakpoint-xl" w="full" py="8" className="page-shell">
    <Stack gap="16">
      <Grid
        gridTemplateColumns={{ base: '1fr', lg: 'minmax(0, 7fr) minmax(22rem, 5fr)' }}
        gap="0"
        border="1px solid"
        borderColor="#524533"
        bg="#131313"
      >
        <Stack
          gap={{ base: '5', md: '7' }}
          p={{ base: '6', md: '10' }}
          borderLeft="4px solid"
          borderLeftColor="#ffb000"
        >
          <Text
            fontFamily="JetBrains Mono, monospace"
            fontSize="10px"
            textTransform="uppercase"
            letterSpacing="0.16em"
            color="#2dd4bf"
          >
            {t('hobbies.hero-kicker')}
          </Text>
          <Heading
            as="h1"
            fontSize={{ base: '5xl', md: '7xl' }}
            fontStyle="italic"
            lineHeight="0.95"
          >
            {t('hobbies.page-heading')}
          </Heading>
          <Text color="#c7c6c6" fontSize={{ base: 'lg', md: '2xl' }} maxW="3xl" lineHeight="1.55">
            {t('hobbies.description')}
          </Text>
          <Text color="#9f8e78" fontSize={{ base: 'sm', md: 'md' }} lineHeight="1.8" maxW="2xl">
            {t('hobbies.hero-body')}
          </Text>
        </Stack>
        <Stack className="note-signal-card" p={{ base: '6', md: '8' }} gap="5">
          <Text
            fontFamily="JetBrains Mono, monospace"
            fontSize="10px"
            textTransform="uppercase"
            letterSpacing="0.16em"
            color="#9f8e78"
          >
            {t('hobbies.hero-rail-title')}
          </Text>
          <Stack gap="3">
            {
              featuredHobbies.map((hobby) => {
                const embedType = getEmbedType(hobby);
                const readableEmbedType = getEmbedLabel(embedType);
                return (
                  <Link
                    href={`/${locale}/hobbies/${hobby.id}`}
                    display="grid"
                    gridTemplateColumns="44px minmax(0, 1fr)"
                    gap="4"
                    alignItems="center"
                    borderBottom="1px solid"
                    borderColor="#524533"
                    pb="3"
                    className="group"
                  >
                    <HobbyTypeGlyph type={embedType} label={readableEmbedType} size="badge" />
                    <Box minW="0">
                      <Text color="#e5e2e1" fontWeight="700" className="group-hover-amber">
                        {hobby.title}
                      </Text>
                      <Text
                        color="#9f8e78"
                        fontSize="sm"
                        overflow="hidden"
                        textOverflow="ellipsis"
                        whiteSpace="nowrap"
                      >
                        {readableEmbedType} / {hobby.description}
                      </Text>
                    </Box>
                  </Link>
                );
              })
            }
          </Stack>
        </Stack>
      </Grid>

      {
        hobbies.length === 0 ? (
          <Box border="1px solid" borderColor="#524533" bg="#1c1b1b" p={{ base: '8', md: '12' }}>
            <Stack gap="4" alignItems="center" textAlign="center" py="12">
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.12em"
                color="#9f8e78"
              >
                {t('hobbies.status-unavailable')}
              </Text>
              <Heading as="h2" fontSize={{ base: '3xl', md: '4xl' }} fontStyle="italic">
                {t('hobbies.empty-title')}
              </Heading>
              <Text color="#c7c6c6" maxW="md" lineHeight="1.7">
                {t('hobbies.empty-description')}
              </Text>
            </Stack>
          </Box>
        ) : (
          <>
            <Grid
              gridTemplateColumns={{ base: '1fr', md: 'repeat(12, 1fr)' }}
              gap="0"
              bg="transparent"
              border="1px solid"
              borderColor="#524533"
            >
              {hobbies.map((hobby, index) => {
                const span = index === 0 ? 12 : index === 1 ? 4 : index % 2 === 0 ? 5 : 7;
                const embedType = getEmbedType(hobby);
                const readableEmbedType = getEmbedLabel(embedType);
                const previewLinks = getPreviewLinks(hobby);

                if (index === 0)
                  return (
                    <Link
                      href={`/${locale}/hobbies/${hobby.id}`}
                      gridColumn={{ base: 'span 1', md: '1 / -1' }}
                      w="full"
                      minW="0"
                      bg="#1c1b1b"
                      display="grid"
                      gridTemplateColumns={{ base: '1fr', md: 'minmax(0, 7fr) minmax(22rem, 5fr)' }}
                      overflow="hidden"
                      className="group card-hover-amber"
                      border="1px solid"
                      borderColor="#524533"
                    >
                      <Box
                        position="relative"
                        w="full"
                        h={{ base: '64', md: 'full' }}
                        minH={{ md: '80' }}
                        overflow="hidden"
                        bg="#222221"
                      >
                        <Box
                          position="absolute"
                          inset="0"
                          bgGradient="to-br"
                          gradientFrom="#1c1b1b"
                          gradientVia="#2a2a2a"
                          gradientTo="#1c1b1b"
                        >
                          <Box position="absolute" inset="0" className="fallback-grid-lines" />
                          <Box
                            position="absolute"
                            insetX={{ base: '8', md: '20' }}
                            top={{ base: '10', md: '14' }}
                            h="1px"
                            bg="#e5e2e1"
                            opacity="0.55"
                          />
                          <Box
                            position="absolute"
                            insetX={{ base: '8', md: '20' }}
                            bottom={{ base: '14', md: '18' }}
                            h="1px"
                            bg="#e5e2e1"
                            opacity="0.55"
                          />
                          <Box
                            position="absolute"
                            right="-8"
                            top="-4"
                            className="group-hover-watermark-strong"
                          >
                            <HobbyTypeGlyph type={getEmbedType(hobby)} size="watermark" />
                          </Box>
                          <Box
                            position="absolute"
                            bottom="0"
                            left="0"
                            right="0"
                            h="4px"
                            bg="#ffb000"
                            opacity="0.75"
                          />
                          <Box position="absolute" bottom="12" left="8" opacity="0.95">
                            <Text
                              fontFamily="JetBrains Mono, monospace"
                              fontSize="10px"
                              textTransform="uppercase"
                              letterSpacing="0.2em"
                              color="#ffb000"
                            >
                              {hobby.title}
                            </Text>
                          </Box>
                        </Box>
                        {hobby.banner ? (
                          <>
                            <img src={hobby.banner} alt="" class={hobbyStyles.imageHero} />
                            <Box
                              position="absolute"
                              inset="0"
                              zIndex="1"
                              bgGradient="to-t"
                              gradientFrom="rgba(14, 14, 14, 0.72)"
                              gradientVia="rgba(14, 14, 14, 0.18)"
                              gradientTo="rgba(14, 14, 14, 0.12)"
                            />
                          </>
                        ) : previewLinks.length > 0 ? (
                          <Box
                            position="absolute"
                            inset="0"
                            zIndex="1"
                            display="flex"
                            alignItems="center"
                            px={{ base: '6', md: '12' }}
                            py={{ base: '8', md: '12' }}
                            pointerEvents="none"
                          >
                            <Box
                              w="min(100%, 34rem)"
                              border="2px solid"
                              borderColor="#ffb000"
                              bg="rgba(14, 14, 14, 0.72)"
                              boxShadow="12px 12px 0 rgba(255, 176, 0, 0.12)"
                              p={{ base: '5', md: '7' }}
                              textAlign="left"
                            >
                              <Text
                                fontFamily="JetBrains Mono, monospace"
                                fontSize="10px"
                                textTransform="uppercase"
                                letterSpacing="0.18em"
                                color="#ffb000"
                                mb="4"
                              >
                                {t('hobbies.source-backed')} / {readableEmbedType}
                              </Text>
                              <Stack gap="2">
                                {previewLinks.map((link, linkIndex) => (
                                  <Box
                                    key={link.href}
                                    display="grid"
                                    gridTemplateColumns="2.5rem minmax(0, 1fr)"
                                    gap="3"
                                    alignItems="center"
                                    color="#e5e2e1"
                                    fontFamily="JetBrains Mono, monospace"
                                    fontSize={{ base: '11px', md: '12px' }}
                                    textTransform="uppercase"
                                    letterSpacing="0.08em"
                                  >
                                    <Text color="#2dd4bf">
                                      {String(linkIndex + 1).padStart(2, '0')}
                                    </Text>
                                    <Text
                                      overflow="hidden"
                                      textOverflow="ellipsis"
                                      whiteSpace="nowrap"
                                    >
                                      {link.label}
                                    </Text>
                                  </Box>
                                ))}
                              </Stack>
                            </Box>
                          </Box>
                        ) : (
                          <Box
                            position="absolute"
                            inset="0"
                            zIndex="1"
                            display="grid"
                            placeItems="center"
                            px={{ base: '8', md: '12' }}
                            textAlign="center"
                            pointerEvents="none"
                          >
                            <Box
                              border="2px solid"
                              borderColor="#ffb000"
                              px={{ base: '6', md: '10' }}
                              py={{ base: '5', md: '7' }}
                              bg="rgba(14, 14, 14, 0.58)"
                              boxShadow="12px 12px 0 rgba(255, 176, 0, 0.12)"
                            >
                              <HobbyTypeGlyph
                                type={getEmbedType(hobby)}
                                label={readableEmbedType}
                                size="hero"
                              />
                              <Text
                                mt="4"
                                fontFamily="JetBrains Mono, monospace"
                                fontSize={{ base: '10px', md: '12px' }}
                                textTransform="uppercase"
                                letterSpacing="0.18em"
                                color="#e5e2e1"
                              >
                                {readableEmbedType}
                              </Text>
                            </Box>
                          </Box>
                        )}
                        <Box
                          position="absolute"
                          top={{ base: '6', md: '8' }}
                          left={{ base: '6', md: '8' }}
                          zIndex="2"
                        >
                          <Text
                            fontFamily="JetBrains Mono, monospace"
                            fontSize={{ base: '8px', md: '10px' }}
                            textTransform="uppercase"
                            letterSpacing={{ base: '0.14em', md: '0.2em' }}
                            color="#ffb000"
                            fontWeight="bold"
                          >
                            {readableEmbedType}
                          </Text>
                        </Box>
                      </Box>
                      <Box
                        p={{ base: '6', md: '8' }}
                        borderTop={{ base: '1px solid', md: '0' }}
                        borderLeft={{ md: '1px solid' }}
                        borderColor="#524533"
                        display="flex"
                        flexDirection="column"
                      >
                        <Box
                          display="flex"
                          justifyContent="space-between"
                          alignItems="start"
                          mb={{ base: '3', md: '4' }}
                        >
                          <Heading as="h2" fontSize={{ base: '2xl', md: '3xl' }} fontStyle="italic">
                            {hobby.title}
                          </Heading>
                          <HobbyTypeGlyph
                            type={getEmbedType(hobby)}
                            label={readableEmbedType}
                            size="badge"
                          />
                        </Box>
                        <Box
                          display="flex"
                          flexWrap="wrap"
                          gap="2"
                          mb="4"
                          fontFamily="JetBrains Mono, monospace"
                          fontSize="10px"
                          textTransform="uppercase"
                          color="#9f8e78"
                        >
                          <Text>{getStatusLabel(hobby.status)}</Text>
                          <Text>/</Text>
                          <Text>{readableEmbedType}</Text>
                          <Text>/</Text>
                          <Text>{hobby.updatedLabel}</Text>
                        </Box>
                        <Text
                          color="#c7c6c6"
                          mb={{ base: '4', md: '6' }}
                          maxW="lg"
                          overflowWrap="anywhere"
                          className="line-clamp-2"
                        >
                          {hobby.description}
                        </Text>
                        <Box display="flex" flexWrap="wrap" gap={{ base: '3', md: '4' }} mt="auto">
                          <Box
                            px="6"
                            py="2"
                            bg="#ffb000"
                            color="#432c00"
                            fontWeight="bold"
                            fontSize="sm"
                            border="1px solid"
                            borderColor="#9f8e78"
                            className="blocky-shadow blocky-shadow-hover"
                            textTransform="uppercase"
                            letterSpacing="0.08em"
                            fontFamily="var(--font-body)"
                          >
                            {t('hobbies.browse-gallery')}
                          </Box>
                          <Box
                            px="6"
                            py="2"
                            border="1px solid"
                            borderColor="#9f8e78"
                            color="#c7c6c6"
                            fontWeight="medium"
                            fontSize="sm"
                            textTransform="uppercase"
                            fontFamily="var(--font-body)"
                          >
                            {t('hobbies.process-notes')}
                          </Box>
                        </Box>
                      </Box>
                    </Link>
                  );

                if (index === 1)
                  return (
                    <Link
                      href={`/${locale}/hobbies/${hobby.id}`}
                      gridColumn={{ base: 'span 1', md: `span ${span}` }}
                      w="full"
                      minW="0"
                      bg="#1c1b1b"
                      display="block"
                      position="relative"
                      className="group card-hover-amber"
                      border="1px solid"
                      borderColor="#524533"
                    >
                      <Stack p={{ base: '6', md: '8' }} h="full" justifyContent="space-between">
                        <Box>
                          <Box
                            alignSelf="start"
                            display="inline-block"
                            px="3"
                            py="1"
                            bg="#353534"
                            fontFamily="JetBrains Mono, monospace"
                            fontSize="10px"
                            color="#ffd597"
                            border="1px solid"
                            borderColor="#524533"
                            textTransform="uppercase"
                            letterSpacing="0.12em"
                            mb="8"
                          >
                            {readableEmbedType}
                          </Box>
                          <Box
                            display="flex"
                            flexWrap="wrap"
                            gap="2"
                            fontFamily="JetBrains Mono, monospace"
                            fontSize="10px"
                            textTransform="uppercase"
                            color="#9f8e78"
                            mb="4"
                          >
                            <Text>{getStatusLabel(hobby.status)}</Text>
                            <Text>/</Text>
                            <Text>{readableEmbedType}</Text>
                          </Box>
                          <Heading as="h2" fontSize="3xl" fontStyle="italic" mb="4">
                            {hobby.title}
                          </Heading>
                          <Text
                            color="#c7c6c6"
                            mb="8"
                            overflowWrap="anywhere"
                            className="line-clamp-3"
                          >
                            {hobby.description}
                          </Text>
                        </Box>
                        <Box>
                          <Box borderTop="1px solid" borderColor="#524533" pt="4">
                            <Text
                              fontFamily="JetBrains Mono, monospace"
                              fontSize="10px"
                              color="#dbdbdb"
                              textTransform="uppercase"
                              mb="1"
                            >
                              {t('hobbies.last-updated')}
                            </Text>
                            <Text color="#9f8e78" fontSize="sm">
                              {hobby.updatedLabel}
                            </Text>
                          </Box>
                          <Box
                            display="flex"
                            alignItems="center"
                            mt="4"
                            fontSize="sm"
                            color="#ffb000"
                            fontWeight="bold"
                            fontStyle="italic"
                            className="group-hover-underline"
                          >
                            <HobbyTypeGlyph type={getEmbedType(hobby)} size="inline" />
                            {t('hobbies.explore')}
                          </Box>
                        </Box>
                      </Stack>
                      <Box
                        position="absolute"
                        bottom="0"
                        right="0"
                        p="4"
                        opacity="0.1"
                        fontSize="8xl"
                        fontStyle="italic"
                        fontWeight="black"
                        fontFamily="var(--font-display)"
                        className="group-hover-watermark"
                      >
                        <HobbyTypeGlyph type={getEmbedType(hobby)} size="watermark" />
                      </Box>
                    </Link>
                  );

                if (index === 2)
                  return (
                    <Link
                      href={`/${locale}/hobbies/${hobby.id}`}
                      gridColumn={{ base: 'span 1', md: `span ${span}` }}
                      w="full"
                      minW="0"
                      bg="#1c1b1b"
                      display="flex"
                      flexDirection="column"
                      alignItems="stretch"
                      overflow="hidden"
                      className="group card-hover-amber"
                      border="1px solid"
                      borderColor="#524533"
                    >
                      <Box p={{ base: '6', md: '8' }}>
                        <Box
                          display="flex"
                          justifyContent="space-between"
                          alignItems="start"
                          mb={{ base: '4', md: '6' }}
                        >
                          <Heading
                            as="h2"
                            fontSize={{ base: '2xl', md: '3xl' }}
                            fontStyle="italic"
                            lineHeight="tight"
                          >
                            {hobby.title}
                          </Heading>
                          <HobbyTypeGlyph
                            type={getEmbedType(hobby)}
                            label={readableEmbedType}
                            size="badge"
                          />
                        </Box>
                        <Text
                          color="#c7c6c6"
                          mb={{ base: '6', md: '8' }}
                          overflowWrap="anywhere"
                          className="line-clamp-3"
                        >
                          {hobby.description}
                        </Text>
                        <Box
                          display="flex"
                          flexWrap="wrap"
                          gap="2"
                          mb="5"
                          fontFamily="JetBrains Mono, monospace"
                          fontSize="10px"
                          textTransform="uppercase"
                          color="#9f8e78"
                        >
                          <Text>{getStatusLabel(hobby.status)}</Text>
                          <Text>/</Text>
                          <Text>{readableEmbedType}</Text>
                          <Text>/</Text>
                          <Text>{hobby.updatedLabel}</Text>
                        </Box>
                        <Box
                          display="grid"
                          gridTemplateColumns="repeat(2, 1fr)"
                          gap="2"
                          fontFamily="JetBrains Mono, monospace"
                          fontSize="10px"
                          color="#dbdbdb"
                          mb={{ base: '6', md: '8' }}
                        >
                          <Box
                            border="1px solid"
                            borderColor="#524533"
                            p="2"
                            textTransform="uppercase"
                            cursor="pointer"
                            _hover={{ bg: '#353534' }}
                          >
                            {t('hobbies.process-notes')}
                          </Box>
                          <Box
                            border="1px solid"
                            borderColor="#524533"
                            p="2"
                            textTransform="uppercase"
                            cursor="pointer"
                            _hover={{ bg: '#353534' }}
                          >
                            {t('hobbies.explore')}
                          </Box>
                        </Box>
                      </Box>
                      <Box
                        h={{ base: '48', md: '64' }}
                        mt="auto"
                        borderTop="1px solid"
                        borderColor="#524533"
                        bg="#222221"
                        position="relative"
                        overflow="hidden"
                      >
                        {hobby.banner ? (
                          <img src={hobby.banner} alt="" class={hobbyStyles.imageBottom} />
                        ) : (
                          <Box
                            position="absolute"
                            inset="0"
                            bgGradient="to-t"
                            gradientFrom="#0e0e0e"
                            gradientVia="#1c1b1b"
                            gradientTo="#2a2a2a"
                          >
                            <Box position="absolute" inset="0" className="fallback-grid-lines" />
                            <Box
                              position="absolute"
                              inset="0"
                              display="flex"
                              alignItems="center"
                              justifyContent="center"
                              opacity="0.18"
                              className="group-hover-watermark-strong"
                            >
                              <HobbyTypeGlyph
                                type={getEmbedType(hobby)}
                                label={readableEmbedType}
                                size="hero"
                              />
                            </Box>
                            <Box
                              position="absolute"
                              top="0"
                              left="0"
                              right="0"
                              h="2px"
                              bg="#ffb000"
                              opacity="0.4"
                            />
                            <Box position="absolute" bottom="4" right="6" opacity="0.08">
                              <Text
                                fontFamily="JetBrains Mono, monospace"
                                fontSize="10px"
                                textTransform="uppercase"
                                letterSpacing="0.2em"
                                color="#ffb000"
                              >
                                {readableEmbedType}
                              </Text>
                            </Box>
                          </Box>
                        )}
                      </Box>
                    </Link>
                  );

                return (
                  <Link
                    href={`/${locale}/hobbies/${hobby.id}`}
                    gridColumn={{ base: 'span 1', md: `span ${span}` }}
                    w="full"
                    minW="0"
                    bg="#1c1b1b"
                    display="flex"
                    flexDirection="column"
                    alignItems="stretch"
                    className="group card-hover-amber"
                    border="1px solid"
                    borderColor="#524533"
                  >
                    <Box position="relative" flex="1" minH={{ base: '56', md: '72' }} bg="#222221">
                      {hobby.banner ? (
                        <>
                          <img src={hobby.banner} alt="" class={hobbyStyles.imageOverlay} />
                          <Box
                            position="absolute"
                            inset="0"
                            bgGradient="to-t"
                            gradientFrom="#1c1b1b"
                            gradientVia="transparent"
                            gradientTo="transparent"
                            opacity="0.9"
                          />
                        </>
                      ) : (
                        <Box
                          position="absolute"
                          inset="0"
                          bgGradient="to-t"
                          gradientFrom="#131313"
                          gradientVia="#1c1b1b"
                          gradientTo="#2a2a2a"
                        >
                          <Box position="absolute" inset="0" className="fallback-grid-lines" />
                          <Box
                            position="absolute"
                            top="4"
                            right="6"
                            opacity="0.14"
                            className="group-hover-watermark-strong"
                          >
                            <Text
                              fontSize={{ base: '120px', md: '180px' }}
                              fontWeight="black"
                              fontFamily="var(--font-display)"
                              fontStyle="italic"
                              lineHeight="1"
                              color="#e5e2e1"
                              aria-hidden="true"
                            >
                              {hobby.title?.charAt(0).toUpperCase()}
                            </Text>
                          </Box>
                          <Box
                            position="absolute"
                            inset="0"
                            bgGradient="to-t"
                            gradientFrom="#131313"
                            gradientVia="transparent"
                            gradientTo="transparent"
                            opacity="0.8"
                          />
                        </Box>
                      )}
                      <Box position="absolute" bottom="0" left="0" p={{ base: '6', md: '8' }}>
                        <Box
                          display="inline-block"
                          px="3"
                          py="1"
                          bg="#ffb000"
                          color="#432c00"
                          fontFamily="JetBrains Mono, monospace"
                          fontSize="10px"
                          fontWeight="bold"
                          textTransform="uppercase"
                          letterSpacing="0.12em"
                          mb={{ base: '3', md: '4' }}
                        >
                          {readableEmbedType}
                        </Box>
                        <Heading
                          as="h2"
                          fontSize={{ base: '3xl', md: '4xl' }}
                          fontStyle="italic"
                          mb="2"
                        >
                          {hobby.title}
                        </Heading>
                        <Text
                          color="#c7c6c6"
                          maxW="md"
                          overflowWrap="anywhere"
                          className="line-clamp-2"
                        >
                          {hobby.description}
                        </Text>
                        <Box
                          display="flex"
                          flexWrap="wrap"
                          gap="2"
                          mt="3"
                          fontFamily="JetBrains Mono, monospace"
                          fontSize="10px"
                          textTransform="uppercase"
                          color="#9f8e78"
                        >
                          <Text>{getStatusLabel(hobby.status)}</Text>
                          <Text>/</Text>
                          <Text>{readableEmbedType}</Text>
                          <Text>/</Text>
                          <Text>{hobby.updatedLabel}</Text>
                        </Box>
                      </Box>
                    </Box>
                    <Box
                      borderTop="1px solid"
                      borderColor="#524533"
                      p={{ base: '4', md: '6' }}
                      display="flex"
                      flexDirection={{ base: 'column', md: 'row' }}
                      gap={{ base: '3', md: '0' }}
                      justifyContent="space-between"
                      alignItems={{ base: 'start', md: 'center' }}
                      bg="#0e0e0e"
                    >
                      <Text
                        fontFamily="JetBrains Mono, monospace"
                        fontSize="10px"
                        color="#9f8e78"
                        textTransform="uppercase"
                        opacity="0.8"
                      >
                        {readableEmbedType}: {hobby.title}
                      </Text>
                      <Box
                        display="flex"
                        alignItems="center"
                        fontFamily="JetBrains Mono, monospace"
                        fontSize="10px"
                        color="#ffb000"
                        textTransform="uppercase"
                        fontWeight="bold"
                        letterSpacing="0.12em"
                        cursor="pointer"
                        _hover={{ color: '#e5e2e1' }}
                      >
                        <HobbyTypeGlyph type={getEmbedType(hobby)} size="inline" />
                        {t('hobbies.explore')}
                      </Box>
                    </Box>
                  </Link>
                );
              })}
            </Grid>

            <Grid
              gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)' }}
              gap={{ base: '8', md: '12' }}
              borderTop="1px solid"
              borderColor="#524533"
              pt={{ base: '8', md: '12' }}
              mt={{ base: '12', md: '24' }}
            >
              <Stack>
                <Heading
                  as="h3"
                  fontSize="2xl"
                  fontStyle="italic"
                  mb="6"
                  display="flex"
                  alignItems="center"
                >
                  <HobbyTypeGlyph type="field-notes" size="inline" />
                  {t('hobbies.learning-resources')}
                </Heading>
                <Stack as="ul" gap="4">
                  {hobbies.map((hobby) => {
                    const itemEmbedType = getEmbedType(hobby);
                    const itemEmbedLabel = getEmbedLabel(itemEmbedType);
                    return (
                      <Link
                        href={`/${locale}/hobbies/${hobby.id}`}
                        display="flex"
                        minH="44px"
                        justifyContent="space-between"
                        alignItems="center"
                        borderBottom="1px solid"
                        borderColor="#524533"
                        pb="2"
                        className="group"
                      >
                        <Text color="#c7c6c6" className="group-hover-amber">
                          {hobby.title}
                        </Text>
                        <Text opacity="0.5">
                          <HobbyTypeGlyph
                            type={itemEmbedType}
                            label={itemEmbedLabel}
                            size="inline"
                          />
                        </Text>
                      </Link>
                    );
                  })}
                </Stack>
              </Stack>
              <Stack
                bg="#2a2a2a"
                border="1px solid"
                borderColor="#524533"
                p={{ base: '6', md: '8' }}
                position="relative"
                overflow="hidden"
              >
                <Box
                  position="absolute"
                  top="-4"
                  right="-4"
                  w="40"
                  h="40"
                  opacity="0.05"
                  pointerEvents="none"
                  transform="rotate(12deg)"
                >
                  <BrandMark size={160} color="#e5e2e1" accent="#ffb000" />
                </Box>
                <Heading as="h3" fontSize="2xl" fontStyle="italic" color="#ffb000" mb="4">
                  {t('hobbies.collaboration-heading')}
                </Heading>
                <Text color="#c7c6c6" lineHeight="1.8" mb="6">
                  {t('hobbies.collaboration-body')}
                </Text>
                <Link
                  href={`/${locale}/contact`}
                  display="inline-block"
                  px="8"
                  py="3"
                  bg="#ffb000"
                  color="#432c00"
                  fontWeight="bold"
                  fontFamily="var(--font-body)"
                  letterSpacing="0.12em"
                  fontSize="sm"
                  className="blocky-shadow blocky-shadow-hover"
                >
                  {t('hobbies.send-message')}
                </Link>
              </Stack>
            </Grid>
          </>
        )
      }
    </Stack>
  </Container>
</MainLayout>
