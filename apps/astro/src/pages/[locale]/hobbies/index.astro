---
import MainLayout from '~/layouts/MainLayout.astro';
import { Box, Container, Grid, Stack } from 'styled-system/jsx';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { BrandMark } from '~/components/brand/BrandMark';
import { useTranslations, validateLocale } from '~/i18n/utils';
import { outlineClient, outlineServerUrl } from '~/utils/outline-api';
import { orderHobbyCards } from '~/utils/hobby-cards';
import { getOutlineSettings } from '~/utils/outline-settings';
import { getArticleBanner } from 'outline/article';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.hobbies')} | ${t('common.name')}`;

let hobbiesList: any[] | undefined = undefined;

try {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);
  const settings = await getOutlineSettings();
  if (settings?.['hobbies-collection']) {
    const res = await outlineClient.POST('/documents.list', {
      body: { collectionId: settings['hobbies-collection'] },
      signal: controller.signal
    });
    hobbiesList = res.data?.data?.filter((d: any) => !d.parentDocumentId);
  }
  clearTimeout(timeout);
} catch {
  // CMS unavailable or timeout — render fallback
}

const outlineAssetPrefix = outlineServerUrl.replace('/api', '');
const outlineAssetProxyPath = `/${locale}/api/outline-asset`;
const resolveOutlineAssetUrl = (rawUrl?: string) => {
  if (!rawUrl) return rawUrl;
  if (/^(?:[a-z]+:)?\/\//i.test(rawUrl) || rawUrl.startsWith('data:')) return rawUrl;
  if (rawUrl.includes('attachments.redirect')) {
    const query = rawUrl.split('?')[1];
    return query ? `${outlineAssetProxyPath}?${query}` : outlineAssetProxyPath;
  }
  const normalizedUrl = rawUrl.startsWith('/') ? rawUrl : `/${rawUrl.replace(/^\.?\/*/, '')}`;
  return `${outlineAssetPrefix}${normalizedUrl}`;
};

const getHobbyDescription = (content?: string) => {
  const lines = (content ?? '')
    .split('\n')
    .map((l) => l.trim())
    .filter(Boolean)
    .filter((l) => !/^!\[/.test(l))
    .filter((l) => !/^#{1,6}\s/.test(l))
    .filter((l) => !/^[-*]\s/.test(l))
    .filter((l) => !/^>\s/.test(l))
    .filter((l) => !/^```/.test(l))
    .filter((l) => !/^https?:\/\//.test(l))
    .filter((l) => !/^<https?:\/\//.test(l))
    .filter((l) => !/^\|/.test(l))
    .filter((l) => !/^\\$/.test(l))
    .map((l) =>
      l
        .replaceAll(/`{1,3}([^`]*)`{1,3}/g, '$1')
        .replaceAll(/(\*\*|__)(.*?)\1/g, '$2')
        .replaceAll(/(\*|_)(.*?)\1/g, '$2')
        .replaceAll(/\[([^\]]+)\]\(([^)]+)\)/g, '$1')
        .replaceAll(/<https?:\/\/[^>]+>/g, '')
        .replaceAll(/https?:\/\/\S+/g, '')
        .replaceAll(/[*_~\\]/g, '')
        .trim()
    )
    .filter((l) => l.length > 20);

  const prose = lines[0] ?? '';
  if (!prose) return '';
  const truncated = prose.substring(0, 140);
  const lastSpace = truncated.lastIndexOf(' ');
  return lastSpace > 40 ? truncated.substring(0, lastSpace) + '…' : truncated + '…';
};

const hobbies = hobbiesList
  ? orderHobbyCards(
      hobbiesList.map((h) => ({
        ...h,
        banner: resolveOutlineAssetUrl(getArticleBanner(h.text) ?? undefined),
        description: getHobbyDescription(h.text)
      }))
    ).slice(0, 4)
  : [];
---

<MainLayout title={pageTitle} description={t('hobbies.description')}>
  <Container maxW="breakpoint-xl" w="full" py="8" className="page-shell">
    <Stack gap="16">
      <Box borderLeft="4px solid" borderLeftColor="#ffb000" pl="6" py="2">
        <Heading
          as="h1"
          fontSize={{ base: '5xl', md: '7xl' }}
          fontStyle="italic"
          lineHeight="0.95"
          mb="4"
        >
          {t('hobbies.page-heading')}
        </Heading>
        <Text color="#c7c6c6" fontSize={{ base: 'lg', md: '2xl' }} maxW="2xl" lineHeight="1.6">
          {t('hobbies.description')}
        </Text>
      </Box>

      {
        hobbies.length === 0 ? (
          <Box border="1px solid" borderColor="#524533" bg="#1c1b1b" p={{ base: '8', md: '12' }}>
            <Stack gap="4" alignItems="center" textAlign="center" py="12">
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.12em"
                color="#9f8e78"
              >
                status: unavailable
              </Text>
              <Heading as="h2" fontSize={{ base: '3xl', md: '4xl' }} fontStyle="italic">
                {t('hobbies.empty-title')}
              </Heading>
              <Text color="#c7c6c6" maxW="md" lineHeight="1.7">
                {t('hobbies.empty-description')}
              </Text>
            </Stack>
          </Box>
        ) : (
          <>
            <Grid
              gridTemplateColumns={{ base: '1fr', md: 'repeat(12, 1fr)' }}
              gap="0"
              bg="#524533"
              border="1px solid"
              borderColor="#524533"
            >
              {hobbies.map((hobby, index) => {
                const span = index === 0 ? 8 : index === 1 ? 4 : index === 2 ? 5 : 7;

                if (index === 0)
                  return (
                    <Link
                      href={`/${locale}/hobbies/${hobby.id}`}
                      gridColumn={{ base: 'span 1', md: `span ${span}` }}
                      w="full"
                      minW="0"
                      bg="#1c1b1b"
                      display="flex"
                      flexDirection="column"
                      alignItems="stretch"
                      overflow="hidden"
                      className="group card-hover-amber"
                      border="1px solid"
                      borderColor="#524533"
                    >
                      <Box
                        position="relative"
                        w="full"
                        h={{ base: '64', md: '96' }}
                        overflow="hidden"
                        bg="#222221"
                        className="hobby-camera-plate"
                      >
                        <Box
                          position="absolute"
                          inset="0"
                          bgGradient="to-br"
                          gradientFrom="#1c1b1b"
                          gradientVia="#2a2a2a"
                          gradientTo="#1c1b1b"
                        >
                          <Box position="absolute" inset="0" className="fallback-grid-lines" />
                          <Box position="absolute" inset="0" className="hobby-camera-mark" />
                          <Box
                            position="absolute"
                            insetX={{ base: '8', md: '20' }}
                            top={{ base: '10', md: '14' }}
                            h="1px"
                            bg="#e5e2e1"
                            opacity="0.55"
                          />
                          <Box
                            position="absolute"
                            insetX={{ base: '8', md: '20' }}
                            bottom={{ base: '14', md: '18' }}
                            h="1px"
                            bg="#e5e2e1"
                            opacity="0.55"
                          />
                          <Box
                            position="absolute"
                            right="-10"
                            top="-6"
                            opacity="0.24"
                            className="group-hover-watermark-strong"
                          >
                            <Text
                              fontSize={{ base: '180px', md: '240px' }}
                              fontWeight="black"
                              fontFamily="Newsreader, serif"
                              fontStyle="italic"
                              lineHeight="1"
                              color="#e5e2e1"
                              aria-hidden="true"
                            >
                              {hobby.title?.charAt(0).toUpperCase()}
                            </Text>
                          </Box>
                          <Box
                            position="absolute"
                            bottom="0"
                            left="0"
                            right="0"
                            h="4px"
                            bg="#ffb000"
                            opacity="0.75"
                          />
                          <Box position="absolute" bottom="12" left="8" opacity="0.95">
                            <Text
                              fontFamily="JetBrains Mono, monospace"
                              fontSize="10px"
                              textTransform="uppercase"
                              letterSpacing="0.2em"
                              color="#ffb000"
                            >
                              {hobby.title}
                            </Text>
                          </Box>
                        </Box>
                        <Box
                          position="absolute"
                          inset={{ base: '12', md: '16' }}
                          border="2px solid"
                          borderColor="#ffb000"
                          zIndex="1"
                          opacity="0.78"
                          className="hobby-camera-panel"
                        />
                        <Box
                          position="absolute"
                          inset="0"
                          display="flex"
                          alignItems="center"
                          justifyContent="center"
                          zIndex="2"
                          pointerEvents="none"
                        >
                          <Box className="hobby-camera-lens" />
                        </Box>
                        <Box
                          position="absolute"
                          top={{ base: '6', md: '8' }}
                          left={{ base: '6', md: '8' }}
                          zIndex="2"
                        >
                          <Text
                            fontFamily="JetBrains Mono, monospace"
                            fontSize={{ base: '8px', md: '10px' }}
                            textTransform="uppercase"
                            letterSpacing={{ base: '0.14em', md: '0.2em' }}
                            color="#ffb000"
                            fontWeight="bold"
                          >
                            Photo
                          </Text>
                        </Box>
                        {hobby.banner && <img src={hobby.banner} alt="" class="hobby-image-hero" />}
                        <Box
                          position="absolute"
                          top="4"
                          right="4"
                          opacity="0.4"
                          className="group-hover-opacity-full"
                          transition="opacity 0.3s ease"
                        >
                          <BrandMark size={40} color="#e5e2e1" accent="#FFB000" />
                        </Box>
                      </Box>
                      <Box p={{ base: '6', md: '8' }} borderTop="1px solid" borderColor="#524533">
                        <Box
                          display="flex"
                          justifyContent="space-between"
                          alignItems="start"
                          mb={{ base: '3', md: '4' }}
                        >
                          <Heading as="h2" fontSize={{ base: '2xl', md: '3xl' }} fontStyle="italic">
                            {hobby.title}
                          </Heading>
                          <span
                            class="material-symbols-outlined"
                            style="color: #ffb000; font-size: 24px;"
                          >
                            photo_camera
                          </span>
                        </Box>
                        <Text
                          color="#c7c6c6"
                          mb={{ base: '4', md: '6' }}
                          maxW="lg"
                          className="line-clamp-2"
                        >
                          {hobby.description}
                        </Text>
                        <Box display="flex" flexWrap="wrap" gap={{ base: '3', md: '4' }} mt="auto">
                          <Box
                            px="6"
                            py="2"
                            bg="#ffb000"
                            color="#432c00"
                            fontWeight="bold"
                            fontSize="sm"
                            border="1px solid"
                            borderColor="#9f8e78"
                            className="blocky-shadow blocky-shadow-hover"
