---
import MainLayout from '~/layouts/MainLayout.astro';
import { Box, Container, Stack } from 'styled-system/jsx';
import { css, cx } from 'styled-system/css';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { useTranslations, validateLocale } from '~/i18n/utils';
import { withLastGood } from '~/utils/cms-cache';
import { outlineClient, outlineServerUrl } from '~/utils/outline-api';
import { orderHobbyCards } from '~/utils/hobby-cards';
import { getOutlineSettings } from '~/utils/outline-settings';
import { parseHobbyContent } from '~/utils/hobby-content';
import { getHobbyRenderedLinks } from '~/utils/hobby-links';
import {
  formatHobbyUpdated,
  getHobbyContentLabel,
  getHobbyCountLabel,
  getHobbyOverviewSummary
} from '~/utils/hobby-labels';
import { getOutlineAssetProxyPath, resolveOutlineAssetUrl } from '~/utils/outline-assets';

export const prerender = false;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const pageTitle = `${t('common.hobbies')} | ${t('common.name')}`;
const monoMetaText = css({
  fontFamily: 'JetBrains Mono, monospace',
  fontSize: '10px',
  letterSpacing: '0.08em',
  textTransform: 'uppercase'
});
const thaiMetaText = css({
  fontFamily: 'var(--font-body)',
  fontSize: 'xs',
  letterSpacing: '0',
  textTransform: 'none'
});
const metaTextClass = locale === 'th' ? thaiMetaText : monoMetaText;
const unavailableMetaTextClass =
  locale === 'th'
    ? thaiMetaText
    : cx(
        monoMetaText,
        css({
          letterSpacing: '0.12em'
        })
      );
const hobbyThumbnail = css({
  display: 'block',
  w: 'full',
  h: 'full',
  objectFit: 'cover',
  filter: 'saturate(0.68) sepia(0.16) brightness(0.82) contrast(1.05)'
});
const hobbyRow = css({
  pos: 'relative',
  textDecorationLine: 'none',
  transition: 'background-color 160ms ease, border-color 160ms ease',
  _hover: {
    bg: 'rgba(255, 176, 0, 0.035)',
    borderColor: '#765c2f'
  }
});
const hobbyCardTitle = css({
  _groupHover: {
    textDecorationLine: 'underline',
    textDecorationColor: '#ffb000',
    textDecorationThickness: '1px',
    textUnderlineOffset: '0.18em'
  }
});
const hobbyVisual = css({
  pos: 'relative',
  display: 'grid',
  placeItems: 'center',
  w: { base: '7.5rem', md: '9rem' },
  maxW: 'full',
  aspectRatio: '4 / 3',
  border: '1px solid #524533',
  bg: '#131313',
  overflow: 'hidden',
  '&::before': {
    pos: 'absolute',
    inset: '0',
    content: '""',
    opacity: '0.85'
  },
  '&[data-embed="photo-gallery"]::before': {
    bg: 'radial-gradient(circle at 30% 20%, rgba(245, 158, 11, 0.24), transparent 34%), linear-gradient(135deg, rgba(255, 176, 0, 0.13), transparent 58%)'
  },
  '&[data-embed="typing-stats"]::before': {
    bg: 'linear-gradient(135deg, rgba(20, 184, 166, 0.2), transparent 46%), linear-gradient(315deg, rgba(99, 102, 241, 0.14), transparent 52%)'
  },
  '&[data-embed="piano-chords"]::before': {
    bg: 'linear-gradient(135deg, rgba(250, 250, 240, 0.14), transparent 42%), linear-gradient(315deg, rgba(168, 85, 247, 0.18), transparent 58%)'
  },
  '&[data-embed="darts-board"]::before': {
    bg: 'radial-gradient(circle at 72% 18%, rgba(132, 204, 22, 0.18), transparent 34%), linear-gradient(135deg, rgba(220, 38, 38, 0.14), transparent 52%)'
  },
  '&[data-embed="rubik-algorithms"]::before': {
    bg: 'linear-gradient(135deg, rgba(239, 68, 68, 0.18), transparent 38%), linear-gradient(225deg, rgba(34, 197, 94, 0.14), transparent 46%), linear-gradient(315deg, rgba(59, 130, 246, 0.14), transparent 54%)'
  },
  '&[data-embed="link-library"]::before': {
    bg: 'linear-gradient(135deg, rgba(56, 189, 248, 0.16), transparent 44%), linear-gradient(315deg, rgba(250, 204, 21, 0.12), transparent 54%)'
  },
  '&[data-embed="field-notes"]::before': {
    bg: 'linear-gradient(135deg, rgba(255, 176, 0, 0.16), transparent 44%), linear-gradient(315deg, rgba(255, 213, 151, 0.09), transparent 54%)'
  },
  '&[data-visual="image"][data-embed]::before': {
    bg: 'linear-gradient(160deg, rgba(255, 176, 0, 0.14), transparent 55%), linear-gradient(180deg, rgba(17, 16, 14, 0.58), rgba(17, 16, 14, 0.78))',
    opacity: '1',
    zIndex: '1'
  },
  '&[data-visual="glyph"]': {
    boxShadow: 'inset 0 0 0 1px rgba(255, 176, 0, 0.08)'
  },
  '&[data-visual="glyph"]::after': {
    pos: 'absolute',
    inset: '0',
    content: '""',
    opacity: '0.9',
    mixBlendMode: 'screen'
  },
  '&[data-embed="photo-gallery"][data-visual="glyph"]::after': {
    bg: 'linear-gradient(90deg, transparent 0 16%, rgba(255, 176, 0, 0.28) 16% 18%, transparent 18% 48%, rgba(255, 176, 0, 0.2) 48% 50%, transparent 50% 80%, rgba(255, 176, 0, 0.2) 80% 82%, transparent 82%), radial-gradient(circle at 48% 50%, transparent 0 13%, rgba(245, 158, 11, 0.34) 14% 15%, transparent 16% 24%, rgba(255, 176, 0, 0.18) 25% 26%, transparent 27%)'
  },
  '&[data-embed="typing-stats"][data-visual="glyph"]::after': {
    bg: 'linear-gradient(90deg, transparent 0 58%, rgba(20, 184, 166, 0.34) 58% 63%, transparent 63% 70%, rgba(99, 102, 241, 0.28) 70% 75%, transparent 75% 82%, rgba(45, 212, 191, 0.24) 82% 87%, transparent 87%), linear-gradient(0deg, rgba(45, 212, 191, 0.2) 0 1px, transparent 1px 25%)'
  },
  '&[data-embed="piano-chords"][data-visual="glyph"]::after': {
    bg: 'linear-gradient(90deg, rgba(250, 250, 240, 0.16) 0 9%, transparent 9% 11%, rgba(250, 250, 240, 0.16) 11% 20%, transparent 20% 22%, rgba(250, 250, 240, 0.16) 22% 31%, transparent 31% 33%, rgba(250, 250, 240, 0.16) 33% 42%, transparent 42% 44%, rgba(250, 250, 240, 0.16) 44% 53%, transparent 53% 55%, rgba(250, 250, 240, 0.16) 55% 64%, transparent 64% 100%), linear-gradient(90deg, transparent 0 17%, rgba(196, 181, 253, 0.42) 17% 23%, transparent 23% 31%, rgba(196, 181, 253, 0.42) 31% 37%, transparent 37% 49%, rgba(196, 181, 253, 0.42) 49% 55%, transparent 55%)',
    backgroundSize: '100% 58%, 100% 34%',
    backgroundPosition: '0 100%, 0 0',
    backgroundRepeat: 'no-repeat'
  },
  '&[data-embed="darts-board"][data-visual="glyph"]::after': {
    bg: 'radial-gradient(circle at 62% 44%, rgba(132, 204, 22, 0.36) 0 4%, transparent 5% 16%, rgba(132, 204, 22, 0.24) 17% 19%, transparent 20% 31%, rgba(220, 38, 38, 0.24) 32% 34%, transparent 35%), linear-gradient(35deg, transparent 0 48%, rgba(255, 176, 0, 0.2) 48% 50%, transparent 50%)'
  },
  '&[data-embed="rubik-algorithms"][data-visual="glyph"]::after': {
    bg: 'linear-gradient(90deg, rgba(239, 68, 68, 0.32) 0 32%, rgba(34, 197, 94, 0.28) 32% 34%, rgba(59, 130, 246, 0.3) 34% 66%, rgba(250, 204, 21, 0.24) 66% 68%, rgba(245, 158, 11, 0.3) 68%), linear-gradient(0deg, transparent 0 31%, rgba(19, 19, 19, 0.78) 31% 34%, transparent 34% 64%, rgba(19, 19, 19, 0.78) 64% 67%, transparent 67%), linear-gradient(90deg, transparent 0 31%, rgba(19, 19, 19, 0.78) 31% 34%, transparent 34% 64%, rgba(19, 19, 19, 0.78) 64% 67%, transparent 67%)',
    transform: 'scale(0.58) rotate(-8deg)'
  },
  '&[data-embed="link-library"][data-visual="glyph"]::after': {
    bg: 'radial-gradient(circle at 22% 32%, rgba(56, 189, 248, 0.42) 0 5%, transparent 6%), radial-gradient(circle at 70% 24%, rgba(250, 204, 21, 0.34) 0 5%, transparent 6%), radial-gradient(circle at 78% 70%, rgba(45, 212, 191, 0.34) 0 5%, transparent 6%), radial-gradient(circle at 28% 72%, rgba(255, 176, 0, 0.32) 0 5%, transparent 6%), linear-gradient(28deg, transparent 0 48%, rgba(56, 189, 248, 0.24) 48% 50%, transparent 50%), linear-gradient(118deg, transparent 0 48%, rgba(255, 176, 0, 0.2) 48% 50%, transparent 50%)'
  },
  '&[data-embed="field-notes"][data-visual="glyph"]::after': {
    bg: 'linear-gradient(135deg, transparent 0 24%, rgba(255, 176, 0, 0.18) 24% 26%, transparent 26%), linear-gradient(90deg, transparent 0 20%, rgba(255, 176, 0, 0.18) 20% 68%, transparent 68%), linear-gradient(0deg, transparent 0 22%, rgba(255, 213, 151, 0.18) 22% 24%, transparent 24% 36%, rgba(255, 176, 0, 0.14) 36% 38%, transparent 38%)'
  }
});
const hobbyCardBody = css({
  display: 'grid',
  gap: '4',
  alignContent: 'center',
  minW: '0'
});
const hobbyCardMeta = css({
  display: 'flex',
  flexWrap: 'wrap',
  gap: '2',
  color: '#9f8e78'
});
const hobbyCardPill = css({
  display: 'inline-flex',
  alignItems: 'center',
  border: '1px solid #524533',
  minH: '2rem',
  px: '3',
  bg: 'rgba(19, 19, 19, 0.72)',
  color: '#c7c6c6',
  whiteSpace: { base: 'normal', md: 'nowrap' },
  overflowWrap: 'anywhere',
  '&[data-status="active"]': {
    borderColor: 'rgba(45, 212, 191, 0.38)',
    color: '#2dd4bf'
  },
  '&[data-status="inactive"]': {
    color: '#9f8e78'
  }
});

let hobbiesList: any[] | undefined = undefined;

try {
  hobbiesList = await withLastGood('hobbies:list', async () => {
    const settings = await getOutlineSettings();
    if (!settings?.['hobbies-collection']) {
      throw new Error('hobbies collection not configured');
    }

    const allDocuments: any[] = [];
    const pageLimit = 100;
    let offset = 0;

    while (true) {
      const res = await outlineClient.POST('/documents.list', {
        body: { collectionId: settings['hobbies-collection'], offset, limit: pageLimit }
      });
      if (!res.response.ok) throw new Error(`documents.list ${res.response.status}`);
      const rows = res.data?.data ?? [];
      allDocuments.push(...rows);
      if (rows.length < (res.data?.pagination?.limit ?? pageLimit)) break;
      offset += rows.length;
    }

    const childrenByParent = new Map<string, { id: string; title: string }[]>();

    allDocuments.forEach((document: any) => {
      if (!document.parentDocumentId) return;
      const children = childrenByParent.get(document.parentDocumentId) ?? [];
      children.push({
        id: document.id,
        title: document.title ?? 'Untitled'
      });
      childrenByParent.set(document.parentDocumentId, children);
    });

    const rootDocuments = allDocuments.filter((d: any) => !d.parentDocumentId);
    return rootDocuments.map((document: any) => ({
      ...document,
      childPages: childrenByParent.get(document.id) ?? []
    }));
  });
} catch {}

const outlineAssetPrefix = outlineServerUrl.replace('/api', '');
const outlineAssetProxyPath = getOutlineAssetProxyPath(locale);
const resolveHobbyAssetUrl = (rawUrl?: string) =>
  resolveOutlineAssetUrl(rawUrl, {
    assetsPrefix: outlineAssetPrefix,
    assetProxyBasePath: outlineAssetProxyPath
  });

const getEmbedType = (hobby: { embeds: { type: string }[] }) =>
  hobby.embeds[0]?.type ?? 'field-notes';
const getHobbyLabel = (hobby: {
  embeds: { type: string }[];
  body?: string;
  images?: string[];
  links?: { href: string; label: string }[];
  childPages?: { id: string; title: string }[];
}) =>
  getHobbyContentLabel({
    hasSource: hasSourceContent(hobby),
    type: getEmbedType(hobby),
    t
  });
const getStatusLabel = (status: 'active' | 'inactive') =>
  status === 'inactive' ? t('hobbies.status-inactive') : t('hobbies.status-active');
const hasExplicitStatus = (meta: Record<string, unknown>) =>
  typeof meta.status === 'string' || typeof meta.active === 'boolean';
const hasSourceContent = (hobby: {
  body?: string;
  images?: string[];
  links?: { href: string; label: string }[];
  childPages?: { id: string; title: string }[];
}) =>
  !!hobby.body?.trim() ||
  !!hobby.images?.length ||
  !!hobby.links?.length ||
  !!hobby.childPages?.length;
const getEffectiveStatus = (hobby: {
  status: 'active' | 'inactive';
  meta: Record<string, unknown>;
  body?: string;
  images?: string[];
  links?: { href: string; label: string }[];
  childPages?: { id: string; title: string }[];
}) => {
  if (hasExplicitStatus(hobby.meta)) return hobby.status;
  return hasSourceContent(hobby) ? hobby.status : 'inactive';
};

const formatUpdated = (date?: string | null) =>
  formatHobbyUpdated({ date, locale, noDateLabel: String(t('hobbies.no-date')) });
const formatNestedDescription = (childPages?: { title: string }[]) => {
  const titles = (childPages ?? [])
    .map((child) => child.title)
    .filter(Boolean)
    .slice(0, 3);
  if (titles.length === 0) return '';
  if (titles.length === 1) return titles[0];
  if (titles.length === 2) return `${titles[0]} / ${titles[1]}`;
  return `${titles.slice(0, -1).join(' / ')} / ${titles.at(-1)}`;
};

const hobbies = hobbiesList
  ? orderHobbyCards(
      hobbiesList.map((h) => {
        const content = parseHobbyContent({
          title: h.title,
          text: h.text,
          fallbackUpdatedAt: h.updatedAt ?? h.createdAt
        });
        const childPages = h.childPages ?? [];
        const nestedSummary = formatNestedDescription(childPages);
        const resolvedImages = content.images
          .map(resolveHobbyAssetUrl)
          .filter((image): image is string => !!image);
        return {
          ...h,
          ...content,
          banner: resolveHobbyAssetUrl(content.banner ?? content.images[0]),
          images: resolvedImages,
          description:
            getHobbyOverviewSummary({
              hasSource: hasSourceContent({
                ...content,
                images: resolvedImages,
                childPages
              }),
              value: content.description,
              t
            }) || nestedSummary,
          updatedLabel: formatUpdated(content.updatedAt),
          childPages,
          status: getEffectiveStatus({
            ...content,
            images: resolvedImages,
            childPages
          })
        };
      })
    )
  : [];
---

<MainLayout title={pageTitle} description={t('hobbies.description')}>
  <Container maxW="breakpoint-xl" w="full" py={{ base: '6', md: '10' }} className="page-shell">
    <Stack gap={{ base: '8', md: '10' }}>
      <Stack gap="4" maxW="4xl">
        <Heading as="h1" fontSize={{ base: '5xl', md: '8xl' }} fontStyle="italic" lineHeight="0.92">
          {t('hobbies.page-heading')}
        </Heading>
        <Text color="#c7c6c6" fontSize={{ base: 'lg', md: 'xl' }} lineHeight="1.7" maxW="3xl">
          {t('hobbies.description')}
        </Text>
      </Stack>

      {
        hobbies.length === 0 ? (
          <Box border="1px solid" borderColor="#524533" bg="#171615" p={{ base: '6', md: '8' }}>
            <Stack gap="4" py="8">
              <Text className={unavailableMetaTextClass} color="#9f8e78">
                {t('hobbies.status-unavailable')}
              </Text>
              <Heading as="h2" fontSize={{ base: '2xl', md: '3xl' }}>
                {t('hobbies.empty-title')}
              </Heading>
              <Text color="#c7c6c6" maxW="md" lineHeight="1.7">
                {t('hobbies.empty-description')}
              </Text>
            </Stack>
          </Box>
        ) : (
          <>
            <Stack gap="0" borderTop="1px solid" borderColor="#524533">
              {hobbies.map((hobby) => {
                const embedType = getEmbedType(hobby);
                const hasModule = hobby.embeds.length > 0;
                const hobbySourced = hasSourceContent(hobby);
                const readableEmbedType =
                  hasModule && hobbySourced ? getHobbyLabel(hobby) : undefined;
                const linkCount = getHobbyRenderedLinks({
                  type: embedType,
                  links: hobby.links ?? [],
                  body: hobby.body,
                  images: hobby.images
                }).length;
                const metaItems = [
                  {
                    label: getStatusLabel(hobby.status),
                    status: hobby.status
                  },
                  {
                    label: `${t('hobbies.metric-updated')} ${hobby.updatedLabel}`
                  },
                  ...(linkCount
                    ? [
                        {
                          label: getHobbyCountLabel({
                            count: linkCount,
                            locale,
                            type: 'link',
                            t
                          })
                        }
                      ]
                    : []),
                  ...(hobby.childPages?.length
                    ? [
                        {
                          label: getHobbyCountLabel({
                            count: hobby.childPages.length,
                            locale,
                            type: 'page',
                            t
                          })
                        }
                      ]
                    : [])
                ];

                return (
                  <Link
                    href={`/${locale}/hobbies/${hobby.id}`}
                    display="grid"
                    gridTemplateColumns={{
                      base: '1fr',
                      md: 'minmax(9rem, 10rem) minmax(0, 1fr)'
                    }}
                    gap={{ base: '4', md: '7' }}
                    alignItems={{ md: 'center' }}
                    py={{ base: '5', md: '6' }}
                    borderBottom="1px solid"
                    borderColor="#524533"
                    className={cx('group', hobbyRow)}
                  >
                    <Box
                      className={hobbyVisual}
                      data-embed={embedType}
                      data-visual={hobby.banner ? 'image' : 'glyph'}
                    >
                      <Box
                        fontFamily="Newsreader, serif"
                        fontStyle="italic"
                        fontSize="64px"
                        lineHeight="1"
                        color="#ffb000"
                        opacity="0.3"
                        userSelect="none"
                        aria-hidden="true"
                        gridArea="1 / 1"
                      >
                        {(hobby.title ?? '?').charAt(0).toUpperCase()}
                      </Box>
                      {hobby.banner && (
                        <img
                          src={hobby.banner}
                          alt=""
                          class={hobbyThumbnail}
                          loading="lazy"
                          style="grid-area: 1 / 1; position: relative; z-index: 1"
                          onerror="this.closest('[data-visual]')?.setAttribute('data-visual', 'glyph'); this.remove()"
                        />
                      )}
                    </Box>
                    <div class={hobbyCardBody}>
                      {readableEmbedType && (
                        <Text className={metaTextClass} color="#9f8e78">
                          {readableEmbedType}
                        </Text>
                      )}
                      <Heading
                        as="h2"
                        className={hobbyCardTitle}
                        fontSize={{ base: '2xl', md: '3xl' }}
                        lineHeight="1.15"
                      >
                        {hobby.title}
                      </Heading>
                      <Text color="#c7c6c6" lineHeight="1.7" overflowWrap="anywhere">
                        {hobby.description}
                      </Text>
                      <div class={cx(hobbyCardMeta, metaTextClass)}>
                        {metaItems.map((item) => (
                          <span class={hobbyCardPill} data-status={item.status}>
                            {item.label}
                          </span>
                        ))}
                      </div>
                    </div>
                  </Link>
                );
              })}
            </Stack>
          </>
        )
      }
    </Stack>
  </Container>
</MainLayout>
