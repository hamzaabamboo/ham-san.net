---
import { HobbyInteractiveEmbed } from '~/components/hobbies/HobbyInteractiveEmbed';
import { HobbyTypeGlyph } from '~/components/hobbies/HobbyTypeGlyph';
import { hobbyStyles } from '~/components/hobbies/hobbyStyles';
import { Markdown } from '~/components/lib/Markdown';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import { getHobbyBodyIntro, parseHobbyContent, splitHobbyBodyParts } from '~/utils/hobby-content';
import {
  getHobbyContentLabel,
  getHobbyOverviewDescription,
  getHobbyOverviewSummary
} from '~/utils/hobby-labels';
import { withLastGood } from '~/utils/cms-cache';
import { outlineClient, outlineServerUrl } from '~/utils/outline-api';
import { getOutlineAssetProxyPath, resolveOutlineAssetUrl } from '~/utils/outline-assets';
import { getOutlineSettings } from '~/utils/outline-settings';
import { cx } from 'styled-system/css';

export const prerender = false;

const { locale, slug } = Astro.params;
const slugParts = slug?.split('/') ?? [];
const [rootId, maybeDocSegment, childId] = slugParts;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

if (!rootId || (maybeDocSegment && maybeDocSegment !== 'doc')) {
  return Astro.redirect(`/${locale}/404`);
}

const t = useTranslations(locale);

let cmsUnavailable = false;
let settings: Awaited<ReturnType<typeof getOutlineSettings>>;
try {
  settings = await getOutlineSettings();
} catch {
  cmsUnavailable = true;
}

const documentId = childId ?? rootId;
const fetchHobbyDocument = (collectionId: string, id: string) =>
  outlineClient.POST('/documents.info', { body: { collectionId, id } });
let data: NonNullable<Awaited<ReturnType<typeof fetchHobbyDocument>>['data']>['data'] | undefined;

if (!cmsUnavailable) {
  if (!settings?.['hobbies-collection']) {
    return Astro.redirect(`/${locale}/404`);
  }
  try {
    const documentRequest = await withLastGood(`hobby:${documentId}`, async () => {
      const request = await fetchHobbyDocument(settings!['hobbies-collection'], documentId);
      if (request.response.status >= 500) {
        throw new Error(`documents.info ${request.response.status}`);
      }
      return request;
    });
    if (documentRequest.response.status >= 500) {
      cmsUnavailable = true;
    } else {
      data = documentRequest.data?.data;
    }
  } catch {
    cmsUnavailable = true;
  }
}

if (!cmsUnavailable && !data) {
  return Astro.redirect(`/${locale}/404`);
}

if (cmsUnavailable) {
  Astro.response.status = 503;
}

const childDocumentsParentId = childId && data?.parentDocumentId ? data.parentDocumentId : data?.id;
const childDocumentsRequest = data
  ? await withLastGood(`hobby-children:${childDocumentsParentId}`, () =>
      outlineClient.POST('/documents.list', {
        body: { parentDocumentId: childDocumentsParentId }
      })
    ).catch(() => null)
  : null;
const childDocuments = (childDocumentsRequest?.data?.data ?? [])
  .filter(Boolean)
  .filter((child) => child.id !== data?.id);
const backHref = childId ? `/${locale}/hobbies/${rootId}` : `/${locale}/hobbies`;
const backLabel = childId ? t('hobbies.back-to-parent') : t('hobbies.back-to-hobbies');
const content = parseHobbyContent({
  title: data?.title ?? '',
  text: data?.text ?? '',
  fallbackUpdatedAt: data?.updatedAt ?? data?.createdAt
});
const nestedPages = childDocuments.map((child) => ({
  title: child.title ?? 'Untitled',
  href: `/${locale}/hobbies/${rootId}/doc/${child.id}`
}));
const hasExplicitStatus =
  typeof content.meta.status === 'string' || typeof content.meta.active === 'boolean';
const hasSourceContent =
  !!content.body.trim() ||
  content.images.length > 0 ||
  content.links.length > 0 ||
  nestedPages.length > 0;
const effectiveStatus = hasExplicitStatus || hasSourceContent ? content.status : 'inactive';
const nestedDescription = nestedPages
  .map((child) => child.title)
  .filter(Boolean)
  .slice(0, 3)
  .join(' / ');
const pageTitle = `${data?.title ?? t('common.hobbies')} | ${t('common.name')}`;
const outlineAssetPrefix = outlineServerUrl.replace('/api', '');
const outlineAssetProxyPath = getOutlineAssetProxyPath(locale);
const resolveHobbyAssetUrl = (rawUrl?: string) =>
  resolveOutlineAssetUrl(rawUrl, {
    assetsPrefix: outlineAssetPrefix,
    assetProxyBasePath: outlineAssetProxyPath
  });
const embedType = content.embeds[0]?.type ?? 'field-notes';
const hasModule = content.embeds.length > 0;
const detailDescription =
  getHobbyOverviewSummary({
    hasSource: hasSourceContent,
    value: content.description,
    t
  }) || nestedDescription;
const heroDescription =
  detailDescription === getHobbyBodyIntro(content.body) ? '' : detailDescription;
const embedLabel = getHobbyContentLabel({ hasSource: hasSourceContent, type: embedType, t });
const statusLabel =
  effectiveStatus === 'inactive' ? t('hobbies.status-inactive') : t('hobbies.status-active');
const banner = resolveHobbyAssetUrl(content.banner);
const images = content.images.map(resolveHobbyAssetUrl).filter((image): image is string => !!image);
const updatedDate = content.updatedAt ? new Date(content.updatedAt) : null;
const updatedLabel =
  updatedDate && !Number.isNaN(updatedDate.getTime())
    ? new Intl.DateTimeFormat(locale, { year: 'numeric', month: 'short', day: 'numeric' }).format(
        updatedDate
      )
    : t('hobbies.no-date');
const bodyParts = splitHobbyBodyParts(content.body, content.embeds.length);
const embedProps = {
  title: data?.title,
  description: detailDescription,
  body: content.sourceBody,
  images,
  links: content.links,
  nestedPages,
  emptySourceLabel: t('hobbies.empty-source-description'),
  emptySourceStateLabel: t('hobbies.empty-source-state'),
  nestedSourcePagesLabel: t('hobbies.nested-source-pages'),
  sourceNoteAttachedLabel: t('hobbies.source-note-attached'),
  linkedPhotoSourcesLabel: t('hobbies.linked-photo-sources'),
  noImagesLabel: t('hobbies.no-images'),
  noLinksLabel: t('hobbies.no-links'),
  sourceNoteLabel: t('hobbies.source-note'),
  noFeedLabel: t('hobbies.no-feed'),
  noTypingProfilesLabel: t('hobbies.no-typing-profiles'),
  sourceNoteUseLabel: t('hobbies.source-note-use'),
  openSourcePageLabel: t('hobbies.open-source-page'),
  noAlgorithmSetsLabel: t('hobbies.no-algorithm-sets'),
  audioUnavailableLabel: t('hobbies.audio-unavailable'),
  playedLabel: t('hobbies.played'),
  audioStartsAfterTapLabel: t('hobbies.audio-starts-after-tap'),
  noChordsLabel: t('hobbies.no-chords'),
  status: effectiveStatus
};

if (!cmsUnavailable) {
  Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=86400, must-revalidate');
}
---

<MainLayout title={pageTitle} description={detailDescription || data?.title}>
  <div class={cx(hobbyStyles.detail, 'page-shell', 'hobby-detail')}>
    <a class={cx(hobbyStyles.detailBack, 'hobby-meta')} href={backHref}>
      <span aria-hidden="true">←</span>
      <span>{backLabel}</span>
    </a>

    {
      cmsUnavailable && (
        <section class={hobbyStyles.detailBody}>
          <div class={hobbyStyles.detailMain}>
            <div class={hobbyStyles.detailPanel}>
              <p class={cx(hobbyStyles.detailPanelTitle, 'hobby-meta')}>
                {t('hobbies.status-unavailable')}
              </p>
              <h1 class={hobbyStyles.detailTitle}>{t('hobbies.empty-title')}</h1>
              <p class={hobbyStyles.detailDescription}>{t('hobbies.empty-description')}</p>
            </div>
          </div>
        </section>
      )
    }

    {
      !cmsUnavailable && (
        <section class={hobbyStyles.detailHero} data-visual={banner ? 'image' : 'glyph'}>
          <div class={hobbyStyles.detailHeadline}>
            <p class={cx(hobbyStyles.detailEyebrow, 'hobby-meta')} data-status={effectiveStatus}>
              {statusLabel}
              {hasModule && ` / ${embedLabel}`}
            </p>
            <h1 class={hobbyStyles.detailTitle}>{data?.title}</h1>
            {heroDescription && <p class={hobbyStyles.detailDescription}>{heroDescription}</p>}
            <p class={cx(hobbyStyles.detailUpdated, 'hobby-meta')}>
              <span>{t('hobbies.last-updated')}</span>
              <span>/</span>
              <span>{updatedLabel}</span>
            </p>
          </div>

          <div
            class={hobbyStyles.detailVisual}
            data-embed={embedType}
            data-visual={banner ? 'image' : 'glyph'}
          >
            {banner ? (
              <img
                src={banner}
                alt=""
                class={hobbyStyles.detailBanner}
                onerror="this.closest('[data-visual]')?.setAttribute('data-visual', 'glyph'); this.remove()"
              />
            ) : (
              <HobbyTypeGlyph
                type={embedType}
                label={embedLabel}
                size="watermark"
                className={hobbyStyles.detailVisualGlyph}
              />
            )}
          </div>
        </section>
      )
    }

    {
      !cmsUnavailable && (
        <section
          class={hobbyStyles.detailBody}
          data-has-aside={childDocuments.length > 0 && bodyParts.length > 0}
        >
          <div class={hobbyStyles.detailMain}>
            {bodyParts.length === 0 && childDocuments.length > 0 && (
              <div class={hobbyStyles.detailPanel}>
                <p class={cx(hobbyStyles.detailPanelTitle, 'hobby-meta')}>
                  {t('hobbies.learning-resources')}
                </p>
                <div class={hobbyStyles.detailNested}>
                  {childDocuments.map((child) => (
                    <a href={`/${locale}/hobbies/${rootId}/doc/${child.id}`}>
                      <span>{child.title}</span>
                      <span class="hobby-meta">{t('hobbies.doc-label')}</span>
                    </a>
                  ))}
                </div>
              </div>
            )}
            {bodyParts.map((part) => {
              if (part.type === 'markdown') {
                return (
                  <div class={hobbyStyles.detailSurface}>
                    <Markdown
                      content={part.content}
                      assetsPrefix={outlineAssetPrefix}
                      assetProxyBasePath={outlineAssetProxyPath}
                      openLinkLabel={t('hobbies.open-link')}
                      headingLevelOffset={1}
                    />
                  </div>
                );
              }

              const embed = content.embeds[part.index];
              if (!embed) return null;

              return (
                <HobbyInteractiveEmbed
                  client:load
                  {...embedProps}
                  type={embed.type}
                  moduleTitle={
                    embed.label === embed.type
                      ? getHobbyContentLabel({ hasSource: hasSourceContent, type: embed.type, t })
                      : embed.label
                  }
                  moduleDescription={
                    hasSourceContent
                      ? getHobbyOverviewDescription(t, embed.type)
                      : detailDescription
                  }
                />
              );
            })}
          </div>

          {childDocuments.length > 0 && bodyParts.length > 0 && (
            <aside class={hobbyStyles.detailAside}>
              <div class={hobbyStyles.detailPanel}>
                <p class={cx(hobbyStyles.detailPanelTitle, 'hobby-meta')}>
                  {t('hobbies.learning-resources')}
                </p>
                <div class={hobbyStyles.detailNested}>
                  {childDocuments.map((child) => (
                    <a href={`/${locale}/hobbies/${rootId}/doc/${child.id}`}>
                      <span>{child.title}</span>
                      <span class="hobby-meta">{t('hobbies.doc-label')}</span>
                    </a>
                  ))}
                </div>
              </div>
            </aside>
          )}
        </section>
      )
    }
  </div>
</MainLayout>
