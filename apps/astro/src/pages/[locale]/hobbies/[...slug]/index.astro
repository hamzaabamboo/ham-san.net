---
import { HobbyInteractiveEmbed } from '~/components/hobbies/HobbyInteractiveEmbed';
import { hobbyStyles } from '~/components/hobbies/hobbyStyles';
import { Markdown } from '~/components/lib/Markdown';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import { parseHobbyContent } from '~/utils/hobby-content';
import { outlineClient, outlineServerUrl } from '~/utils/outline-api';
import { getOutlineAssetProxyPath, resolveOutlineAssetUrl } from '~/utils/outline-assets';
import { getOutlineSettings } from '~/utils/outline-settings';
import { cx } from 'styled-system/css';

export const prerender = false;

const { locale, slug } = Astro.params;
const slugParts = slug?.split('/') ?? [];
const [rootId, maybeDocSegment, childId] = slugParts;

if (!validateLocale(locale) || !rootId || (maybeDocSegment && maybeDocSegment !== 'doc')) {
  return Astro.redirect('/404');
}

const t = useTranslations(locale);
const settings = await getOutlineSettings();

if (!settings?.['hobbies-collection']) {
  return Astro.redirect('/404');
}

const documentId = childId ?? rootId;
const documentRequest = await outlineClient.POST('/documents.info', {
  body: { collectionId: settings['hobbies-collection'], id: documentId }
});
const data = documentRequest.data?.data;

if (!data) {
  return Astro.redirect('/404');
}

const childDocumentsParentId = childId && data.parentDocumentId ? data.parentDocumentId : data.id;
const childDocumentsRequest = await outlineClient.POST('/documents.list', {
  body: { parentDocumentId: childDocumentsParentId }
});
const childDocuments = (childDocumentsRequest.data?.data ?? []).filter(Boolean);
const content = parseHobbyContent({
  title: data.title,
  text: data.text,
  fallbackUpdatedAt: data.updatedAt ?? data.createdAt
});
const pageTitle = `${data.title ?? t('common.hobbies')} | ${t('common.name')}`;
const outlineAssetPrefix = outlineServerUrl.replace('/api', '');
const outlineAssetProxyPath = getOutlineAssetProxyPath(locale);
const resolveHobbyAssetUrl = (rawUrl?: string) =>
  resolveOutlineAssetUrl(rawUrl, {
    assetsPrefix: outlineAssetPrefix,
    assetProxyBasePath: outlineAssetProxyPath
  });
const embedType = content.embeds[0]?.type ?? 'field-notes';
const embedLabel = embedType.replace(/-/g, ' ');
const banner = resolveHobbyAssetUrl(content.banner);
const images = content.images.map(resolveHobbyAssetUrl).filter((image): image is string => !!image);
const updatedLabel = content.updatedAt
  ? new Intl.DateTimeFormat(locale, { year: 'numeric', month: 'short', day: 'numeric' }).format(
      new Date(content.updatedAt)
    )
  : 'No date';

Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=86400, must-revalidate');
---

<MainLayout title={pageTitle} description={content.description || data.title}>
  <div class={cx(hobbyStyles.detail, 'page-shell')}>
    <a class={hobbyStyles.detailBack} href={`/${locale}/hobbies`}>
      <span aria-hidden="true">←</span>
      <span>{t('hobbies.back-to-hobbies')}</span>
    </a>

    <section class={hobbyStyles.detailHero}>
      <div class={hobbyStyles.detailHeadline}>
        <p class={hobbyStyles.detailEyebrow}>{content.status} hobby / {embedLabel}</p>
        <h1 class={hobbyStyles.detailTitle}>{data.title}</h1>
        {content.description && <p class={hobbyStyles.detailDescription}>{content.description}</p>}
        <p class={hobbyStyles.detailUpdated}>
          <span>Last updated</span>
          <span>/</span>
          <span>{updatedLabel}</span>
        </p>
      </div>

      <div class={hobbyStyles.detailVisual}>
        {
          banner ? (
            <img src={banner} alt="" class={hobbyStyles.detailBanner} />
          ) : (
            <div class={cx(hobbyStyles.detailFallback, 'fallback-grid-lines')}>
              <span aria-hidden="true">{data.title?.charAt(0).toUpperCase() ?? 'H'}</span>
            </div>
          )
        }
        <p class={hobbyStyles.detailVisualLabel}>{embedLabel}</p>
      </div>
    </section>

    <section class={hobbyStyles.detailBody}>
      <div class={hobbyStyles.detailMain}>
        {
          content.embeds.map((embed) => (
            <HobbyInteractiveEmbed
              client:load
              type={embed.type}
              title={data.title}
              description={content.description}
              body={content.body}
              images={images}
              links={content.links}
              updatedAt={updatedLabel}
              status={content.status}
            />
          ))
        }

        {
          content.body && (
            <div class={hobbyStyles.detailSurface}>
              <Markdown
                content={content.body}
                assetsPrefix={outlineAssetPrefix}
                assetProxyBasePath={outlineAssetProxyPath}
              />
            </div>
          )
        }
      </div>

      <aside class={hobbyStyles.detailAside}>
        <div class={hobbyStyles.detailPanel}>
          <p class={hobbyStyles.detailPanelTitle}>Related pages</p>
          {
            childDocuments.length > 0 ? (
              <div class={hobbyStyles.detailNested}>
                {childDocuments.map((child) => (
                  <a
                    href={`/${locale}/hobbies/${rootId}/doc/${child.id}`}
                    aria-current={child.id === data.id ? 'page' : undefined}
                  >
                    <span>{child.title}</span>
                    <span>DOC</span>
                  </a>
                ))}
              </div>
            ) : (
              <p class={hobbyStyles.detailMuted}>No related pages yet.</p>
            )
          }
        </div>

        <div class={cx(hobbyStyles.detailPanel, 'note-signal-card')}>
          <p class={cx(hobbyStyles.detailPanelTitle, hobbyStyles.detailPanelTitleCyan)}>Details</p>
          <p class={hobbyStyles.detailMuted}>
            {content.status} / {embedLabel} / {updatedLabel}
          </p>
        </div>
      </aside>
    </section>
  </div>
</MainLayout>
