---
import { parseISO } from 'date-fns';
import { Box, Container, Grid, Stack, Wrap } from 'styled-system/jsx';
import { formatMonthYear } from 'utils/date';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import { outlineClient } from '~/utils/outline-api';

export const prerender = false;

const PAGE_SIZE = 10;

const { locale } = Astro.params;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const rawPage = Astro.url.searchParams.get('page');
const parsedPage = rawPage === null ? 1 : Number(rawPage);
if (rawPage !== null && (!Number.isInteger(parsedPage) || parsedPage < 1)) {
  return Astro.redirect(`/${locale}/notes`);
}
const page = parsedPage;

const headers = {
  Authorization: undefined as unknown as 'Bearer hoge'
};
const t = useTranslations(locale);
const pageTitle = `${t('common.note')} | ${t('common.name')}`;

const fetchSharePage = async (offset: number, pageLimit: number) => {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);
  try {
    return await outlineClient.POST('/shares.list', {
      body: {
        sort: 'createdAt',
        direction: 'DESC',
        limit: pageLimit,
        offset
      },
      headers,
      signal: controller.signal
    });
  } finally {
    clearTimeout(timeout);
  }
};

const fetchAllShares = async () => {
  const shares: any[] = [];
  const pageLimit = 100;
  let offset = 0;
  while (true) {
    const shareRequest = await fetchSharePage(offset, pageLimit);
    if (!shareRequest.response.ok) return undefined;
    const rows = shareRequest.data?.data ?? [];
    shares.push(...rows);
    if (rows.length < (shareRequest.data?.pagination?.limit ?? pageLimit)) break;
    offset += rows.length;
  }
  return shares;
};

let sharedArticlesList: any[] | undefined = undefined;
for (let attempt = 0; attempt < 2 && !sharedArticlesList; attempt++) {
  try {
    sharedArticlesList = await fetchAllShares();
  } catch {
    sharedArticlesList = undefined;
  }
}

const allArticles = (sharedArticlesList ?? []).filter(Boolean);
if (sharedArticlesList && allArticles.length > 0) {
  const lastPage = Math.ceil(allArticles.length / PAGE_SIZE);
  if (page > lastPage) {
    return Astro.redirect(
      lastPage === 1 ? `/${locale}/notes` : `/${locale}/notes?page=${lastPage}`
    );
  }
}
const visibleArticles = allArticles.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);
const hasNextPage = allArticles.length > page * PAGE_SIZE;
const hasPrevPage = page > 1;
const showHero = page === 1;
const collectionCount = new Set(
  allArticles.map((article) => article.collectionName).filter(Boolean)
).size;
const latestNoteDate = allArticles[0]?.createdAt
  ? formatMonthYear(parseISO(allArticles[0].createdAt), locale)
  : '----';

const makeExcerpt = (summary: unknown, max: number) => {
  const cleaned = String(summary ?? '')
    .replace(/https?:\/\/\S+/g, '')
    .replace(/\(image\)/gi, '')
    .replace(/\s+/g, ' ')
    .trim();
  if (!cleaned) return null;
  return cleaned.length > max ? `${cleaned.slice(0, max).trimEnd()}...` : cleaned;
};

Astro.response.headers.set(
  'CDN-Cache-Control',
  sharedArticlesList
    ? 'public, max-age=86400, must-revalidate'
    : 'public, max-age=60, must-revalidate'
);
---

<MainLayout title={pageTitle} description={t('note.description')}>
  <Container maxW="breakpoint-xl" w="full" className="page-shell">
    <Stack py="8" gap="10">
      <Stack gap="4" borderLeftWidth="2px" borderLeftStyle="solid" borderLeftColor="#ffb000" pl="6">
        <Heading as="h1" fontSize={{ base: '5xl', md: '7xl' }} fontStyle="italic">
          {t('note.notes')}
        </Heading>
        <Text color="#c7c6c6" fontSize="lg" maxW="2xl">
          {t('note.description')}
        </Text>
      </Stack>
      {
        !sharedArticlesList || visibleArticles.length === 0 ? (
          <Box border="1px solid" borderColor="#524533" bg="#1c1b1b" p={{ base: '8', md: '12' }}>
            <Stack gap="4" alignItems="center" textAlign="center" py="12">
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.12em"
                color="#9f8e78"
              >
                {t('note.status-unavailable')}
              </Text>
              <Heading as="h2" fontSize={{ base: '3xl', md: '4xl' }} fontStyle="italic">
                {t('note.empty-title')}
              </Heading>
              <Text color="#c7c6c6" maxW="md" lineHeight="1.7">
                {t('note.empty-description')}
              </Text>
            </Stack>
          </Box>
        ) : (
          <>
            <Grid
              gridTemplateColumns={{ base: '1fr', md: 'repeat(3, 1fr)' }}
              gap="1px"
              bg="#524533"
              border="1px solid"
              borderColor="#524533"
            >
              <Stack bg="#131313" p="5" gap="2">
                <Text
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  color="#9f8e78"
                >
                  {t('note.total-notes')}
                </Text>
                <Text fontFamily="JetBrains Mono, monospace" fontSize="3xl" color="#ffb000">
                  {allArticles.length}
                </Text>
              </Stack>
              <Stack className="note-signal-card" p="5" gap="2">
                <Text
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  color="#9f8e78"
                >
                  {t('note.collections')}
                </Text>
                <Text fontFamily="JetBrains Mono, monospace" fontSize="3xl" color="#ffb000">
                  {collectionCount}
                </Text>
              </Stack>
              <Stack bg="#131313" p="5" gap="2">
                <Text
                  fontFamily="JetBrains Mono, monospace"
                  fontSize="10px"
                  textTransform="uppercase"
                  color="#9f8e78"
                >
                  {t('note.latest')}
                </Text>
                <Text fontFamily="JetBrains Mono, monospace" fontSize="lg" color="#ffd597">
                  {latestNoteDate}
                </Text>
              </Stack>
            </Grid>
            <Stack gap="4">
              {showHero &&
                visibleArticles.slice(0, 1).map((data) => {
                  const { id, documentTitle, collectionName, documentSummary, createdAt } =
                    data as typeof data & {
                      collectionName: string;
                      documentSummary: string;
                      documentCreatedAt: string;
                    };
                  const excerpt = makeExcerpt(documentSummary, 220);

                  return (
                    <Link
                      href={`/${locale}/notes/${id}`}
                      display="block"
                      w="full"
                      textDecorationLine="none"
                      className="group"
                    >
                      <Box
                        border="1px solid"
                        borderColor="#524533"
                        p={{ base: '6', md: '10' }}
                        w="full"
                        _hover={{ transform: 'translate(-2px, -2px)' }}
                        transition="transform 0.2s ease"
                        className="card-hover-amber note-feature-card"
                      >
                        <Stack gap={4}>
                          <Text
                            fontFamily="JetBrains Mono, monospace"
                            fontSize="10px"
                            textTransform="uppercase"
                            letterSpacing="0.12em"
                            color="#ffb000"
                          >
                            {t('note.latest-note')}
                          </Text>
                          <Heading
                            as="h2"
                            fontSize={{ base: '4xl', md: '5xl' }}
                            fontStyle="italic"
                            lineHeight="0.95"
                            className="group-hover-underline"
                          >
                            {documentTitle}
                          </Heading>
                          <Wrap
                            fontSize="sm"
                            color="#9f8e78"
                            fontFamily="JetBrains Mono, monospace"
                          >
                            <Text>{collectionName}</Text> |{' '}
                            <Text>
                              {createdAt ? formatMonthYear(parseISO(createdAt), locale) : null}
                            </Text>
                          </Wrap>
                          {excerpt && (
                            <Text color="#c7c6c6" maxW="3xl" fontSize="md" lineHeight="1.7">
                              {excerpt}
                            </Text>
                          )}
                        </Stack>
                      </Box>
                    </Link>
                  );
                })}
              <Grid gap="4" gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)' }}>
                {(showHero ? visibleArticles.slice(1) : visibleArticles).map(
                  (data, index, cards) => {
                    const { id, documentTitle, collectionName, documentSummary, createdAt } =
                      data as typeof data & {
                        collectionName: string;
                        documentSummary: string;
                        documentCreatedAt: string;
                      };
                    const excerpt = makeExcerpt(documentSummary, 100);
                    const spansRow = cards.length % 2 === 1 && index === cards.length - 1;

                    return (
                      <Link
                        href={`/${locale}/notes/${id}`}
                        display="block"
                        w="full"
                        h="full"
                        minW="0"
                        style={spansRow ? { gridColumn: '1 / -1' } : undefined}
                        textDecorationLine="none"
                        className="group"
                      >
                        <Box
                          border="1px solid"
                          borderColor="#524533"
                          p="6"
                          h="full"
                          _hover={{ transform: 'translate(-2px, -2px)' }}
                          transition="transform 0.2s ease"
                          className="card-hover-amber note-signal-card"
                        >
                          <Stack gap={3}>
                            <Heading
                              as="h4"
                              fontSize={{ base: '2xl', md: '3xl' }}
                              fontStyle="italic"
                              overflowWrap="anywhere"
                              className="group-hover-underline"
                            >
                              {documentTitle}
                            </Heading>
                            <Wrap
                              fontSize="sm"
                              color="#9f8e78"
                              fontFamily="JetBrains Mono, monospace"
                            >
                              <Text>{collectionName}</Text> |{' '}
                              <Text>
                                {createdAt ? formatMonthYear(parseISO(createdAt), locale) : null}
                              </Text>
                            </Wrap>
                            {excerpt && (
                              <Text color="#c7c6c6" fontSize="sm">
                                {excerpt}
                              </Text>
                            )}
                          </Stack>
                        </Box>
                      </Link>
                    );
                  }
                )}
              </Grid>
            </Stack>
            {(hasPrevPage || hasNextPage) && (
              <Box
                className={
                  hasPrevPage && hasNextPage
                    ? 'notes-pagination notes-pagination-between'
                    : hasNextPage
                      ? 'notes-pagination notes-pagination-end'
                      : 'notes-pagination notes-pagination-start'
                }
                display="flex"
                alignItems="center"
                pt="4"
                borderTopWidth="1px"
                borderTopStyle="solid"
                borderTopColor="#524533"
              >
                {hasPrevPage && (
                  <a
                    href={page === 2 ? `/${locale}/notes` : `/${locale}/notes?page=${page - 1}`}
                    class="notes-pagination-link card-hover-amber"
                  >
                    ← {t('note.newer-notes')}
                  </a>
                )}
                {hasNextPage && (
                  <a
                    href={`/${locale}/notes?page=${page + 1}`}
                    class="notes-pagination-link card-hover-amber"
                  >
                    {t('note.older-notes')} →
                  </a>
                )}
              </Box>
            )}
          </>
        )
      }
    </Stack>
  </Container>
</MainLayout>
