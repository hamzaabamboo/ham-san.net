---
import { parseISO } from 'date-fns';
import { Box, Center, Container, Grid, Stack, Wrap } from 'styled-system/jsx';
import { formatMonthYear } from 'utils/date';
import { AppPagination } from '~/components/common/AppPagination';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import { outlineClient } from '~/utils/outline-api';

export const prerender = false;

const PAGE_SIZE = 10;

const { locale } = Astro.params;
const page =
  Astro.url.searchParams.get('page') && !isNaN(Number(Astro.url.searchParams.get('page')))
    ? Number(Astro.url.searchParams.get('page'))
    : 1;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const headers = {
  Authorization: undefined as unknown as 'Bearer hoge'
};
const t = useTranslations(locale);
const pageTitle = `${t('common.note')} | ${t('common.name')}`;

const shareRequest = await outlineClient.POST('/shares.list', {
  body: {
    sort: 'createdAt',
    direction: 'DESC',
    limit: PAGE_SIZE,
    offset: (page - 1) * PAGE_SIZE
  },
  headers
});

if (!shareRequest.response.ok) {
  return Astro.redirect('/500');
}

const sharedArticlesList = shareRequest.data?.data;

Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=86400, must-revalidate');
---

<MainLayout title={pageTitle}>
  <Container maxW="breakpoint-xl" w="full">
    <Stack py="8" gap="10">
      <Stack
        gap="4"
        borderLeftWidth="2px"
        borderLeftStyle="solid"
        borderLeftColor="amber.500"
        pl="6"
      >
        <Text
          fontFamily="JetBrains Mono, monospace"
          fontSize="10px"
          textTransform="uppercase"
          letterSpacing="0.12em"
          color="amber.500"
        >
          note_archive
        </Text>
        <Heading as="h1" fontSize={{ base: '5xl', md: '7xl' }} fontStyle="italic">
          {t('note.notes')}
        </Heading>
        <Text color="fg.muted" fontSize="lg" maxW="2xl">
          {t('note.description')}
        </Text>
      </Stack>
      <Grid gap="4">
        {
          sharedArticlesList?.map((data) => {
            if (!data) return null;
            const { id, documentTitle, collectionName, documentSummary, createdAt } =
              data as typeof data & {
                collectionName: string;
                documentSummary: string;
                documentCreatedAt: string;
              };

            return (
              <Link href={`/${locale}/notes/${id}`}>
                <Box
                  border="1px solid"
                  borderColor="border.subtle"
                  bg="bg.default"
                  p="6"
                  _hover={{ transform: 'translate(-2px, -2px)' }}
                  transition="transform 0.2s ease"
                >
                  <Stack gap={3}>
                    <Text
                      fontFamily="JetBrains Mono, monospace"
                      fontSize="10px"
                      textTransform="uppercase"
                      letterSpacing="0.12em"
                      color="amber.500"
                    >
                      shared_note
                    </Text>
                    <Heading as="h4" fontSize="4xl" fontStyle="italic">
                      {documentTitle}
                    </Heading>
                    <Wrap fontSize="sm" color="fg.subtle" fontFamily="JetBrains Mono, monospace">
                      <Text>{collectionName}</Text> |{' '}
                      <Text>{createdAt ? formatMonthYear(parseISO(createdAt), locale) : null}</Text>
                    </Wrap>
                    <Text color="fg.muted">{documentSummary.substring(0, 140) + '...'}</Text>
                  </Stack>
                </Box>
              </Link>
            );
          })
        }
      </Grid>
      <Center>
        {
          shareRequest?.data?.pagination && (
            <AppPagination
              client:visible
              count={shareRequest.data.pagination.limit ?? 1}
              page={`${Math.floor(shareRequest.data.pagination.offset ?? 0 / PAGE_SIZE) + 1}`}
              pageSize={PAGE_SIZE}
            />
          )
        }
      </Center>
    </Stack>
  </Container>
</MainLayout>
