---
import { parseISO } from 'date-fns';
import { Box, Container, Grid, Stack, Wrap } from 'styled-system/jsx';
import { formatMonthYear } from 'utils/date';
import { Heading } from '~/components/ui/heading';
import { Link } from '~/components/ui/link';
import { Text } from '~/components/ui/text';
import { useTranslations, validateLocale } from '~/i18n/utils';
import MainLayout from '~/layouts/MainLayout.astro';
import { outlineClient } from '~/utils/outline-api';

export const prerender = false;

const PAGE_SIZE = 10;

const { locale } = Astro.params;
const page =
  Astro.url.searchParams.get('page') && !isNaN(Number(Astro.url.searchParams.get('page')))
    ? Number(Astro.url.searchParams.get('page'))
    : 1;

if (!validateLocale(locale)) {
  return Astro.redirect('/404');
}

const headers = {
  Authorization: undefined as unknown as 'Bearer hoge'
};
const t = useTranslations(locale);
const pageTitle = `${t('common.note')} | ${t('common.name')}`;

let sharedArticlesList: any[] | undefined = undefined;
try {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 5000);
  const shareRequest = await outlineClient.POST('/shares.list', {
    body: {
      sort: 'createdAt',
      direction: 'DESC',
      limit: PAGE_SIZE,
      offset: (page - 1) * PAGE_SIZE
    },
    headers,
    signal: controller.signal
  });
  clearTimeout(timeout);
  if (shareRequest.response.ok) {
    sharedArticlesList = shareRequest.data?.data;
  }
} catch {
  // CMS unavailable or timeout — render fallback
}

const hasNextPage = (sharedArticlesList?.length ?? 0) >= PAGE_SIZE;
const hasPrevPage = page > 1;

Astro.response.headers.set('CDN-Cache-Control', 'public, max-age=86400, must-revalidate');
---

<MainLayout title={pageTitle} description={t('note.description')}>
  <Container maxW="breakpoint-xl" w="full" className="page-shell">
    <Stack py="8" gap="10">
      <Stack gap="4" borderLeftWidth="2px" borderLeftStyle="solid" borderLeftColor="#ffb000" pl="6">
        <Text
          fontFamily="JetBrains Mono, monospace"
          fontSize="10px"
          textTransform="uppercase"
          letterSpacing="0.12em"
          color="#ffd597"
        >
          {t('note.note-label')}
        </Text>
        <Heading as="h1" fontSize={{ base: '5xl', md: '7xl' }} fontStyle="italic">
          {t('note.notes')}
        </Heading>
        <Text color="#c7c6c6" fontSize="lg" maxW="2xl">
          {t('note.description')}
        </Text>
      </Stack>
      {
        !sharedArticlesList || sharedArticlesList.length === 0 ? (
          <Box border="1px solid" borderColor="#524533" bg="#1c1b1b" p={{ base: '8', md: '12' }}>
            <Stack gap="4" alignItems="center" textAlign="center" py="12">
              <Text
                fontFamily="JetBrains Mono, monospace"
                fontSize="10px"
                textTransform="uppercase"
                letterSpacing="0.12em"
                color="#9f8e78"
              >
                status: unavailable
              </Text>
              <Heading as="h2" fontSize={{ base: '3xl', md: '4xl' }} fontStyle="italic">
                {t('note.empty-title')}
              </Heading>
              <Text color="#c7c6c6" maxW="md" lineHeight="1.7">
                {t('note.empty-description')}
              </Text>
            </Stack>
          </Box>
        ) : (
          <>
            <Stack gap="4">
              {sharedArticlesList?.map((data, index) => {
                if (!data) return null;
                const { id, documentTitle, collectionName, documentSummary, createdAt } =
                  data as typeof data & {
                    collectionName: string;
                    documentSummary: string;
                    documentCreatedAt: string;
                  };

                const isHero = index === 0;

                if (isHero) {
                  return (
                    <Link href={`/${locale}/notes/${id}`}>
                      <Box
                        border="1px solid"
                        borderColor="#524533"
                        bg="#1c1b1b"
                        p={{ base: '6', md: '10' }}
                        _hover={{ transform: 'translate(-2px, -2px)' }}
                        transition="transform 0.2s ease"
                        className="card-hover-amber"
                      >
                        <Stack gap={4}>
                          <Text
                            fontFamily="JetBrains Mono, monospace"
                            fontSize="10px"
                            textTransform="uppercase"
                            letterSpacing="0.12em"
                            color="#ffd597"
                          >
                            Latest note
                          </Text>
                          <Heading as="h2" fontSize={{ base: '4xl', md: '5xl' }} fontStyle="italic">
                            {documentTitle}
                          </Heading>
                          <Wrap
                            fontSize="sm"
                            color="#9f8e78"
                            fontFamily="JetBrains Mono, monospace"
                          >
                            <Text>{collectionName}</Text> |{' '}
                            <Text>
                              {createdAt ? formatMonthYear(parseISO(createdAt), locale) : null}
                            </Text>
                          </Wrap>
                          <Text color="#c7c6c6" maxW="3xl" fontSize="md" lineHeight="1.7">
                            {documentSummary.substring(0, 220) + '...'}
                          </Text>
                        </Stack>
                      </Box>
                    </Link>
                  );
                }
                return null;
              })}
              <Grid gap="4" gridTemplateColumns={{ base: '1fr', md: 'repeat(2, 1fr)' }}>
                {sharedArticlesList?.slice(1).map((data) => {
                  if (!data) return null;
                  const { id, documentTitle, collectionName, documentSummary, createdAt } =
                    data as typeof data & {
                      collectionName: string;
                      documentSummary: string;
                      documentCreatedAt: string;
                    };

                  return (
                    <Link href={`/${locale}/notes/${id}`} style={{ minWidth: 0 }}>
                      <Box
                        border="1px solid"
                        borderColor="#524533"
                        bg="#1c1b1b"
                        p="6"
                        h="full"
                        _hover={{ transform: 'translate(-2px, -2px)' }}
                        transition="transform 0.2s ease"
                        className="card-hover-amber"
                      >
                        <Stack gap={3}>
                          <Text
                            fontFamily="JetBrains Mono, monospace"
                            fontSize="10px"
                            textTransform="uppercase"
                            letterSpacing="0.12em"
                            color="#ffd597"
                          >
                            Note
                          </Text>
                          <Heading
                            as="h4"
                            fontSize={{ base: '2xl', md: '3xl' }}
                            fontStyle="italic"
                            overflowWrap="anywhere"
                          >
                            {documentTitle}
                          </Heading>
                          <Wrap
                            fontSize="sm"
                            color="#9f8e78"
                            fontFamily="JetBrains Mono, monospace"
                          >
                            <Text>{collectionName}</Text> |{' '}
                            <Text>
                              {createdAt ? formatMonthYear(parseISO(createdAt), locale) : null}
                            </Text>
                          </Wrap>
                          <Text color="#c7c6c6" fontSize="sm">
                            {documentSummary.substring(0, 100) + '...'}
                          </Text>
                        </Stack>
                      </Box>
                    </Link>
                  );
                })}
              </Grid>
            </Stack>
            {(hasPrevPage || hasNextPage) && (
              <Box
                className={
                  hasPrevPage && hasNextPage
                    ? 'notes-pagination notes-pagination-between'
                    : hasNextPage
                      ? 'notes-pagination notes-pagination-end'
                      : 'notes-pagination notes-pagination-start'
                }
                display="flex"
                alignItems="center"
                pt="4"
                borderTopWidth="1px"
                borderTopStyle="solid"
                borderTopColor="#524533"
              >
                {hasPrevPage && (
                  <a
                    href={page === 2 ? `/${locale}/notes` : `/${locale}/notes?page=${page - 1}`}
                    style="display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border:1px solid #524533;background:#1c1b1b;color:#ffd597;font-family:'JetBrains Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.12em;text-decoration:none;transition:border-color 0.25s ease"
                    class="card-hover-amber"
                  >
                    ← {t('note.previous-entry')}
                  </a>
                )}
                {hasNextPage && (
                  <a
                    href={`/${locale}/notes?page=${page + 1}`}
                    style="display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border:1px solid #524533;background:#1c1b1b;color:#ffd597;font-family:'JetBrains Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:0.12em;text-decoration:none;transition:border-color 0.25s ease"
                    class="card-hover-amber"
                  >
                    {t('note.next-entry')} →
                  </a>
                )}
              </Box>
            )}
          </>
        )
      }
    </Stack>
  </Container>
</MainLayout>
