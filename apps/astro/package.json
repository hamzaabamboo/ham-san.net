{
  "name": "astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "bun codegen:panda",
    "codegen": "graphql-codegen",
    "codegen:prod": "graphql-codegen -c codegen.prod.yml && bun scripts/fix-codegen-prod.mjs",
    "codegen:panda": "panda codegen",
    "codegen:park-ui": "bunx @park-ui/cli add --all",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "compile": "tsc --pretty --noEmit",
    "format": "prettier -c --ignore-path .prettierignore 'src/**/*.{ts,tsx,astro}'",
    "format:fix": "prettier -w --ignore-path .prettierignore 'src/**/*.{ts,tsx,astro}'",
    "fix:all": "bun lint:fix && bun format:fix"
  },
  "dependencies": {
    "@ark-ui/react": "5.34.1",
    "@astrojs/check": "^0.9.9",
    "@astrojs/netlify": "^7.0.11",
    "@astrojs/node": "^10.1.2",
    "@astrojs/react": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "astro": "^6.4.2",
    "date-fns": "^4.4.0",
    "eslint-plugin-astro": "^1.7.0",
    "fets": "^0.8.6",
    "front-matter": "^4.0.2",
    "graphql-request": "^7.4.0",
    "graphql-tag": "^2.12.6",
    "lenis": "^1.3.23",
    "linkedom": "^0.18.12",
    "lodash": "^4.18.1",
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-gfm": "^3.1.0",
    "micromark-extension-gfm": "^3.0.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "remark-textr": "^6.1.0",
    "three": "^0.184.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-graphql-request": "^7.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.3",
    "@pandabox/prettier-plugin": "^0.1.3",
    "@pandacss/dev": "1.9.0",
    "@pandacss/eslint-plugin": "0.3.1",
    "@types/mdast": "^4.0.4",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "pandacss-preset-typography": "^0.1.6",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "vite": "7.3.5"
  }
}
