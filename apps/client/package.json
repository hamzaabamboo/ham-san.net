{
  "name": "client",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "serve": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "check": "svelte-kit sync",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "vitest",
    "lint": "eslint .",
    "sync": "svelte-kit sync",
    "start": "node --experimental-loader ./scripts/loader.js -r dotenv/config ../../dist/apps/client/index.js",
    "start:prod": "node --experimental-loader ./scripts/loader.js -r dotenv/config index.js",
    "codegen": "graphql-codegen",
    "codegen:prod": "graphql-codegen -c codegen.prod.yml",
    "build:prod": "bun codegen:prod && bun build"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.2",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-graphql-request": "^7.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.3",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/three": "0.171.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "@types/remove-markdown": "^0.3.4",
    "eslint-plugin-svelte": "^3.19.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "graphql-codegen-svelte-apollo": "^1.1.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.100.0",
    "svelte": "^5.56.1",
    "svelte-carousel": "^1.0.25",
    "svelte-check": "^4.5.0",
    "svelte-preprocess": "^6.0.5",
    "tailwindcss": "3.4.19",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-imagetools": "^10.0.0",
    "vitest": "^4.1.8",
    "vite-plugin-pwa": "^1.3.0"
  },
  "type": "module",
  "dependencies": {
    "@apollo/client": "^4.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "ammo.js": "^0.0.10",
    "ammojs3": "^0.0.11",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "fets": "^0.8.6",
    "graphql": "^16.12.0",
    "graphql-request": "7.4.0",
    "graphql-tag": "^2.12.6",
    "lodash": "^4.18.1",
    "remove-markdown": "^0.6.4",
    "resolve": "^1.22.12",
    "svelte-fa": "^4.0.4",
    "svelte-inview": "^4.0.4",
    "svelte-markdown": "^0.4.1",
    "sveltekit-i18n": "^2.4.2",
    "three": "0.171.0"
  },
  "volta": {
    "node": "18.20.1"
  }
}
